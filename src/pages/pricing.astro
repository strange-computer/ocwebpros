                <!-- CTA (mobile order 3) -->
                <div class="order-3 md:order-none text-center flex flex-col items-center">
                  <a href="/contact" class="inline-block px-8 py-3.5 bg-orange-600 text-white font-semibold rounded-full hover:bg-orange-500 transition-colors btn-glow text-sm md:text-base">
