---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Pricing | Lake Forest Websites" bodyClass="page-pricing">
  <link rel="stylesheet" href="/css/pages/pricing.css" />

  <header class="relative pt-32 sm:pt-32 md:pt-40 pb-12 sm:pb-16 px-4 sm:px-6 text-center overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90vw] max-w-[800px] h-[400px] sm:h-[500px] md:h-[600px] glow-bg pointer-events-none opacity-40"></div>
    <div class="max-w-5xl mx-auto relative">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-orange-400 mb-6">
        <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
        Pricing
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4">
        Clear pricing for <span class="text-gradient-orange">every service</span>
      </h1>
      <p class="text-zinc-400 text-lg leading-relaxed">
        Transparent pricing for web design, SEO, support, and hosting - built for real businesses.
      </p>
    </div>
  </header>

  <main class="pb-16 sm:pb-24 px-4 sm:px-6 md:px-8">
    <!-- Web Design Pricing Box -->
    <section class="max-w-7xl mx-auto pt-4 md:pt-8 pb-12 md:pb-16 px-4 sm:px-6">
      <div class="backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-2xl p-8 md:p-12 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-orange-500/5 via-transparent to-transparent pointer-events-none"></div>
        <div class="relative">
          <div class="text-center mb-8 md:mb-12">
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-3">Web Design</h2>
            <p class="text-zinc-400 text-lg max-w-2xl mx-auto">Your first step. We build the website itself - the pages, layout, and content that become your digital storefront. This is a one-time project that creates the foundation for everything else.</p>
          </div>
          <div class="max-w-5xl mx-auto relative">
        <!-- Glow orb behind card -->
        <div class="absolute -top-12 -left-12 w-64 h-64 md:w-80 md:h-80 bg-gradient-to-tr from-orange-500/20 to-purple-500/20 blur-3xl rounded-full pointer-events-none" aria-hidden="true"></div>
        <div class="web-design-pricing-card relative backdrop-blur-[12px] border border-white/10 rounded-2xl p-8 md:p-10 overflow-hidden transition-all duration-300 ease-out shadow-[0_10px_40px_-10px_rgba(0,0,0,0.5)]" style="background: rgba(24, 24, 27, 0.6);">
          <!-- Stronger gradient overlays -->
          <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 via-transparent to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 bg-gradient-to-tl from-purple-500/5 via-transparent to-transparent pointer-events-none"></div>
          
          <div class="relative">
            <!-- Mobile only: badge + headline at top -->
            <div class="text-center mb-4 md:hidden">
              <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-orange-400 mb-4">
                <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
                WEB ARCHITECTURE
              </div>
              <h2 class="text-2xl md:text-4xl font-bold mb-2 text-white tracking-tight">The &quot;Authority&quot; Website</h2>
              <p class="text-zinc-400 text-sm leading-relaxed max-w-xl mx-auto">Stop building digital brochures. We engineer high-performance assets designed to withstand Google&apos;s Core Web Vitals updates and capture local market share.</p>
            </div>

            <!-- Mobile: badge/headline (top) → price → features → CTA. Desktop: left = badge+headline+features, right = price+CTA -->
            <div class="flex flex-col md:grid gap-6 md:grid-cols-[1fr_auto] md:items-stretch">
              <!-- Left column: badge + headline (desktop only) + features -->
              <div class="order-2 md:order-1 md:col-start-1 md:row-start-1 md:pr-8 min-w-0">
                <div class="hidden md:block text-center mb-4">
                  <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-orange-400 mb-4">
                    <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
                    WEB ARCHITECTURE
                  </div>
                  <h2 class="text-2xl md:text-4xl font-bold mb-2 text-white tracking-tight">The &quot;Authority&quot; Website</h2>
                  <p class="text-zinc-400 text-sm leading-relaxed max-w-xl mx-auto">Stop building digital brochures. We engineer high-performance assets designed to withstand Google&apos;s Core Web Vitals updates and capture local market share.</p>
                </div>
                <ul class="grid grid-cols-2 md:grid-cols-3 gap-2 md:gap-2">
                  <li class="flex items-center gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                    <svg class="w-5 h-5 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span class="text-sm text-zinc-300">Strategy-First Sitemap</span>
                  </li>
                  <li class="flex items-center gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                    <svg class="w-5 h-5 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span class="text-sm text-zinc-300">Conversion-Engineered UI</span>
                  </li>
                  <li class="flex items-center gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                    <svg class="w-5 h-5 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span class="text-sm text-zinc-300">90+ Google Speed Score</span>
                  </li>
                  <li class="flex items-center gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                    <svg class="w-5 h-5 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span class="text-sm text-zinc-300">Local Schema Injection</span>
                  </li>
                  <li class="flex items-center gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                    <svg class="w-5 h-5 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
