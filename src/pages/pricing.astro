---
import MainLayout from '../layouts/MainLayout.astro';
import WebDesignFeatureGrid from '../components/WebDesignFeatureGrid.astro';
---
<MainLayout 
  title="Pricing | OCWebPros" 
  description="Transparent pricing for web design, local SEO, hosting, and support. Web design from $3,500, SEO from $500/mo, with clear scope and no surprise fees."
  bodyClass="page-pricing"
  pageCSS="/css/pages/pricing.css">

  <header class="relative pt-32 sm:pt-32 md:pt-40 pb-12 sm:pb-16 px-4 sm:px-6 text-center overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90vw] max-w-[800px] h-[400px] sm:h-[500px] md:h-[600px] glow-bg pointer-events-none opacity-40"></div>
    <div class="max-w-5xl mx-auto relative">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 border border-slate-200 text-xs font-medium text-orange-400 mb-6">
        <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
        Pricing
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4">
        Clear pricing for <span class="text-gradient-orange">every service</span>
      </h1>
      <p class="text-slate-600 text-lg leading-relaxed max-w-2xl mx-auto">
        Transparent pricing for web design, SEO, support, and hosting. Every number comes with real scope — so you know what you&apos;re buying before we talk.
      </p>
    </div>
  </header>

  <main class="pb-16 sm:pb-24 px-4 sm:px-6 md:px-8">
    <!-- Web Design Pricing Box -->
    <section id="web-design" class="max-w-7xl mx-auto pt-4 md:pt-8 pb-12 md:pb-16 px-4 sm:px-6 scroll-mt-28">
      <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-8 md:p-12 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-orange-500/5 via-transparent to-transparent pointer-events-none"></div>
        <div class="relative">
          <div class="text-center mb-8 md:mb-12">
            <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-3">Web Design</h2>
            <p class="text-slate-600 text-lg max-w-2xl mx-auto">Your first step. We build the website itself: the pages, layout, and content that become your digital storefront. This is a one-time project that creates the foundation for everything else.</p>
          </div>
          <div class="max-w-5xl mx-auto relative">
        <!-- Glow orb behind card -->
        <div class="absolute -top-12 -left-12 w-64 h-64 md:w-80 md:h-80 bg-gradient-to-tr from-orange-500/20 to-sky-500/20 blur-3xl rounded-full pointer-events-none" aria-hidden="true"></div>
        <div class="web-design-pricing-card relative backdrop-blur-[12px] border border-slate-200 rounded-2xl p-8 md:p-10 overflow-hidden transition-all duration-300 ease-out shadow-[0_10px_40px_-10px_rgba(15,23,42,0.12)]" style="background: #ffffff;">
          <!-- Stronger gradient overlays -->
          <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 via-transparent to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 bg-gradient-to-tl from-orange-500/5 via-transparent to-transparent pointer-events-none"></div>
          
          <div class="relative">
            <!-- Mobile only: badge + headline at top -->
            <div class="text-center mb-4 md:hidden">
              <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 border border-slate-200 text-xs font-medium text-orange-400 mb-4">
                <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
                WEB ARCHITECTURE
              </div>
              <h2 class="text-2xl md:text-4xl font-bold mb-2 text-slate-900 tracking-tight">The &quot;Authority&quot; Website</h2>
              <p class="text-slate-600 text-sm leading-relaxed max-w-xl mx-auto">High-performance websites built to meet Core Web Vitals standards and capture local market share.</p>
            </div>

            <!-- Mobile: badge/headline (top) → price → features → CTA. Desktop: left = badge+headline+features, right = price+CTA -->
            <div class="flex flex-col md:grid gap-6 md:grid-cols-[1.15fr_auto] md:items-stretch">
              <!-- Left column: badge + headline (desktop only) + features -->
              <div class="order-2 md:order-1 md:col-start-1 md:row-start-1 md:pr-8 min-w-0">
                <div class="hidden md:block text-center mb-4">
                  <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 border border-slate-200 text-xs font-medium text-orange-400 mb-4">
                    <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
                    WEB ARCHITECTURE
                  </div>
                  <h2 class="text-2xl md:text-4xl font-bold mb-2 text-slate-900 tracking-tight">The &quot;Authority&quot; Website</h2>
                  <p class="text-slate-600 text-sm leading-relaxed max-w-xl mx-auto">High-performance websites built to meet Core Web Vitals standards and capture local market share.</p>
                </div>
                <WebDesignFeatureGrid />
              </div>

              <!-- Right column: price + CTA in one block (single cell on desktop, display:contents on mobile for order) -->
              <div class="contents md:flex md:flex-col md:gap-4 md:pl-8 md:border-l md:border-slate-200 md:col-start-2 md:row-start-1 md:justify-center">
                <!-- Price (mobile order 1) -->
                <div class="order-1 md:order-none text-center flex flex-col items-center">
                  <p class="text-orange-400 text-xs font-semibold uppercase tracking-wide mb-2">Starting at</p>
                  <div class="text-4xl md:text-5xl font-bold text-slate-900 mb-1">
                    <span class="text-xl md:text-2xl align-top">$</span>3,500
                  </div>
                  <p class="text-slate-600 text-sm">One-Time Project</p>
                  <p class="text-slate-500 text-xs mt-2 max-w-[200px]">Most builds land between $3,500 and $5,000</p>
                </div>
                <!-- CTA (mobile order 3) -->
                <div class="order-3 md:order-none text-center flex flex-col items-center">
                  <button class="add-to-cart inline-block px-8 py-3.5 bg-orange-700 text-white font-semibold rounded-full hover:bg-orange-600 transition-colors btn-glow text-sm md:text-base cursor-pointer"
                    data-item-id="web-design"
                    data-name="Web Design - Authority Website"
                    data-price="3500"
                    data-category="web-design"
                    data-type="one-time">
                    Add to Plan
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>

          <!-- Starter scope + price drivers -->
          <div class="max-w-5xl mx-auto mt-8 md:mt-10 grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="pricing-scope-card backdrop-blur-[12px] border border-slate-200 rounded-2xl p-6 md:p-8 relative overflow-hidden" style="background: #ffffff;">
              <div class="absolute inset-0 bg-gradient-to-br from-orange-500/5 via-transparent to-transparent pointer-events-none"></div>
              <div class="relative">
                <h3 class="text-lg font-bold text-slate-900 mb-1">What&apos;s included at the starting price</h3>
                <p class="text-slate-500 text-sm mb-5">The baseline &quot;Authority&quot; package — built for most local businesses.</p>
                <ul class="space-y-2.5">
                  <li class="flex items-start gap-2.5 text-sm text-slate-700"><span class="w-1.5 h-1.5 rounded-full bg-orange-500 mt-2 flex-shrink-0"></span>Up to 5–7 core pages (Home, About, Services, Contact, and more)</li>
                  <li class="flex items-start gap-2.5 text-sm text-slate-700"><span class="w-1.5 h-1.5 rounded-full bg-orange-500 mt-2 flex-shrink-0"></span>Custom mobile-first design — no templates</li>
                  <li class="flex items-start gap-2.5 text-sm text-slate-700"><span class="w-1.5 h-1.5 rounded-full bg-orange-500 mt-2 flex-shrink-0"></span>Contact &amp; lead forms wired and tested</li>
                  <li class="flex items-start gap-2.5 text-sm text-slate-700"><span class="w-1.5 h-1.5 rounded-full bg-orange-500 mt-2 flex-shrink-0"></span>Local SEO foundations &amp; analytics setup</li>
                  <li class="flex items-start gap-2.5 text-sm text-slate-700"><span class="w-1.5 h-1.5 rounded-full bg-orange-500 mt-2 flex-shrink-0"></span>Two revision rounds before launch</li>
                  <li class="flex items-start gap-2.5 text-sm text-slate-700"><span class="w-1.5 h-1.5 rounded-full bg-orange-500 mt-2 flex-shrink-0"></span>Typical launch in 4–6 weeks</li>
                </ul>
                <p class="text-slate-500 text-xs mt-5 pt-5 border-t border-slate-200">
                  <span class="text-emerald-400 font-medium">Managed hosting ($75/mo) is required</span> for every site we build. SEO and support are optional add-ons you can stack later.
                </p>
              </div>
            </div>

            <div class="pricing-scope-card backdrop-blur-[12px] border border-slate-200 rounded-2xl p-6 md:p-8 relative overflow-hidden" style="background: #ffffff;">
              <div class="absolute inset-0 bg-gradient-to-br from-orange-500/5 via-transparent to-transparent pointer-events-none"></div>
              <div class="relative">
                <h3 class="text-lg font-bold text-slate-900 mb-1">What can increase your investment</h3>
                <p class="text-slate-500 text-sm mb-5">Not arbitrary — these are the things that add real build time.</p>
                <ul class="space-y-2.5">
                  <li class="flex items-start gap-2.5 text-sm text-slate-700"><span class="w-1.5 h-1.5 rounded-full bg-orange-100 mt-2 flex-shrink-0"></span>Extra service or location pages</li>
                  <li class="flex items-start gap-2.5 text-sm text-slate-700"><span class="w-1.5 h-1.5 rounded-full bg-orange-100 mt-2 flex-shrink-0"></span>Full copywriting from scratch</li>
                  <li class="flex items-start gap-2.5 text-sm text-slate-700"><span class="w-1.5 h-1.5 rounded-full bg-orange-100 mt-2 flex-shrink-0"></span>Advanced forms, booking, or payment flows</li>
                  <li class="flex items-start gap-2.5 text-sm text-slate-700"><span class="w-1.5 h-1.5 rounded-full bg-orange-100 mt-2 flex-shrink-0"></span>E-commerce or product catalog functionality</li>
                  <li class="flex items-start gap-2.5 text-sm text-slate-700"><span class="w-1.5 h-1.5 rounded-full bg-orange-100 mt-2 flex-shrink-0"></span>Content migration from an existing website</li>
                  <li class="flex items-start gap-2.5 text-sm text-slate-700"><span class="w-1.5 h-1.5 rounded-full bg-orange-100 mt-2 flex-shrink-0"></span>Accelerated launch timelines</li>
                </ul>
                <p class="text-slate-500 text-xs mt-5 pt-5 border-t border-slate-200">We&apos;ll walk through scope on your consultation call — no surprise invoice at the end.</p>
              </div>
            </div>
          </div>
      </div>
        </div>
      </div>
    </section>

    <!-- Local SEO Pricing Tiers -->
    <section id="local-seo" class="max-w-7xl mx-auto pt-4 md:pt-8 pb-12 md:pb-16 px-4 sm:px-6 scroll-mt-28">
      <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-8 md:p-12 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-orange-500/5 via-transparent to-transparent pointer-events-none"></div>
        <div class="relative">
          <div class="text-center mb-8 md:mb-12">
            <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-3">Local SEO</h2>
            <p class="text-slate-600 text-lg max-w-2xl mx-auto">After your site is built, SEO gets you found on Google. We optimize your pages, manage your Google Business Profile, and build the authority that brings customers to your door. Ongoing monthly service.</p>
          </div>
      <div class="relative text-center mb-8" data-aos="fade-up">
        <!-- Subtle glow behind header -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-72 h-48 md:w-96 md:h-56 bg-gradient-to-tr from-orange-500/15 to-sky-500/15 blur-3xl rounded-full pointer-events-none" aria-hidden="true"></div>
        <div class="relative">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 border border-slate-200 text-xs font-medium text-orange-400 mb-4">
            <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
            Local SEO Pricing
          </div>
          <h2 class="text-2xl md:text-3xl font-bold mb-2 text-slate-900">Choose your plan</h2>
          <p class="text-slate-600 text-sm md:text-base">Monthly packages to fit your business needs</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-6xl mx-auto">
        <!-- Tier 1: The Foundation -->
        <div class="local-seo-pricing-card backdrop-blur-[12px] border border-slate-200 rounded-2xl p-6 md:p-8 overflow-hidden relative flex flex-col transition-all duration-300 ease-out" style="background: #ffffff;">
          <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 via-transparent to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 bg-gradient-to-tl from-orange-500/5 via-transparent to-transparent pointer-events-none"></div>
          <div class="relative flex flex-col flex-1">
            <div class="mb-6">
              <h3 class="text-xl font-bold text-slate-900 mb-2">The Foundation</h3>
              <div class="text-4xl font-bold text-slate-900 mb-1">
                <span class="text-lg align-top">$</span>500
              </div>
              <p class="text-slate-600 text-sm">per month</p>
              <p class="text-orange-400 text-xs font-medium mt-2">Maintain listings, technical health &amp; GBP activity</p>
              <p class="text-slate-600 text-sm mt-2">For established businesses that need to keep their digital doors open and technical health green.</p>
            </div>
            <ul class="space-y-2 mb-6 flex-1">
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-slate-100 hover:border-slate-200">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm text-slate-700">Google Map Protection: Weekly posts &amp; spam fighting.</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-slate-100 hover:border-slate-200">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm text-slate-700">Search Health Monitor: Monthly crawl errors, index issues, and broken internal link fixes.</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-slate-100 hover:border-slate-200">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm text-slate-700">Review Management: Monitor Google &amp; Yelp, alert you to every new review, and flag suspicious or policy-violating ones.</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-slate-100 hover:border-slate-200">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm text-slate-700">Citation Upkeep: Keeping your address consistent on Yelp/Bing.</span>
              </li>
            </ul>
            <button class="add-to-cart block w-full px-6 py-3 bg-slate-100 text-slate-900 font-semibold rounded-full text-center border border-slate-200 hover:bg-slate-100 transition-colors text-sm mt-auto cursor-pointer"
              data-item-id="seo-foundation"
              data-name="Local SEO - The Foundation"
              data-price="500"
              data-category="seo"
              data-type="subscription"
              data-interval="month">
              Add to Plan
            </button>
          </div>
        </div>

        <!-- Tier 2: The Growth Engine (Featured) -->
        <div class="local-seo-pricing-card backdrop-blur-[12px] border-2 border-orange-500/50 rounded-2xl p-6 md:p-8 overflow-hidden relative flex flex-col transition-all duration-300 ease-out" style="background: #ffffff;">
          <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 via-transparent to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 bg-gradient-to-tl from-orange-500/5 via-transparent to-transparent pointer-events-none"></div>
          <div class="absolute top-4 right-4">
            <span class="px-2 py-1 bg-orange-700 text-white text-xs font-semibold rounded-full">Recommended</span>
          </div>
          <div class="relative flex flex-col flex-1">
            <div class="mb-6">
              <h3 class="text-xl font-bold text-slate-900 mb-2">The Growth Engine</h3>
              <div class="text-4xl font-bold text-slate-900 mb-1">
                <span class="text-lg align-top">$</span>1,250
              </div>
              <p class="text-slate-600 text-sm">per month</p>
              <p class="text-orange-400 text-xs font-medium mt-2">Content, page optimization &amp; local authority</p>
              <p class="text-slate-600 text-sm mt-2">For businesses ready to expand their service area and capture high-intent leads from competitors.</p>
            </div>
            <ul class="space-y-2 mb-6 flex-1">
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-emerald-500/5 border border-emerald-500/20 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-emerald-500/10 hover:border-emerald-500/30">
                <svg class="w-5 h-5 text-emerald-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm font-semibold text-emerald-400">Everything in Foundation, PLUS:</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-slate-100 hover:border-slate-200">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm text-slate-700">2 Strategic Articles/Mo: We write content that answers customer questions.</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-slate-100 hover:border-slate-200">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm text-slate-700">Competitor Gap Analysis: Find and capture keyword opportunities your competitors are ranking for.</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-slate-100 hover:border-slate-200">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm text-slate-700">Local Link Building: Monthly outreach to relevant local sites, directories, and community resources.</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-slate-100 hover:border-slate-200">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm text-slate-700">On-Page SEO Optimization: Keyword-focused updates to titles, headings, internal links, and page copy.</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-slate-100 hover:border-slate-200">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm text-slate-700">Live Dashboard: 24/7 view of your keyword rankings.</span>
              </li>
            </ul>
            <button class="add-to-cart block w-full px-6 py-3 bg-orange-700 text-white font-semibold rounded-full text-center hover:bg-orange-600 transition-colors btn-glow text-sm mt-auto cursor-pointer"
              data-item-id="seo-growth"
              data-name="Local SEO - The Growth Engine"
              data-price="1250"
              data-category="seo"
              data-type="subscription"
              data-interval="month">
              Add to Plan
            </button>
          </div>
        </div>

        <!-- Tier 3: Market Dominance -->
        <div class="local-seo-pricing-card backdrop-blur-[12px] border border-slate-200 rounded-2xl p-6 md:p-8 overflow-hidden relative flex flex-col transition-all duration-300 ease-out" style="background: #ffffff;">
          <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 via-transparent to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 bg-gradient-to-tl from-orange-500/5 via-transparent to-transparent pointer-events-none"></div>
          <div class="relative flex flex-col flex-1">
            <div class="mb-6">
              <h3 class="text-xl font-bold text-slate-900 mb-2">Market Dominance</h3>
              <div class="text-4xl font-bold text-slate-900 mb-1">
                <span class="text-lg align-top">$</span>3,000
              </div>
              <p class="text-slate-600 text-sm">per month</p>
              <p class="text-orange-400 text-xs font-medium mt-2">Multi-city expansion with heavier content &amp; outreach</p>
              <p class="text-slate-600 text-sm mt-2">For franchises and ambitious brands pushing into multiple cities or service areas across Orange County.</p>
            </div>
            <ul class="space-y-2 mb-6 flex-1">
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-emerald-500/5 border border-emerald-500/20 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-emerald-500/10 hover:border-emerald-500/30">
                <svg class="w-5 h-5 text-emerald-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
