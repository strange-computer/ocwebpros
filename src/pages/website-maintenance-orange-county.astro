---
import MainLayout from '../layouts/MainLayout.astro';
import SpotlightImage from '../components/SpotlightImage.astro';
---
<MainLayout 
  title="Website Maintenance Orange County CA | OCWebPros" 
  description="Website maintenance for Orange County businesses. Security updates, daily backups, performance monitoring, and content updates - with local support from Lake Forest, CA. Plans from $50/mo."
  bodyClass="page-support page-maintenance"
  pageCSS="/css/pages/support.css">

  <header class="relative pt-32 sm:pt-32 md:pt-40 pb-12 sm:pb-16 px-4 sm:px-6 text-center overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90vw] max-w-[800px] h-[400px] sm:h-[500px] md:h-[600px] glow-bg pointer-events-none opacity-40"></div>
    <div class="max-w-5xl mx-auto relative">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 border border-slate-200 text-xs font-medium text-orange-400 mb-6">
        <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
        Website Maintenance
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4">
        Website Maintenance in <span class="text-gradient-orange">Orange County</span>
      </h1>
      <p class="text-slate-600 text-lg leading-relaxed max-w-3xl mx-auto">
        Keep your site secure, fast, and reliable - with proactive maintenance from a local team in Lake Forest. No overseas handoffs, no ticket queues.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a href="/contact" class="px-8 py-3.5 bg-orange-700 text-white font-semibold rounded-full hover:bg-orange-600 transition-colors btn-glow text-sm md:text-base">
          Get a Free Maintenance Audit
        </a>
        <a href="/pricing#support" class="px-8 py-3.5 bg-slate-100 text-slate-900 font-semibold rounded-full border border-slate-200 hover:bg-slate-100 transition-colors text-sm md:text-base">
          View Pricing
        </a>
      </div>
    </div>
  </header>

  <main class="pb-16 sm:pb-24 px-4 sm:px-6 md:px-8">
    <!-- Spotlight -->
    <section class="max-w-7xl mx-auto pt-8 md:pt-12 pb-16 md:pb-24 px-4 sm:px-6">
      <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
        <div class="w-full md:w-1/2 backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6 sm:p-8 md:p-10" data-aos="fade-right">
          <div class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h2 class="text-3xl md:text-4xl font-bold mb-4 text-slate-900">More Than Occasional Updates</h2>
          <p class="text-slate-600 mb-6 text-lg leading-relaxed">Your website is your digital storefront. For Orange County businesses in Irvine, Mission Viejo, and beyond, effective maintenance is proactive upkeep, not a checkbox.</p>
          <ul class="space-y-3 text-slate-700">
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Security and dependency updates, malware scanning, and SSL monitoring</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Daily automated backups with one-click restore</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Regular content updates and technical site health checks</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Direct email and phone support from Lake Forest, CA</span></li>
          </ul>
        </div>
        <SpotlightImage
          src="/images/unsplash/support-development.jpg"
          alt="Developer maintaining a business website at a laptop"
          aos="fade-left"
        />
      </div>
    </section>

    <!-- Five Pillars -->
    <section class="max-w-7xl mx-auto pt-2 md:pt-4 pb-16 md:pb-24 px-4 sm:px-6 md:px-8">
      <div class="text-center mb-12" data-aos="fade-up">
        <h2 class="text-2xl md:text-3xl font-bold mb-2 text-slate-900">What Website Maintenance Includes</h2>
        <p class="text-slate-600 text-sm md:text-base max-w-2xl mx-auto">Support covers website operations: code, speed, backups, and edits.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6" data-aos="fade-up" data-aos-delay="0">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Security &amp; Monitoring</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Security and dependency updates, firewall protection, malware scanning, and brute-force login prevention - with alerts sent directly to you.</p>
        </div>
        <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6" data-aos="fade-up" data-aos-delay="100">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Daily Backups</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Automated off-site backups with one-click restore. You&apos;re never more than 24 hours away from recovery if something goes wrong.</p>
        </div>
        <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6" data-aos="fade-up" data-aos-delay="200">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Performance Monitoring</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Uptime tracking, Core Web Vitals checks, and image audits to keep your site fast for Orange County customers on every device.</p>
        </div>
        <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6" data-aos="fade-up" data-aos-delay="300">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Content Updates</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Service changes, team updates, testimonials, and seasonal offers - keep your site fresh without managing a freelancer.</p>
        </div>
        <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6" data-aos="fade-up" data-aos-delay="400">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Technical Site Checks</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Broken-link scans, sitemap validation, redirect checks, and post-update verification, keeping your site&apos;s technical foundation solid.</p>
        </div>
        <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6" data-aos="fade-up" data-aos-delay="500">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Local Support, Same Time Zone</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Based in Lake Forest - not outsourced overseas. Same-time-zone responses, local market understanding, and direct access to the people maintaining your site.</p>
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="max-w-7xl mx-auto pt-4 md:pt-8 pb-12 md:pb-16 px-4 sm:px-6">
      <div class="relative text-center mb-8" data-aos="fade-up">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-72 h-48 md:w-96 md:h-56 bg-gradient-to-tr from-orange-500/15 to-sky-500/15 blur-3xl rounded-full pointer-events-none" aria-hidden="true"></div>
        <div class="relative">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 border border-slate-200 text-xs font-medium text-orange-400 mb-4">
            <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
            Support Plans
          </div>
          <h2 class="text-2xl md:text-3xl font-bold mb-2 text-slate-900">Choose your plan</h2>
          <p class="text-slate-600 text-sm md:text-base">Monthly plans to fit your business needs</p>
          <p class="text-slate-500 text-sm mt-3">Support plans are for websites we&apos;ve built and host: security updates, performance monitoring, content edits, and ongoing upkeep.</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-6xl mx-auto">
        <div class="support-pricing-card backdrop-blur-[12px] border border-slate-200 rounded-2xl p-6 md:p-8 overflow-hidden relative flex flex-col transition-all duration-300 ease-out" style="background: #ffffff;">
          <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 via-transparent to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 bg-gradient-to-tl from-orange-500/5 via-transparent to-transparent pointer-events-none"></div>
          <div class="relative flex flex-col flex-1">
            <div class="mb-6">
              <h3 class="text-xl font-bold text-slate-900 mb-2">The &quot;Technical&quot; Plan</h3>
              <div class="text-4xl font-bold text-slate-900 mb-1"><span class="text-lg align-top">$</span>50</div>
              <p class="text-slate-600 text-sm">per month</p>
              <p class="text-slate-600 text-sm mt-2">For businesses that want ongoing technical upkeep.</p>
            </div>
            <ul class="space-y-2 mb-6 flex-1">
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-slate-100 hover:border-slate-200">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-slate-700">Security &amp; Dependency Updates: We keep your site&apos;s code and dependencies current and secure.</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-slate-100 hover:border-slate-200">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-slate-700">Post-Update Checks: We verify updates didn&apos;t break your design or layout.</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-slate-100 hover:border-slate-200">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-slate-700">Monthly PDF Report: Clear summary of updates and site performance.</span>
              </li>
            </ul>
            <a href="/pricing#support" class="block w-full px-6 py-3 bg-slate-100 text-slate-900 font-semibold rounded-full text-center border border-slate-200 hover:bg-slate-100 transition-colors text-sm mt-auto">Get Started</a>
          </div>
        </div>

        <div class="support-pricing-card backdrop-blur-[12px] border-2 border-orange-500/50 rounded-2xl p-6 md:p-8 overflow-hidden relative flex flex-col transition-all duration-300 ease-out" style="background: #ffffff;">
          <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 via-transparent to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 bg-gradient-to-tl from-orange-500/5 via-transparent to-transparent pointer-events-none"></div>
          <div class="absolute top-4 right-4">
            <span class="px-2 py-1 bg-orange-700 text-white text-xs font-semibold rounded-full">Recommended</span>
          </div>
          <div class="relative flex flex-col flex-1">
            <div class="mb-6">
              <h3 class="text-xl font-bold text-slate-900 mb-2">The &quot;Content&quot; Plan</h3>
              <div class="text-4xl font-bold text-slate-900 mb-1"><span class="text-lg align-top">$</span>125</div>
              <p class="text-slate-600 text-sm">per month</p>
              <p class="text-slate-600 text-sm mt-2">For businesses that need regular website updates.</p>
            </div>
            <ul class="space-y-2 mb-6 flex-1">
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg transition-all duration-200 ease-out hover:-translate-y-0.5" style="background-color: rgba(249, 115, 22, 0.1); border: 1px solid rgba(249, 115, 22, 0.25);">
                <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: #B450C8;">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm font-semibold" style="color: #B450C8;">Everything in Technical, PLUS:</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-slate-100 hover:border-slate-200">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-slate-700">1 Hour of Content Edits: Send us your text/image changes, and we do them for you.</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-slate-100 hover:border-slate-200">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-slate-700">Priority Support: You skip the line. 24-hour turnaround guarantee.</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-slate-100 hover:border-slate-200">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-slate-700">Performance Audits: Regular checkups to ensure Google still loves your speed.</span>
              </li>
            </ul>
            <a href="/pricing#support" class="block w-full px-6 py-3 bg-orange-700 text-white font-semibold rounded-full text-center hover:bg-orange-600 transition-colors btn-glow text-sm mt-auto">Get Started</a>
          </div>
        </div>

        <div class="support-pricing-card backdrop-blur-[12px] border border-slate-200 rounded-2xl p-6 md:p-8 overflow-hidden relative flex flex-col transition-all duration-300 ease-out" style="background: #ffffff;">
          <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 via-transparent to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 bg-gradient-to-tl from-orange-500/5 via-transparent to-transparent pointer-events-none"></div>
          <div class="relative flex flex-col flex-1">
            <div class="mb-6">
              <h3 class="text-xl font-bold text-slate-900 mb-2">The &quot;VIP&quot; Plan</h3>
              <div class="text-4xl font-bold text-slate-900 mb-1"><span class="text-lg align-top">$</span>250</div>
              <p class="text-slate-600 text-sm">per month</p>
              <p class="text-slate-600 text-sm mt-2">For high-traffic sites or businesses that need maximum support.</p>
            </div>
            <ul class="space-y-2 mb-6 flex-1">
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg transition-all duration-200 ease-out hover:-translate-y-0.5" style="background-color: rgba(249, 115, 22, 0.1); border: 1px solid rgba(249, 115, 22, 0.25);">
                <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: #B450C8;">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm font-semibold" style="color: #B450C8;">Everything in Content, PLUS:</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-slate-100 hover:border-slate-200">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-slate-700">2 Hours of Content Edits: Text, images, and small changes when you need them.</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-slate-100 hover:border-slate-200">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-slate-700">Emergency Response: Immediate top priority for downtime, bugs, and urgent site issues.</span>
              </li>
            </ul>
            <a href="/pricing#support" class="block w-full px-6 py-3 bg-slate-100 text-slate-900 font-semibold rounded-full text-center border border-slate-200 hover:bg-slate-100 transition-colors text-sm mt-auto">Get Started</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Related -->
    <section class="max-w-7xl mx-auto py-16 md:py-24 px-4 sm:px-6 md:px-8 bg-slate-50 border-y border-slate-100">
      <div class="grid md:grid-cols-3 gap-6">
        <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6 sm:p-8" data-aos="fade-up">
          <h3 class="text-xl font-bold text-slate-900 mb-3">Managed Hosting</h3>
          <p class="text-sm text-slate-600 leading-relaxed mb-4">Pair maintenance with managed hosting: CDN, SSL, deploy rollback, and uptime monitoring included.</p>
          <a href="/hosting" class="text-sm text-orange-400 font-medium hover:text-orange-300 transition-colors inline-flex items-center gap-1">
            View hosting plans
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          </a>
        </div>
        <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6 sm:p-8" data-aos="fade-up" data-aos-delay="100">
          <h3 class="text-xl font-bold text-slate-900 mb-3">Full Support Details</h3>
          <p class="text-sm text-slate-600 leading-relaxed mb-4">See everything our support team handles - from layout issues and broken forms to content edits and emergency fixes.</p>
          <a href="/support" class="text-sm text-orange-400 font-medium hover:text-orange-300 transition-colors inline-flex items-center gap-1">
            Explore web support
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          </a>
        </div>
        <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6 sm:p-8" data-aos="fade-up" data-aos-delay="200">
          <h3 class="text-xl font-bold text-slate-900 mb-3">Local SEO Services</h3>
          <p class="text-sm text-slate-600 leading-relaxed mb-4">Grow your presence on Google Maps, build citations, publish local content, and improve rankings. Local SEO plans start at $500/mo.</p>
