---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout 
  title="Order Successful | OCWebPros" 
  description="Thank you for your order! We'll be in touch within 1 business day to get started on your project."
  bodyClass="page-success">

  <header class="relative pt-32 sm:pt-32 md:pt-40 pb-12 sm:pb-16 px-4 sm:px-6 text-center overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90vw] max-w-[800px] h-[400px] sm:h-[500px] md:h-[600px] glow-bg pointer-events-none opacity-40"></div>
    <div class="max-w-5xl mx-auto relative">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-emerald-500/10 border border-emerald-500/30 text-sm font-medium text-emerald-300 mb-6">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
        Payment Successful
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4">
        Thank you for <span class="text-gradient-orange">your order!</span>
      </h1>
      <p class="text-zinc-400 text-lg leading-relaxed">
        Your payment has been processed successfully. We'll be in touch shortly to get started.
      </p>
    </div>
  </header>

  <main class="pb-24 px-6 md:px-8">
    <div class="max-w-3xl mx-auto">
      <!-- Success Card -->
      <div class="backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-2xl p-8 md:p-10 mb-8">
        <div class="flex items-center gap-4 mb-6 pb-6 border-b border-white/10">
          <div class="w-12 h-12 bg-emerald-500/10 border border-emerald-500/30 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <div>
            <h2 class="text-xl font-bold text-white">Order Confirmed</h2>
            <p class="text-sm text-zinc-400">Check your email for confirmation details</p>
          </div>
        </div>

        <div class="space-y-4">
          <h3 class="font-semibold text-white mb-3">What happens next?</h3>
          
          <div class="flex gap-4">
            <div class="w-8 h-8 bg-orange-500/10 border border-orange-500/30 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
              <span class="text-orange-400 font-bold text-sm">1</span>
            </div>
            <div>
              <h4 class="font-semibold text-white text-sm mb-1">Confirmation Email</h4>
              <p class="text-sm text-zinc-400">You'll receive a confirmation email with your receipt and order details within the next few minutes.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="w-8 h-8 bg-orange-500/10 border border-orange-500/30 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
              <span class="text-orange-400 font-bold text-sm">2</span>
            </div>
            <div>
              <h4 class="font-semibold text-white text-sm mb-1">Kickoff Call</h4>
              <p class="text-sm text-zinc-400">We'll reach out within 1 business day to schedule your project kickoff call and discuss next steps.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="w-8 h-8 bg-orange-500/10 border border-orange-500/30 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
              <span class="text-orange-400 font-bold text-sm">3</span>
            </div>
            <div>
              <h4 class="font-semibold text-white text-sm mb-1">We Get to Work</h4>
              <p class="text-sm text-zinc-400">Our team begins working on your project immediately to deliver the results you're expecting.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Info -->
      <div class="backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-2xl p-6 text-center">
        <h3 class="font-semibold text-white mb-2">Questions about your order?</h3>
        <p class="text-sm text-zinc-400 mb-4">We're here to help</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="mailto:hello@ocwebpros.com" class="px-6 py-2.5 bg-white/5 text-white font-semibold rounded-full border border-white/10 hover:bg-white/10 transition-colors text-sm">
            Email Us
          </a>
          <a href="tel:9493294437" class="px-6 py-2.5 bg-white/5 text-white font-semibold rounded-full border border-white/10 hover:bg-white/10 transition-colors text-sm">
            Call (949) 329-4437
          </a>
        </div>
      </div>

      <!-- Back to Home -->
      <div class="text-center mt-8">
        <a href="/" class="text-zinc-400 hover:text-white transition-colors text-sm">
          ← Back to home
        </a>
      </div>
    </div>
  </main>

  <script is:inline>
    // Clear cart after successful purchase
    if (window.cart) {
      window.cart.clearCart();
    }
  </script>
</MainLayout>
