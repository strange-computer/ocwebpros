---
import MainLayout from '../../layouts/MainLayout.astro';
import SpotlightImage from '../../components/SpotlightImage.astro';
---
<MainLayout 
  title="SEO Strategy Services Orange County CA | OCWebPros" 
  description="Data-driven SEO for Orange County businesses. Keyword research, topic planning, and competitor analysis delivered through monthly SEO plans from $500/mo."
  bodyClass="page-services page-seo-strategy"
  pageCSS="/css/pages/services.css">

  <header class="relative pt-32 sm:pt-32 md:pt-40 pb-12 sm:pb-16 px-4 sm:px-6 text-center overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90vw] max-w-[800px] h-[400px] sm:h-[500px] md:h-[600px] glow-bg pointer-events-none opacity-40"></div>
    <div class="max-w-5xl mx-auto relative">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 border border-slate-200 text-xs font-medium text-orange-400 mb-6">
        <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
        SEO Strategy
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4">
        SEO Strategy for <span class="text-gradient-orange">Orange County</span>
      </h1>
      <p class="text-slate-600 text-lg leading-relaxed max-w-3xl mx-auto">
        Data-driven search strategy built on real keyword demand, competitor gaps, and search intent - delivered through our monthly SEO plans.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a href="/contact" class="px-8 py-3.5 bg-orange-700 text-white font-semibold rounded-full hover:bg-orange-600 transition-colors btn-glow text-sm md:text-base">
          Request a Consult
        </a>
        <a href="/pricing" class="px-8 py-3.5 bg-slate-100 text-slate-900 font-semibold rounded-full border border-slate-200 hover:bg-slate-100 transition-colors text-sm md:text-base">
          View Pricing
        </a>
      </div>
    </div>
  </header>

  <main class="pb-16 sm:pb-24 px-4 sm:px-6 md:px-8">
    <!-- Spotlight -->
    <section class="max-w-7xl mx-auto pt-8 md:pt-12 pb-16 md:pb-24 px-4 sm:px-6">
      <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
        <div class="w-full md:w-1/2 backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6 sm:p-8 md:p-10" data-aos="fade-right">
          <div class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          </div>
          <h2 class="text-3xl md:text-4xl font-bold mb-4 text-slate-900">Strategy Before Tactics</h2>
          <p class="text-slate-600 mb-6 text-lg leading-relaxed">Ranking in 2026 means building topical authority, matching search intent, and covering the subtopics your competitors already own. On Growth and Dominance plans, we start with research and architecture - then execute month over month.</p>
          <ul class="space-y-3 text-slate-700">
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Ahrefs-powered keyword research and fan-out topic analysis</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Competitor gap analysis to find overlooked ranking opportunities</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Topic cluster architecture with clear internal linking plans</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Search intent mapping before a single page gets written</span></li>
          </ul>
        </div>
        <SpotlightImage
          src="/images/unsplash/services-seo-strategy.jpg"
          alt="SEO strategy and analytics review on laptop"
        />
      </div>
    </section>

    <!-- What We Deliver -->
    <section class="max-w-7xl mx-auto pt-2 md:pt-4 pb-16 md:pb-24 px-4 sm:px-6 md:px-8">
      <div class="text-center mb-12" data-aos="fade-up">
        <h2 class="text-2xl md:text-3xl font-bold mb-2 text-slate-900">What Our SEO Strategy Includes</h2>
        <p class="text-slate-600 text-sm md:text-base max-w-2xl mx-auto">How we approach SEO across our plans. Full research, content strategy, and gap analysis are included on Growth and Dominance; Foundation focuses on technical and local upkeep.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        <div data-aos="fade-up" data-aos-delay="0">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Keyword Research</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Comprehensive research using Ahrefs to identify search volume, difficulty, traffic potential, and question-based queries your customers actually use.</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="100">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Competitor Analysis</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Content gap analysis reveals keywords competitors rank for that you don't - often the fastest path to new traffic.</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="200">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Topic Cluster Planning</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Pillar pages and supporting content mapped into clusters with internal linking - built for Google Web Guide and AI Overview visibility.</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="300">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Intent Mapping</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Every target keyword is matched to the content type that actually ranks - blog posts, service pages, tools, or landing pages.</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="400">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Content Strategy</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Editorial calendars, content briefs, and on-page optimization aligned to your business goals and Orange County market.</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="500">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Rank Tracking &amp; Reporting</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Live dashboards for keyword rankings, traffic trends, and impression spikes - with clear next steps every month.</p>
        </div>
      </div>
    </section>

    <!-- Pricing Tiers -->
    <section class="max-w-7xl mx-auto pt-4 md:pt-8 pb-12 md:pb-16 px-4 sm:px-6">
      <div class="relative text-center mb-8" data-aos="fade-up">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-72 h-48 md:w-96 md:h-56 bg-gradient-to-tr from-orange-500/15 to-sky-500/15 blur-3xl rounded-full pointer-events-none" aria-hidden="true"></div>
        <div class="relative">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 border border-slate-200 text-xs font-medium text-orange-400 mb-4">
            <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
            Local SEO Plans
          </div>
          <h2 class="text-2xl md:text-3xl font-bold mb-2 text-slate-900">Choose your plan</h2>
          <p class="text-slate-600 text-sm md:text-base">Monthly SEO service - pick the level of strategy and execution you need</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-6xl mx-auto">
        <div class="local-seo-pricing-card backdrop-blur-[12px] border border-slate-200 rounded-2xl p-6 md:p-8 overflow-hidden relative flex flex-col transition-all duration-300 ease-out" style="background: #ffffff;">
          <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 via-transparent to-transparent pointer-events-none"></div>
          <div class="relative flex flex-col flex-1">
            <div class="mb-6">
              <h3 class="text-xl font-bold text-slate-900 mb-2">The Foundation</h3>
              <div class="text-4xl font-bold text-slate-900 mb-1"><span class="text-lg align-top">$</span>500</div>
              <p class="text-slate-600 text-sm">per month</p>
              <p class="text-orange-400 text-xs font-medium mt-2">Technical health &amp; baseline monitoring</p>
              <p class="text-slate-600 text-sm mt-2">Keep rankings stable with ongoing technical SEO, citation upkeep, and Google Business Profile maintenance.</p>
            </div>
            <ul class="space-y-2 mb-6 flex-1">
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-slate-700">Technical health monitoring and link fixes</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-slate-700">Google Business Profile optimization</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-slate-700">Citation consistency and review monitoring</span>
              </li>
            </ul>
            <a href="/pricing" class="block w-full px-6 py-3 bg-slate-100 text-slate-900 font-semibold rounded-full text-center border border-slate-200 hover:bg-slate-100 transition-colors text-sm mt-auto">Get Started</a>
          </div>
        </div>

        <div class="local-seo-pricing-card backdrop-blur-[12px] border-2 border-orange-500/50 rounded-2xl p-6 md:p-8 overflow-hidden relative flex flex-col transition-all duration-300 ease-out" style="background: #ffffff;">
          <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 via-transparent to-transparent pointer-events-none"></div>
          <div class="absolute top-4 right-4">
            <span class="px-2 py-1 bg-orange-700 text-white text-xs font-semibold rounded-full">Recommended</span>
          </div>
          <div class="relative flex flex-col flex-1">
            <div class="mb-6">
              <h3 class="text-xl font-bold text-slate-900 mb-2">The Growth Engine</h3>
              <div class="text-4xl font-bold text-slate-900 mb-1"><span class="text-lg align-top">$</span>1,250</div>
              <p class="text-slate-600 text-sm">per month</p>
              <p class="text-orange-400 text-xs font-medium mt-2">Full SEO strategy + content execution</p>
              <p class="text-slate-600 text-sm mt-2">Keyword research, competitor gap analysis, strategic content, and live rank tracking.</p>
            </div>
            <ul class="space-y-2 mb-6 flex-1">
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-emerald-500/5 border border-emerald-500/20">
                <svg class="w-5 h-5 text-emerald-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm font-semibold text-emerald-400">Everything in Foundation, PLUS:</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-slate-700">2 strategic articles per month targeting gap keywords</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-slate-700">Competitor gap analysis and keyword fan-out research</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-slate-700">Local link building and live ranking dashboard</span>
              </li>
            </ul>
            <a href="/pricing" class="block w-full px-6 py-3 bg-orange-700 text-white font-semibold rounded-full text-center hover:bg-orange-600 transition-colors btn-glow text-sm mt-auto">Get Started</a>
          </div>
        </div>

        <div class="local-seo-pricing-card backdrop-blur-[12px] border border-slate-200 rounded-2xl p-6 md:p-8 overflow-hidden relative flex flex-col transition-all duration-300 ease-out" style="background: #ffffff;">
          <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 via-transparent to-transparent pointer-events-none"></div>
          <div class="relative flex flex-col flex-1">
            <div class="mb-6">
              <h3 class="text-xl font-bold text-slate-900 mb-2">Market Dominance</h3>
              <div class="text-4xl font-bold text-slate-900 mb-1"><span class="text-lg align-top">$</span>3,000</div>
              <p class="text-slate-600 text-sm">per month</p>
              <p class="text-orange-400 text-xs font-medium mt-2">Aggressive topical authority building</p>
              <p class="text-slate-600 text-sm mt-2">Double content velocity, CRO audits, and regional PR for brands ready to own their market.</p>
            </div>
            <ul class="space-y-2 mb-6 flex-1">
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-emerald-500/5 border border-emerald-500/20">
                <svg class="w-5 h-5 text-emerald-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm font-semibold text-emerald-400">Everything in Growth, PLUS:</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-slate-700">4 high-impact articles per month</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-slate-700">Conversion rate optimization and ongoing analysis</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-slate-50 border border-slate-100">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-slate-700">Quarterly local media outreach and PR campaigns</span>
              </li>
            </ul>
            <a href="/pricing" class="block w-full px-6 py-3 bg-slate-100 text-slate-900 font-semibold rounded-full text-center border border-slate-200 hover:bg-slate-100 transition-colors text-sm mt-auto">Get Started</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="max-w-7xl mx-auto py-16 md:py-24 px-4 sm:px-6 md:px-8 bg-slate-50 border-y border-slate-100">
      <h2 class="text-2xl md:text-3xl font-bold mb-12 text-center" data-aos="fade-up">Our Strategy Process</h2>
      <div class="hidden md:flex items-center justify-between relative">
        <div class="absolute top-6 left-0 right-0 h-0.5 bg-orange-500/30 -z-10"></div>
        <div class="flex flex-col items-center flex-1 relative group" data-aos="zoom-in" data-aos-delay="0">
          <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">1</div>
          <h3 class="font-bold text-slate-900 mb-2 text-center group-hover:text-orange-400 transition-colors">Research</h3>
          <p class="text-sm text-slate-600 text-center max-w-[180px]">Keyword discovery, competitor audit, and intent mapping.</p>
        </div>
        <div class="flex flex-col items-center flex-1 relative group" data-aos="zoom-in" data-aos-delay="150">
          <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">2</div>
          <h3 class="font-bold text-slate-900 mb-2 text-center group-hover:text-orange-400 transition-colors">Architecture</h3>
          <p class="text-sm text-slate-600 text-center max-w-[180px]">Topic clusters, sitemap strategy, and internal linking plan.</p>
        </div>
        <div class="flex flex-col items-center flex-1 relative group" data-aos="zoom-in" data-aos-delay="300">
          <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">3</div>
          <h3 class="font-bold text-slate-900 mb-2 text-center group-hover:text-orange-400 transition-colors">Execute</h3>
          <p class="text-sm text-slate-600 text-center max-w-[180px]">Content creation, on-page optimization, and link building.</p>
        </div>
        <div class="flex flex-col items-center flex-1 relative group" data-aos="zoom-in" data-aos-delay="450">
          <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">4</div>
          <h3 class="font-bold text-slate-900 mb-2 text-center group-hover:text-orange-400 transition-colors">Measure</h3>
          <p class="text-sm text-slate-600 text-center max-w-[180px]">Rank tracking, traffic analysis, and strategy refinement.</p>
        </div>
      </div>
      <div class="md:hidden space-y-8">
        <div class="flex gap-4 relative">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg">1</div>
            <div class="w-0.5 h-full bg-orange-500/30 mt-2 absolute top-12 left-6"></div>
          </div>
          <div class="flex-1 pt-2">
            <h3 class="font-bold text-slate-900 mb-2">Research</h3>
            <p class="text-sm text-slate-600">Keyword discovery, competitor audit, and intent mapping.</p>
          </div>
        </div>
        <div class="flex gap-4 relative">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg">2</div>
            <div class="w-0.5 h-full bg-orange-500/30 mt-2 absolute top-12 left-6"></div>
