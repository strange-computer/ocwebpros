    </section>

    <!-- CTA -->
    <div class="text-center py-12 sm:py-16 md:py-24 px-4 sm:px-6 md:px-8" data-aos="fade-up">
      <h2 class="text-2xl md:text-3xl font-bold mb-4 text-white">Ready to get cited by AI search?</h2>
      <p class="text-zinc-400 mb-8 max-w-xl mx-auto">Book a free AI readiness audit and we&apos;ll show you where your brand stands in AI-driven search today.</p>
      <div class="inline-flex flex-col sm:flex-row gap-4">
        <a href="/contact" class="px-10 py-5 bg-orange-700 text-white font-bold rounded-full hover:bg-orange-600 transition-colors text-lg btn-glow">
          Get a free AI audit
