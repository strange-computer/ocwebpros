---
import MainLayout from '../../layouts/MainLayout.astro';
import SpotlightImage from '../../components/SpotlightImage.astro';
import WebDesignFeatureGrid from '../../components/WebDesignFeatureGrid.astro';
import { primaryCities, cityRegistry } from '../../data/cityRegistry';

const webDesignProof = [
  { label: 'Custom sites from', value: '$3,500' },
  { label: 'Based in', value: 'Lake Forest, CA' },
  { label: 'Built for', value: '24 OC cities' },
  { label: 'SEO foundations', value: 'Included' },
] as const;

const ocFaqs = [
  {
    question: 'How much does web design cost in Orange County?',
    answer:
      'OCWebPros custom websites typically start at $3,500 for a focused authority site. Scope depends on page count, integrations, and content — we quote after a free consult so Orange County businesses know exactly what they are buying.',
  },
  {
    question: 'Who is the best web design company in Orange County?',
    answer:
      'Choose a Lake Forest–based team that builds custom, mobile-first sites with local SEO foundations — not a template reseller. OCWebPros designs for OC hire intent and pairs every build with optional ongoing local SEO.',
  },
  {
    question: 'Do you build websites for businesses outside South OC?',
    answer:
      'Yes. We serve all of Orange County — Irvine, Newport Beach, Anaheim, Santa Ana, Huntington Beach, and every city on our service-areas list — from our Lake Forest office.',
  },
  {
    question: 'How is this different from your city web design pages?',
    answer:
      'This page is the Orange County–wide commercial home for web design. City pages target searches like “web design Irvine.” Hire here for county-wide positioning; use city pages when the query names a specific city.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: ocFaqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---
<MainLayout 
  title="Web Design Orange County CA | Custom Websites | OCWebPros" 
  description="Looking for web design in Orange County? Custom, mobile-first sites from Lake Forest–based OCWebPros — Core Web Vitals, local schema, conversion-focused. From $3,500. Free consult."
  bodyClass="page-services page-web-design"
  pageCSS="/css/pages/services.css">

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />

  <header class="relative pt-32 sm:pt-32 md:pt-40 pb-12 sm:pb-16 px-4 sm:px-6 text-center overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90vw] max-w-[800px] h-[400px] sm:h-[500px] md:h-[600px] glow-bg pointer-events-none opacity-40"></div>
    <div class="max-w-5xl mx-auto relative">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 border border-slate-200 text-xs font-medium text-orange-400 mb-6">
        <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
        Orange County Web Design
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4">
        Custom Web Design in <span class="text-gradient-orange">Orange County</span>
      </h1>
      <p class="text-slate-600 text-lg leading-relaxed max-w-3xl mx-auto">
        Hire a Lake Forest–based studio for fast, mobile-first websites built for Orange County businesses — designed to convert, rank locally, and stay easy to manage.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a href="/contact/" class="px-8 py-3.5 bg-orange-700 text-white font-semibold rounded-full hover:bg-orange-600 transition-colors btn-glow text-sm md:text-base">
          Request a Free OC Consult
        </a>
        <a href="/portfolio/" class="px-8 py-3.5 bg-slate-100 text-slate-900 font-semibold rounded-full border border-slate-200 hover:bg-slate-100 transition-colors text-sm md:text-base">
          View Our Work
        </a>
      </div>
      <dl class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-3 max-w-3xl mx-auto text-left">
        {webDesignProof.map((item) => (
          <div class="rounded-xl border border-slate-200 bg-white/80 px-4 py-3">
            <dt class="text-[11px] uppercase tracking-wide text-slate-500 font-medium">{item.label}</dt>
            <dd class="text-sm font-semibold text-slate-900 mt-0.5">{item.value}</dd>
          </div>
        ))}
      </dl>
    </div>
  </header>

  <main class="pb-16 sm:pb-24 px-4 sm:px-6 md:px-8">
    <section class="max-w-4xl mx-auto pt-8 pb-12">
      <p class="text-slate-700 text-lg leading-relaxed mb-6">
        If you searched for web design Orange County, web design company OC, or Orange County website design, this is the commercial home to hire from. We build custom sites for businesses across South OC, coastal cities, central OC, and North OC — with local SEO foundations included so the site is ready to rank.
      </p>
      <p class="text-slate-600 text-base leading-relaxed border-l-2 border-orange-500/50 pl-6">
        OC customers judge you on mobile first. Affluent coastal markets and competitive Irvine categories punish slow templates. We ship purpose-built sites that load fast, speak your city, and convert inquiries — not bloated page builders.
      </p>
    </section>

    <!-- Spotlight -->
    <section class="max-w-7xl mx-auto pt-4 md:pt-8 pb-16 md:pb-24 px-4 sm:px-6">
      <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
        <div class="w-full md:w-1/2 backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6 sm:p-8 md:p-10" data-aos="fade-right">
          <div class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          </div>
          <h2 class="text-3xl md:text-4xl font-bold mb-4 text-slate-900">Built for Orange County Businesses</h2>
          <p class="text-slate-600 mb-6 text-lg leading-relaxed">Your website should represent your brand and drive measurable leads in competitive OC markets. We focus on conversion, local SEO structure, and technical performance — not bloated templates.</p>
          <ul class="space-y-3 text-slate-700">
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Custom, component-based UI without template bloat</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Mobile-first layouts tuned for OC “near me” traffic</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>City and service page structure ready for local SEO</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Core Web Vitals, schema, and semantic HTML from day one</span></li>
          </ul>
        </div>
        <SpotlightImage
          src="/images/unsplash/services-web-design.jpg"
          alt="Custom web design for Orange County businesses"
        />
      </div>
    </section>

    <!-- Pricing -->
    <section class="max-w-7xl mx-auto pt-4 md:pt-8 pb-12 md:pb-16 px-4 sm:px-6">
      <div class="max-w-5xl mx-auto relative">
        <div class="absolute -top-12 -left-12 w-64 h-64 md:w-80 md:h-80 bg-gradient-to-tr from-orange-500/20 to-sky-500/20 blur-3xl rounded-full pointer-events-none" aria-hidden="true"></div>
        <div class="web-design-pricing-card relative backdrop-blur-[12px] border border-slate-200 rounded-2xl p-8 md:p-10 overflow-hidden transition-all duration-300 ease-out shadow-[0_10px_40px_-10px_rgba(15,23,42,0.12)]" style="background: #ffffff;">
          <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 via-transparent to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 bg-gradient-to-tl from-orange-500/5 via-transparent to-transparent pointer-events-none"></div>
          
          <div class="relative">
            <div class="text-center mb-4 md:hidden">
              <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 border border-slate-200 text-xs font-medium text-orange-400 mb-4">
                <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
                WEB ARCHITECTURE
              </div>
              <h2 class="text-2xl md:text-4xl font-bold mb-2 text-slate-900 tracking-tight">The &quot;Authority&quot; Website</h2>
              <p class="text-slate-600 text-sm leading-relaxed max-w-xl mx-auto">High-performance websites built to meet Core Web Vitals standards and capture local market share.</p>
            </div>

            <div class="flex flex-col md:grid gap-6 md:grid-cols-[1.15fr_auto] md:items-stretch">
              <div class="order-2 md:order-1 md:col-start-1 md:row-start-1 md:pr-8 min-w-0">
                <div class="hidden md:block text-center mb-4">
                  <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 border border-slate-200 text-xs font-medium text-orange-400 mb-4">
                    <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
                    WEB ARCHITECTURE
                  </div>
                  <h2 class="text-2xl md:text-4xl font-bold mb-2 text-slate-900 tracking-tight">The &quot;Authority&quot; Website</h2>
                  <p class="text-slate-600 text-sm leading-relaxed max-w-xl mx-auto">High-performance websites built to meet Core Web Vitals standards and capture local market share.</p>
                </div>
                <WebDesignFeatureGrid />
              </div>

              <div class="contents md:flex md:flex-col md:gap-4 md:pl-8 md:border-l md:border-slate-200 md:col-start-2 md:row-start-1 md:justify-center">
                <div class="order-1 md:order-none text-center flex flex-col items-center">
                  <div class="text-4xl md:text-5xl font-bold text-slate-900 mb-1">
                    <span class="text-xl md:text-2xl align-top">$</span>3,500
                  </div>
                  <p class="text-slate-600 text-sm">One-Time Investment</p>
                </div>
                <div class="order-3 md:order-none text-center flex flex-col items-center">
                  <a href="/pricing/" class="inline-block px-8 py-3.5 bg-orange-700 text-white font-semibold rounded-full hover:bg-orange-600 transition-colors btn-glow text-sm md:text-base">
                    Secure Your Build Slot
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Grid -->
    <section class="max-w-7xl mx-auto pt-2 md:pt-4 pb-16 md:pb-24 px-4 sm:px-6 md:px-8">
      <div class="text-center mb-12" data-aos="fade-up">
        <h2 class="text-2xl md:text-3xl font-bold mb-2 text-slate-900">What&apos;s Included</h2>
        <p class="text-slate-600 text-sm md:text-base">Every build is tailored to your business - here&apos;s what you can expect.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        <div data-aos="fade-up" data-aos-delay="0">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Custom Design</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Purpose-built layouts that reflect your brand and guide visitors toward action - no generic themes.</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="100">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Core Web Vitals</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Responsive image delivery, WebP conversion, and performance tuning so your site passes Google&apos;s speed benchmarks.</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="200">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Mobile-First UX</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Thumb-friendly navigation, tap targets, and layouts designed for the way people actually browse on phones.</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="300">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">AI-Ready Structure</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Semantic HTML, structured data, and clean site architecture that supports AI-generated content and search visibility.</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="400">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Performance &amp; Security</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Best practices for speed, SSL, and security baked in from day one - not bolted on after launch.</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="500">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Easy to Manage</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Need a text or image change? Send it our way. We handle updates for you - no CMS to learn, no code to touch.</p>
        </div>
      </div>
    </section>

    <!-- Process Timeline -->
    <section class="max-w-7xl mx-auto py-16 md:py-24 px-4 sm:px-6 md:px-8 bg-slate-50 border-y border-slate-100">
      <h2 class="text-2xl md:text-3xl font-bold mb-12 text-center" data-aos="fade-up">Our Design Process</h2>
      <div class="hidden md:flex items-center justify-between relative">
        <div class="absolute top-6 left-0 right-0 h-0.5 bg-orange-500/30 -z-10"></div>
        <div class="flex flex-col items-center flex-1 relative group" data-aos="zoom-in" data-aos-delay="0">
          <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">1</div>
          <h3 class="font-bold text-slate-900 mb-2 text-center group-hover:text-orange-400 transition-colors">Discovery</h3>
          <p class="text-sm text-slate-600 text-center max-w-[180px]">Goals, audience, and success criteria.</p>
        </div>
        <div class="flex flex-col items-center flex-1 relative group" data-aos="zoom-in" data-aos-delay="150">
          <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">2</div>
          <h3 class="font-bold text-slate-900 mb-2 text-center group-hover:text-orange-400 transition-colors">Design</h3>
          <p class="text-sm text-slate-600 text-center max-w-[180px]">Concepts reviewed together before build.</p>
        </div>
        <div class="flex flex-col items-center flex-1 relative group" data-aos="zoom-in" data-aos-delay="300">
          <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">3</div>
          <h3 class="font-bold text-slate-900 mb-2 text-center group-hover:text-orange-400 transition-colors">Build</h3>
          <p class="text-sm text-slate-600 text-center max-w-[180px]">Clean implementation, content, and QA.</p>
        </div>
        <div class="flex flex-col items-center flex-1 relative group" data-aos="zoom-in" data-aos-delay="450">
          <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">4</div>
          <h3 class="font-bold text-slate-900 mb-2 text-center group-hover:text-orange-400 transition-colors">Launch &amp; Support</h3>
          <p class="text-sm text-slate-600 text-center max-w-[180px]">Testing, launch, and ongoing improvements.</p>
        </div>
      </div>
      <div class="md:hidden space-y-8">
        <div class="flex gap-4 relative">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg">1</div>
            <div class="w-0.5 h-full bg-orange-500/30 mt-2 absolute top-12 left-6"></div>
          </div>
          <div class="flex-1 pt-2">
            <h3 class="font-bold text-slate-900 mb-2">Discovery</h3>
            <p class="text-sm text-slate-600">Goals, audience, and success criteria.</p>
          </div>
        </div>
        <div class="flex gap-4 relative">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg">2</div>
            <div class="w-0.5 h-full bg-orange-500/30 mt-2 absolute top-12 left-6"></div>
          </div>
          <div class="flex-1 pt-2">
            <h3 class="font-bold text-slate-900 mb-2">Design</h3>
            <p class="text-sm text-slate-600">Concepts reviewed together before build.</p>
          </div>
        </div>
        <div class="flex gap-4 relative">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg">3</div>
            <div class="w-0.5 h-full bg-orange-500/30 mt-2 absolute top-12 left-6"></div>
          </div>
          <div class="flex-1 pt-2">
            <h3 class="font-bold text-slate-900 mb-2">Build</h3>
            <p class="text-sm text-slate-600">Clean implementation, content, and QA.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg">4</div>
          </div>
          <div class="flex-1 pt-2">
            <h3 class="font-bold text-slate-900 mb-2">Launch &amp; Support</h3>
            <p class="text-sm text-slate-600">Testing, launch, and ongoing improvements.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- OC cities we serve -->
    <section class="max-w-7xl mx-auto py-16 md:py-20 px-4 sm:px-6 md:px-8 bg-slate-50 border-y border-slate-100">
      <div class="text-center mb-10" data-aos="fade-up">
        <h2 class="text-2xl md:text-3xl font-bold mb-2 text-slate-900">Orange County cities we design for</h2>
        <p class="text-slate-600 text-sm md:text-base max-w-2xl mx-auto">
          This hub covers county-wide web design. City pages win searches like “web design Irvine” — {cityRegistry.length} dedicated OC destinations.
        </p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 max-w-4xl mx-auto">
        {primaryCities.map((city) => (
          <a href={`/web-design/${city.slug}/`} class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-center text-sm font-medium text-slate-800 hover:border-orange-300 hover:text-orange-600 transition-colors">
            Web Design {city.name}
          </a>
        ))}
      </div>
      <p class="text-center mt-8 text-sm text-slate-500">
        <a href="/service-areas/" class="text-orange-400 hover:text-orange-300 font-medium transition-colors">View all {cityRegistry.length} Orange County service areas →</a>
      </p>
    </section>

    <!-- OC FAQs -->
    <section class="max-w-3xl mx-auto py-16 px-4 sm:px-6">
      <h2 class="text-2xl md:text-3xl font-bold mb-8 text-slate-900 text-center">Orange County web design — FAQ</h2>
      <div class="space-y-6">
        {ocFaqs.map((faq) => (
          <div class="border-b border-slate-200 pb-6">
            <h3 class="text-lg font-bold text-slate-900 mb-2">{faq.question}</h3>
            <p class="text-slate-600 leading-relaxed">{faq.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Related -->
    <section class="max-w-7xl mx-auto py-16 md:py-24 px-4 sm:px-6 md:px-8">
      <div class="grid md:grid-cols-3 gap-6">
        <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6 sm:p-8" data-aos="fade-up">
          <h3 class="text-xl font-bold text-slate-900 mb-3">Pair with Local SEO</h3>
          <p class="text-sm text-slate-600 leading-relaxed mb-4">A great website needs visibility. Our Orange County local SEO packages help you rank in Google Maps and organic search.</p>
          <a href="/services/local-seo/" class="text-sm text-orange-400 font-medium hover:text-orange-300 transition-colors inline-flex items-center gap-1">
            Explore OC local SEO
