---
import MainLayout from '../../layouts/MainLayout.astro';
---
<MainLayout 
  title="Web Design Services Orange County CA | OCWebPros" 
  description="Custom web design for Orange County businesses. Fast, mobile-first, AI-ready websites with Core Web Vitals optimization, local schema, and conversion-focused UI. From $4,995."
  bodyClass="page-services page-web-design"
  pageCSS="/css/pages/services.css">

  <header class="relative pt-32 sm:pt-32 md:pt-40 pb-12 sm:pb-16 px-4 sm:px-6 text-center overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90vw] max-w-[800px] h-[400px] sm:h-[500px] md:h-[600px] glow-bg pointer-events-none opacity-40"></div>
    <div class="max-w-5xl mx-auto relative">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-orange-400 mb-6">
        <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
        Web Design
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4">
        Custom Web Design in <span class="text-gradient-orange">Orange County</span>
      </h1>
      <p class="text-zinc-400 text-lg leading-relaxed max-w-3xl mx-auto">
        Fast-loading, mobile-first websites built around your business goals - designed to convert visitors, rank in search, and stay easy to manage.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a href="/contact" class="px-8 py-3.5 bg-orange-700 text-white font-semibold rounded-full hover:bg-orange-600 transition-colors btn-glow text-sm md:text-base">
          Request a Free Consult
        </a>
        <a href="/portfolio" class="px-8 py-3.5 bg-white/5 text-white font-semibold rounded-full border border-white/10 hover:bg-white/10 transition-colors text-sm md:text-base">
          View Our Work
        </a>
      </div>
    </div>
  </header>

  <main class="pb-16 sm:pb-24 px-4 sm:px-6 md:px-8">
    <!-- Spotlight -->
    <section class="max-w-7xl mx-auto pt-8 md:pt-12 pb-16 md:pb-24 px-4 sm:px-6">
      <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
        <div class="w-full md:w-1/2 backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-2xl p-6 sm:p-8 md:p-10" data-aos="fade-right">
          <div class="w-12 h-12 bg-white/5 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7h18M3 12h18M3 17h18"/></svg>
          </div>
          <h2 class="text-3xl md:text-4xl font-bold mb-4 text-white">Built for Real Businesses</h2>
          <p class="text-zinc-400 mb-6 text-lg leading-relaxed">Your website should authentically represent your brand and drive measurable results. We focus on content strategy, conversion optimization, and technical performance - not bloated templates.</p>
          <ul class="space-y-3 text-zinc-300">
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Custom, component-based UI without template bloat</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Responsive layouts optimized for phones, tablets, and desktops</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Clean code that loads fast and works for every visitor</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>AI-ready structure with schema markup and semantic HTML</span></li>
          </ul>
        </div>
        <div class="w-full md:w-1/2 h-64 sm:h-80 md:h-[500px] border border-white/10 rounded-xl overflow-hidden" data-aos="fade-left">
          <img src="/images/web-design-mockup.png" alt="Custom web design portfolio mockup for Orange County business" class="w-full h-full object-cover" />
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="max-w-7xl mx-auto pt-4 md:pt-8 pb-12 md:pb-16 px-4 sm:px-6">
      <div class="max-w-5xl mx-auto relative">
        <div class="absolute -top-12 -left-12 w-64 h-64 md:w-80 md:h-80 bg-gradient-to-tr from-orange-500/20 to-purple-500/20 blur-3xl rounded-full pointer-events-none" aria-hidden="true"></div>
        <div class="web-design-pricing-card relative backdrop-blur-[12px] border border-white/10 rounded-2xl p-8 md:p-10 overflow-hidden transition-all duration-300 ease-out shadow-[0_10px_40px_-10px_rgba(0,0,0,0.5)]" style="background: rgba(24, 24, 27, 0.6);">
          <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 via-transparent to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 bg-gradient-to-tl from-purple-500/5 via-transparent to-transparent pointer-events-none"></div>
          
          <div class="relative">
            <div class="text-center mb-4 md:hidden">
              <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-orange-400 mb-4">
                <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
                WEB ARCHITECTURE
              </div>
              <h2 class="text-2xl md:text-4xl font-bold mb-2 text-white tracking-tight">The &quot;Authority&quot; Website</h2>
              <p class="text-zinc-400 text-sm leading-relaxed max-w-xl mx-auto">High-performance websites built to meet Core Web Vitals standards and capture local market share.</p>
            </div>

            <div class="flex flex-col md:grid gap-6 md:grid-cols-[1fr_auto] md:items-stretch">
              <div class="order-2 md:order-1 md:col-start-1 md:row-start-1 md:pr-8 min-w-0">
                <div class="hidden md:block text-center mb-4">
                  <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-orange-400 mb-4">
                    <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
                    WEB ARCHITECTURE
                  </div>
                  <h2 class="text-2xl md:text-4xl font-bold mb-2 text-white tracking-tight">The &quot;Authority&quot; Website</h2>
                  <p class="text-zinc-400 text-sm leading-relaxed max-w-xl mx-auto">High-performance websites built to meet Core Web Vitals standards and capture local market share.</p>
                </div>
                <ul class="grid grid-cols-2 md:grid-cols-3 gap-2 md:gap-2">
                  <li class="flex items-center gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                    <svg class="w-5 h-5 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    <span class="text-sm text-zinc-300">Strategy-First Sitemap</span>
                  </li>
                  <li class="flex items-center gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                    <svg class="w-5 h-5 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    <span class="text-sm text-zinc-300">Conversion-Engineered UI</span>
                  </li>
                  <li class="flex items-center gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                    <svg class="w-5 h-5 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    <span class="text-sm text-zinc-300">90+ Google Speed Score</span>
                  </li>
                  <li class="flex items-center gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                    <svg class="w-5 h-5 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    <span class="text-sm text-zinc-300">Local Schema Injection</span>
                  </li>
                  <li class="flex items-center gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                    <svg class="w-5 h-5 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    <span class="text-sm text-zinc-300">Mobile-First &quot;Thumb&quot; UX</span>
                  </li>
                  <li class="flex items-center gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                    <svg class="w-5 h-5 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    <span class="text-sm text-zinc-300">Analytics Setup &amp; Dashboard</span>
                  </li>
                </ul>
              </div>

              <div class="contents md:flex md:flex-col md:gap-4 md:pl-8 md:border-l md:border-white/10 md:col-start-2 md:row-start-1 md:justify-center">
                <div class="order-1 md:order-none text-center flex flex-col items-center">
                  <div class="text-4xl md:text-5xl font-bold text-white mb-1">
                    <span class="text-xl md:text-2xl align-top">$</span>4,995
                  </div>
                  <p class="text-zinc-400 text-sm">One-Time Investment</p>
                </div>
                <div class="order-3 md:order-none text-center flex flex-col items-center">
                  <a href="/pricing" class="inline-block px-8 py-3.5 bg-orange-700 text-white font-semibold rounded-full hover:bg-orange-600 transition-colors btn-glow text-sm md:text-base">
                    Secure Your Build Slot
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Grid -->
    <section class="max-w-7xl mx-auto pt-2 md:pt-4 pb-16 md:pb-24 px-4 sm:px-6 md:px-8">
      <div class="text-center mb-12" data-aos="fade-up">
        <h2 class="text-2xl md:text-3xl font-bold mb-2 text-white">What&apos;s Included</h2>
        <p class="text-zinc-400 text-sm md:text-base">Every build is tailored to your business - here&apos;s what you can expect.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        <div data-aos="fade-up" data-aos-delay="0">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Custom Design</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Purpose-built layouts that reflect your brand and guide visitors toward action - no generic themes.</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="100">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Core Web Vitals</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Responsive image delivery, WebP conversion, and performance tuning so your site passes Google&apos;s speed benchmarks.</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="200">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Mobile-First UX</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Thumb-friendly navigation, tap targets, and layouts designed for the way people actually browse on phones.</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="300">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">AI-Ready Structure</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Semantic HTML, structured data, and clean site architecture that supports AI-generated content and search visibility.</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="400">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c1.657 0 3-1.567 3-3.5S13.657 4 12 4 9 5.567 9 7.5 10.343 11 12 11zm0 0v9m-7-5h14"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Performance &amp; Security</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Best practices for speed, SSL, and security baked in from day one - not bolted on after launch.</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="500">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Easy to Manage</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Update copy and images yourself, or lean on us - we keep things simple either way.</p>
        </div>
      </div>
    </section>

    <!-- Process Timeline -->
    <section class="max-w-7xl mx-auto py-16 md:py-24 px-4 sm:px-6 md:px-8 bg-zinc-900/30 border-y border-white/5">
      <h2 class="text-2xl md:text-3xl font-bold mb-12 text-center" data-aos="fade-up">Our Design Process</h2>
      <div class="hidden md:flex items-center justify-between relative">
        <div class="absolute top-6 left-0 right-0 h-0.5 bg-orange-500/30 -z-10"></div>
        <div class="flex flex-col items-center flex-1 relative group" data-aos="zoom-in" data-aos-delay="0">
          <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">1</div>
          <h3 class="font-bold text-white mb-2 text-center group-hover:text-orange-400 transition-colors">Discovery</h3>
          <p class="text-sm text-zinc-400 text-center max-w-[180px]">Goals, audience, and success criteria.</p>
        </div>
        <div class="flex flex-col items-center flex-1 relative group" data-aos="zoom-in" data-aos-delay="150">
          <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">2</div>
          <h3 class="font-bold text-white mb-2 text-center group-hover:text-orange-400 transition-colors">Design</h3>
          <p class="text-sm text-zinc-400 text-center max-w-[180px]">Concepts reviewed together before build.</p>
        </div>
        <div class="flex flex-col items-center flex-1 relative group" data-aos="zoom-in" data-aos-delay="300">
          <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">3</div>
          <h3 class="font-bold text-white mb-2 text-center group-hover:text-orange-400 transition-colors">Build</h3>
          <p class="text-sm text-zinc-400 text-center max-w-[180px]">Clean implementation, content, and QA.</p>
        </div>
        <div class="flex flex-col items-center flex-1 relative group" data-aos="zoom-in" data-aos-delay="450">
          <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">4</div>
          <h3 class="font-bold text-white mb-2 text-center group-hover:text-orange-400 transition-colors">Launch &amp; Support</h3>
          <p class="text-sm text-zinc-400 text-center max-w-[180px]">Testing, launch, and ongoing improvements.</p>
        </div>
      </div>
      <div class="md:hidden space-y-8">
        <div class="flex gap-4 relative">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg">1</div>
            <div class="w-0.5 h-full bg-orange-500/30 mt-2 absolute top-12 left-6"></div>
          </div>
          <div class="flex-1 pt-2">
            <h3 class="font-bold text-white mb-2">Discovery</h3>
            <p class="text-sm text-zinc-400">Goals, audience, and success criteria.</p>
          </div>
        </div>
        <div class="flex gap-4 relative">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg">2</div>
            <div class="w-0.5 h-full bg-orange-500/30 mt-2 absolute top-12 left-6"></div>
          </div>
          <div class="flex-1 pt-2">
            <h3 class="font-bold text-white mb-2">Design</h3>
            <p class="text-sm text-zinc-400">Concepts reviewed together before build.</p>
          </div>
        </div>
        <div class="flex gap-4 relative">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg">3</div>
            <div class="w-0.5 h-full bg-orange-500/30 mt-2 absolute top-12 left-6"></div>
          </div>
          <div class="flex-1 pt-2">
            <h3 class="font-bold text-white mb-2">Build</h3>
            <p class="text-sm text-zinc-400">Clean implementation, content, and QA.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg">4</div>
          </div>
          <div class="flex-1 pt-2">
            <h3 class="font-bold text-white mb-2">Launch &amp; Support</h3>
            <p class="text-sm text-zinc-400">Testing, launch, and ongoing improvements.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Related -->
    <section class="max-w-7xl mx-auto py-16 md:py-24 px-4 sm:px-6 md:px-8">
      <div class="grid md:grid-cols-2 gap-6">
        <div class="backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-2xl p-6 sm:p-8" data-aos="fade-up">
          <h3 class="text-xl font-bold text-white mb-3">Pair with Local SEO</h3>
          <p class="text-sm text-zinc-400 leading-relaxed mb-4">A great website needs visibility. Our local SEO packages help Orange County businesses rank in Google Maps and organic search.</p>
          <a href="/services/local-seo" class="text-sm text-orange-400 font-medium hover:text-orange-300 transition-colors inline-flex items-center gap-1">
            Explore local SEO packages
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          </a>
        </div>
        <div class="backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-2xl p-6 sm:p-8" data-aos="fade-up" data-aos-delay="100">
          <h3 class="text-xl font-bold text-white mb-3">Serving All of Orange County</h3>
          <p class="text-sm text-zinc-400 leading-relaxed mb-4">Based in Lake Forest, we work with businesses across Irvine, Mission Viejo, Newport Beach, and the entire OC region.</p>
          <a href="/service-areas" class="text-sm text-orange-400 font-medium hover:text-orange-300 transition-colors inline-flex items-center gap-1">
            View service areas
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class="text-center py-12 sm:py-16 md:py-24 px-4 sm:px-6 md:px-8" data-aos="fade-up">
      <h2 class="text-2xl md:text-3xl font-bold mb-4 text-white">Ready to build your authority website?</h2>
      <p class="text-zinc-400 mb-8 max-w-xl mx-auto">Tell us about your business and we&apos;ll outline a clear plan - no pressure, no jargon.</p>
      <div class="inline-flex flex-col sm:flex-row gap-4">
        <a href="/contact" class="px-10 py-5 bg-orange-700 text-white font-bold rounded-full hover:bg-orange-600 transition-colors text-lg btn-glow">
          Request a free consult
        </a>
        <a href="/portfolio" class="px-10 py-5 bg-white/5 text-white font-bold rounded-full border border-white/10 hover:bg-white/10 transition-colors text-lg">
          See examples
        </a>
      </div>
      <p class="text-zinc-400 text-sm mt-3">Prefer a call? Add your number in the email.</p>
    </div>
  </main>
</MainLayout>
