---
import MainLayout from '../layouts/MainLayout.astro';

const projects = [
  {
    title: 'Woodhaven Flooring',
    image: '/images/woodhavenflooring.com_.png',
    alt: 'Woodhaven Flooring site preview',
    url: 'https://woodhavenflooring.com',
    description: 'Hardwood installation, refinishing, and restoration site for a Southern California flooring company trusted since 1984.',
    tags: ['Local Business', 'Service Areas', 'Lead Generation'],
    highlights: [
      'Service showcase for installation, refinishing, and restoration',
      'Coverage across LA, Long Beach, and 34 Orange County cities',
      'Review-driven trust sections with free estimate lead capture',
    ],
  },
  {
    title: 'Atelier',
    image: '/images/atelierlist.com_.png',
    alt: 'Atelier editorial network site preview',
    url: 'https://atelierlist.com',
    description: 'Editorial blog network for independent voices in design, travel, art, and long-form journalism.',
    tags: ['Editorial', 'Publishing', 'Content Network'],
    highlights: [
      'Five publications united under one editorial hub',
      'Luxury dark-theme design built for long-form reading',
      'Network, journal, and publication pages for discovery',
    ],
  },
  {
    title: 'Honkpill',
    image: '/images/honkpill.com_.png',
    alt: 'Honkpill product site preview',
    url: 'https://honkpill.com',
    description: 'E-commerce site for collectible merchandise with a bold, personality-driven brand.',
    tags: ['E-commerce', 'Product Pages', 'Brand'],
    highlights: [
      'Shop layout built around a hero product',
      'Cart and checkout tuned for mobile',
      'Playful copy without sacrificing clarity',
    ],
  },
  {
    title: 'Tempting Design',
    image: '/images/temptingdesign.com_.png',
    alt: 'Tempting Design site preview',
    url: 'https://temptingdesign.com',
    description: 'Subscription design service with tiered plans, FAQs, and a clear signup path.',
    tags: ['SaaS', 'Landing Page', 'Subscriptions'],
    highlights: [
      'Plan comparison and pricing front and center',
      'Long-form service page that answers objections',
      'Login and subscribe flows for returning clients',
    ],
  },
  {
    title: 'Gondola Adventure Club',
    image: '/images/mint.gondolaadventureclub.com_.png',
    alt: 'Gondola Adventure Club Mint preview',
    url: 'https://gondolaadventureclub.com',
    description: 'Web3 collectibles project with a mint experience and collection showcase.',
    tags: ['Web3', 'Mint Page', 'Interactive'],
    highlights: [
      'Mint details and supply info at a glance',
      'Wallet connect and collection presentation',
      'Character traits and team sections for the drop',
    ],
  },
];

const caseStudies = [
  {
    title: 'Irvine Dental Practice',
    location: 'Irvine, CA',
    result: '347% organic traffic growth in 90 days',
    description: 'Local SEO, content strategy, and technical fixes transformed an Irvine dental practice from page 3 to top 3 for 12 key local terms.',
    tags: ['Local SEO', 'Irvine', 'Healthcare'],
    link: '/blog/2026-05-18-orange-county-web-traffic-case-study',
    serviceLink: '/local-seo/irvine',
  },
  {
    title: 'Mission Viejo Professional Services',
    location: 'Mission Viejo, CA',
    result: 'Master-planned community SEO strategy',
    description: 'Professional services SEO tailored to Mission Viejo\'s affluent, family-oriented market — GBP optimization, city pages, and review velocity.',
    tags: ['Local SEO', 'Mission Viejo', 'Professional Services'],
    link: '/blog/2026-05-15-mission-viejo-professional-services-seo',
    serviceLink: '/local-seo/mission-viejo',
  },
  {
    title: 'Rancho Santa Margarita Local Market',
    location: 'Rancho Santa Margarita, CA',
    result: 'First-mover local SEO advantage',
    description: 'Dedicated RSM landing pages, GBP strategy, and citation building for South OC businesses in a tight-knit community market.',
    tags: ['Local SEO', 'RSM', 'Small Business'],
    link: '/blog/2026-07-06-rancho-santa-margarita-local-seo-guide',
    serviceLink: '/local-seo/rancho-santa-margarita',
  },
];
---
<MainLayout 
  title="Portfolio | OCWebPros" 
  description="View our web design portfolio. Custom websites for local businesses, service providers, and professionals across Orange County. Fast, mobile-first, conversion-focused."
  bodyClass="page-portfolio"
  pageCSS="/css/pages/portfolio.css">

  <!-- Hero -->
  <header class="relative pt-32 sm:pt-32 md:pt-40 pb-12 sm:pb-16 px-4 sm:px-6 text-center overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90vw] max-w-[800px] h-[400px] sm:h-[500px] md:h-[600px] glow-bg pointer-events-none opacity-40"></div>
    <div class="max-w-5xl mx-auto relative">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 border border-slate-200 text-xs font-medium text-orange-400 mb-6">
        <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
        Portfolio
      </div>
      <h1 class="text-3xl sm:text-4xl md:text-6xl font-bold tracking-tight mb-4">
        Selected <span class="text-gradient-orange">Work</span>
      </h1>
      <p class="text-slate-600 text-base sm:text-lg leading-relaxed px-4">
        A handful of recent builds. Each site is tailored to goals, content, and audience - no templates.
      </p>
    </div>
  </header>

  <main class="pb-16 sm:pb-24 px-4 sm:px-6">
    <!-- Featured projects -->
    <section class="max-w-7xl mx-auto">
      <div class="grid md:grid-cols-3 gap-6">
        {projects.map((project, i) => (
          <div class="framer-card p-4 rounded-2xl group overflow-hidden" data-aos="fade-up" data-aos-delay={i * 100}>
            <div class="relative h-52 rounded-xl border border-slate-200 mb-4 overflow-hidden">
              <img src={project.image} alt={project.alt} class="w-full h-full object-cover object-top" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-br from-slate-100/40 to-zinc-900/10 opacity-80 group-hover:opacity-40 transition-opacity"></div>
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(251,146,60,0.12),transparent_40%)] opacity-80 group-hover:opacity-40 transition-opacity"></div>
            </div>
            <div class="px-2 pb-2">
              <h3 class="text-lg font-semibold mb-1 text-slate-900">{project.title}</h3>
              <p class="text-sm text-slate-600 mb-3">{project.description}</p>
              <div class="flex flex-wrap gap-2 mb-3">
                {project.tags.map((tag) => (
                  <span class="px-2 py-1 text-[11px] rounded bg-slate-100 border border-slate-200 text-slate-700">{tag}</span>
                ))}
              </div>
              <ul class="text-[12px] text-slate-600 space-y-1 mb-4">
                {project.highlights.map((item) => (
                  <li class="flex gap-2"><span class="text-orange-400">•</span> {item}</li>
                ))}
              </ul>
              {project.url && (
                <a
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-orange-400 font-medium hover:text-orange-300 transition-colors inline-flex items-center gap-1"
                >
                  Visit site
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                  </svg>
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Local SEO Case Studies -->
    <section class="max-w-7xl mx-auto mt-16 pt-16 border-t border-slate-200">
      <div class="text-center mb-12" data-aos="fade-up">
        <h2 class="text-2xl md:text-3xl font-bold mb-3 text-slate-900">Local SEO &amp; Web Results</h2>
        <p class="text-slate-600 text-sm md:text-base max-w-2xl mx-auto">City-specific strategies and measurable outcomes for Orange County businesses.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {caseStudies.map((study, i) => (
          <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6 sm:p-8" data-aos="fade-up" data-aos-delay={i * 100}>
            <div class="inline-flex items-center gap-2 px-2 py-1 rounded-full bg-orange-500/10 border border-orange-500/30 text-xs font-medium text-orange-400 mb-4">
              {study.location}
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">{study.title}</h3>
            <p class="text-sm font-semibold text-orange-400 mb-3">{study.result}</p>
            <p class="text-sm text-slate-600 mb-4 leading-relaxed">{study.description}</p>
            <div class="flex flex-wrap gap-2 mb-4">
              {study.tags.map((tag) => (
                <span class="px-2 py-1 text-[11px] rounded bg-slate-100 border border-slate-200 text-slate-700">{tag}</span>
              ))}
            </div>
            <div class="flex flex-col gap-2">
              <a href={study.link} class="text-sm text-orange-400 font-medium hover:text-orange-300 transition-colors">Read case study →</a>
              <a href={study.serviceLink} class="text-sm text-slate-600 hover:text-orange-300 transition-colors">Local SEO services →</a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Process Timeline -->
    <section class="max-w-7xl mx-auto mt-12 py-16 md:py-24 px-6 md:px-8 bg-slate-50 border-y border-slate-100">
      <h2 class="text-2xl md:text-3xl font-bold mb-12 text-center" data-aos="fade-up">How We Deliver</h2>
      <!-- Desktop: Horizontal Timeline -->
      <div class="hidden md:flex items-center justify-between relative">
        <!-- Connecting line -->
        <div class="absolute top-6 left-0 right-0 h-0.5 bg-orange-500/30 -z-10"></div>
        <!-- Step 1 -->
        <div class="flex flex-col items-center flex-1 relative group cursor-pointer" data-aos="zoom-in" data-aos-delay="0">
          <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">1</div>
          <h3 class="font-bold text-slate-900 mb-2 text-center group-hover:text-orange-400 transition-colors">Plan</h3>
          <p class="text-sm text-slate-600 text-center max-w-[180px]">Sitemap, content, and goals aligned.</p>
        </div>
        <!-- Step 2 -->
        <div class="flex flex-col items-center flex-1 relative group cursor-pointer" data-aos="zoom-in" data-aos-delay="150">
          <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">2</div>
          <h3 class="font-bold text-slate-900 mb-2 text-center group-hover:text-orange-400 transition-colors">Design</h3>
          <p class="text-sm text-slate-600 text-center max-w-[180px]">Visual concepts refined together.</p>
        </div>
        <!-- Step 3 -->
        <div class="flex flex-col items-center flex-1 relative group cursor-pointer" data-aos="zoom-in" data-aos-delay="300">
          <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">3</div>
          <h3 class="font-bold text-slate-900 mb-2 text-center group-hover:text-orange-400 transition-colors">Build</h3>
          <p class="text-sm text-slate-600 text-center max-w-[180px]">Clean, fast implementation and QA.</p>
        </div>
        <!-- Step 4 -->
        <div class="flex flex-col items-center flex-1 relative group cursor-pointer" data-aos="zoom-in" data-aos-delay="450">
          <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">4</div>
          <h3 class="font-bold text-slate-900 mb-2 text-center group-hover:text-orange-400 transition-colors">Launch</h3>
          <p class="text-sm text-slate-600 text-center max-w-[180px]">Testing, deploy, and smooth handoff.</p>
        </div>
      </div>
      <!-- Mobile: Vertical Timeline -->
      <div class="md:hidden space-y-8">
        <div class="flex gap-4 relative">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg">1</div>
            <div class="w-0.5 h-full bg-orange-500/30 mt-2 absolute top-12 left-6"></div>
          </div>
          <div class="flex-1 pt-2">
            <h3 class="font-bold text-slate-900 mb-2">Plan</h3>
            <p class="text-sm text-slate-600">Sitemap, content, and goals aligned.</p>
          </div>
        </div>
        <div class="flex gap-4 relative">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg">2</div>
            <div class="w-0.5 h-full bg-orange-500/30 mt-2 absolute top-12 left-6"></div>
          </div>
          <div class="flex-1 pt-2">
            <h3 class="font-bold text-slate-900 mb-2">Design</h3>
            <p class="text-sm text-slate-600">Visual concepts refined together.</p>
          </div>
        </div>
        <div class="flex gap-4 relative">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg">3</div>
            <div class="w-0.5 h-full bg-orange-500/30 mt-2 absolute top-12 left-6"></div>
          </div>
          <div class="flex-1 pt-2">
            <h3 class="font-bold text-slate-900 mb-2">Build</h3>
            <p class="text-sm text-slate-600">Clean, fast implementation and QA.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg">4</div>
          </div>
          <div class="flex-1 pt-2">
            <h3 class="font-bold text-slate-900 mb-2">Launch</h3>
            <p class="text-sm text-slate-600">Testing, deploy, and smooth handoff.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class="text-center mt-12 sm:mt-16 px-4" data-aos="fade-up">
      <div class="inline-flex flex-col sm:flex-row gap-3 sm:gap-3 w-full sm:w-auto">
        <a href="/contact" class="px-8 sm:px-10 py-4 sm:py-5 bg-orange-700 text-white font-bold rounded-full hover:bg-orange-600 transition-colors text-base sm:text-lg btn-glow">
          Request a free consult
        </a>
        <a href="/services" class="px-8 sm:px-10 py-4 sm:py-5 bg-slate-100 text-slate-900 font-bold rounded-full border border-slate-200 hover:bg-slate-100 transition-colors text-base sm:text-lg">
          Our services
        </a>
      </div>
      <p class="text-slate-600 text-xs sm:text-sm mt-3">Prefer a call? Add your number in the email.</p>
    </div>
  </main>
</MainLayout>


