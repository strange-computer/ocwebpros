---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Portfolio | Lake Forest Websites" bodyClass="page-portfolio">
  <link rel="stylesheet" href="/css/pages/portfolio.css" />

  <!-- Hero -->
  <header class="relative pt-32 sm:pt-32 md:pt-40 pb-12 sm:pb-16 px-4 sm:px-6 text-center overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90vw] max-w-[800px] h-[400px] sm:h-[500px] md:h-[600px] glow-bg pointer-events-none opacity-40"></div>
    <div class="max-w-5xl mx-auto relative">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-orange-400 mb-6">
        <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
        Portfolio
      </div>
      <h1 class="text-3xl sm:text-4xl md:text-6xl font-bold tracking-tight mb-4">
        Selected <span class="text-gradient-orange">Work</span>
      </h1>
      <p class="text-zinc-400 text-base sm:text-lg leading-relaxed px-4">
        A handful of recent builds. Each site is tailored to goals, content, and audience—no templates.
      </p>
    </div>
  </header>

  <main class="pb-16 sm:pb-24 px-4 sm:px-6">
    <!-- Featured projects -->
    <section class="max-w-7xl mx-auto">
      <div class="grid md:grid-cols-3 gap-6">
        {Array.from({ length: 6 }).map((_, i) => (
          <div class="framer-card p-4 rounded-2xl group overflow-hidden" data-aos="fade-up" data-aos-delay={i * 100}>
            {i === 0 ? (
              <div class="relative h-52 rounded-xl border border-white/10 mb-4 overflow-hidden">
                <img src="/images/honkpill.com_.png" alt="Honkpill product site preview" class="w-full h-full object-cover object-top" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-br from-zinc-900/40 to-zinc-900/10 opacity-80 group-hover:opacity-40 transition-opacity"></div>
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(251,146,60,0.12),transparent_40%)] opacity-80 group-hover:opacity-40 transition-opacity"></div>
              </div>
            ) : i === 1 ? (
              <div class="relative h-52 rounded-xl border border-white/10 mb-4 overflow-hidden">
                <img src="/images/realestate.png" alt="Real Estate site preview" class="w-full h-full object-cover object-top" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-br from-zinc-900/40 to-zinc-900/10 opacity-80 group-hover:opacity-40 transition-opacity"></div>
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(251,146,60,0.12),transparent_40%)] opacity-80 group-hover:opacity-40 transition-opacity"></div>
              </div>
            ) : i === 2 ? (
              <div class="relative h-52 rounded-xl border border-white/10 mb-4 overflow-hidden">
                <img src="/images/temptingdesign.com_.png" alt="Tempting Design site preview" class="w-full h-full object-cover object-top" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-br from-zinc-900/40 to-zinc-900/10 opacity-80 group-hover:opacity-40 transition-opacity"></div>
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(251,146,60,0.12),transparent_40%)] opacity-80 group-hover:opacity-40 transition-opacity"></div>
              </div>
            ) : i === 3 ? (
              <div class="relative h-52 rounded-xl border border-white/10 mb-4 overflow-hidden">
                <img src="/images/mint.gondolaadventureclub.com_.png" alt="Gondola Adventure Club Mint preview" class="w-full h-full object-cover object-top" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-br from-zinc-900/40 to-zinc-900/10 opacity-80 group-hover:opacity-40 transition-opacity"></div>
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(251,146,60,0.12),transparent_40%)] opacity-80 group-hover:opacity-40 transition-opacity"></div>
              </div>
            ) : i === 4 ? (
              <div class="relative h-52 rounded-xl border border-white/10 mb-4 overflow-hidden">
                <img src="/images/houghchiropractic.png" alt="Hough Chiropractic site preview" class="w-full h-full object-cover object-top" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-br from-zinc-900/40 to-zinc-900/10 opacity-80 group-hover:opacity-40 transition-opacity"></div>
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(251,146,60,0.12),transparent_40%)] opacity-80 group-hover:opacity-40 transition-opacity"></div>
              </div>
            ) : i === 5 ? (
              <div class="relative h-52 rounded-xl border border-white/10 mb-4 overflow-hidden">
                <img src="/images/leadcrusade.png" alt="Lead Crusade site preview" class="w-full h-full object-cover object-top" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-br from-zinc-900/40 to-zinc-900/10 opacity-80 group-hover:opacity-40 transition-opacity"></div>
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(251,146,60,0.12),transparent_40%)] opacity-80 group-hover:opacity-40 transition-opacity"></div>
              </div>
            ) : (
              <div class="relative h-44 rounded-xl border border-white/10 bg-gradient-to-br from-zinc-800/60 to-zinc-900/60 mb-4 overflow-hidden">
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(251,146,60,0.12),transparent_40%)]"></div>
                <div class="absolute bottom-2 right-2 text-[10px] px-2 py-1 rounded-full bg-white/10 border border-white/10 text-zinc-300">Mock</div>
              </div>
            )}
            <div class="px-2 pb-2">
              <h3 class="text-lg font-semibold mb-1 text-white">
                {i === 0
                  ? 'Honkpill'
                  : i === 1
                  ? 'Real Estate'
                  : i === 2
                  ? 'Tempting Design'
                  : i === 3
                  ? 'Gondola Adventure Club'
                  : i === 4
                  ? 'Hough Chiropractic'
                  : i === 5
                  ? 'Lead Crusade'
                  : `Project Title ${i + 1}`}
              </h3>
              <p class="text-sm text-zinc-400 mb-3">Modern, fast, and mobile‑first with clear calls to action.</p>
              <div class="flex flex-wrap gap-2 mb-3">
                <span class="px-2 py-1 text-[11px] rounded bg-white/5 border border-white/10 text-zinc-300">Design</span>
                <span class="px-2 py-1 text-[11px] rounded bg-white/5 border border-white/10 text-zinc-300">Build</span>
                <span class="px-2 py-1 text-[11px] rounded bg-white/5 border border-white/10 text-zinc-300">Local SEO</span>
              </div>
              <ul class="text-[12px] text-zinc-400 space-y-1">
                <li class="flex gap-2"><span class="text-orange-400">•</span> Clear service pages and CTAs</li>
                <li class="flex gap-2"><span class="text-orange-400">•</span> Lightweight animations</li>
                <li class="flex gap-2"><span class="text-orange-400">•</span> Fast on mobile</li>
              </ul>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Process Timeline -->
    <section class="max-w-7xl mx-auto mt-12 py-16 md:py-24 px-6 md:px-8 bg-zinc-900/30 border-y border-white/5">
      <h2 class="text-2xl md:text-3xl font-bold mb-12 text-center" data-aos="fade-up">How We Deliver</h2>
      <!-- Desktop: Horizontal Timeline -->
      <div class="hidden md:flex items-center justify-between relative">
        <!-- Connecting line -->
        <div class="absolute top-6 left-0 right-0 h-0.5 bg-orange-500/30 -z-10"></div>
        <!-- Step 1 -->
        <div class="flex flex-col items-center flex-1 relative group cursor-pointer" data-aos="zoom-in" data-aos-delay="0">
          <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">1</div>
          <h3 class="font-bold text-white mb-2 text-center group-hover:text-orange-400 transition-colors">Plan</h3>
          <p class="text-sm text-zinc-400 text-center max-w-[180px]">Sitemap, content, and goals aligned.</p>
        </div>
        <!-- Step 2 -->
        <div class="flex flex-col items-center flex-1 relative group cursor-pointer" data-aos="zoom-in" data-aos-delay="150">
          <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">2</div>
          <h3 class="font-bold text-white mb-2 text-center group-hover:text-orange-400 transition-colors">Design</h3>
          <p class="text-sm text-zinc-400 text-center max-w-[180px]">Visual concepts refined together.</p>
        </div>
        <!-- Step 3 -->
        <div class="flex flex-col items-center flex-1 relative group cursor-pointer" data-aos="zoom-in" data-aos-delay="300">
          <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">3</div>
          <h3 class="font-bold text-white mb-2 text-center group-hover:text-orange-400 transition-colors">Build</h3>
          <p class="text-sm text-zinc-400 text-center max-w-[180px]">Clean, fast implementation and QA.</p>
        </div>
        <!-- Step 4 -->
        <div class="flex flex-col items-center flex-1 relative group cursor-pointer" data-aos="zoom-in" data-aos-delay="450">
          <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">4</div>
          <h3 class="font-bold text-white mb-2 text-center group-hover:text-orange-400 transition-colors">Launch</h3>
          <p class="text-sm text-zinc-400 text-center max-w-[180px]">Testing, deploy, and smooth handoff.</p>
        </div>
      </div>
      <!-- Mobile: Vertical Timeline -->
      <div class="md:hidden space-y-8">
        <div class="flex gap-4 relative">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg">1</div>
            <div class="w-0.5 h-full bg-orange-500/30 mt-2 absolute top-12 left-6"></div>
          </div>
          <div class="flex-1 pt-2">
            <h3 class="font-bold text-white mb-2">Plan</h3>
            <p class="text-sm text-zinc-400">Sitemap, content, and goals aligned.</p>
          </div>
        </div>
        <div class="flex gap-4 relative">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg">2</div>
            <div class="w-0.5 h-full bg-orange-500/30 mt-2 absolute top-12 left-6"></div>
          </div>
          <div class="flex-1 pt-2">
            <h3 class="font-bold text-white mb-2">Design</h3>
            <p class="text-sm text-zinc-400">Visual concepts refined together.</p>
          </div>
        </div>
        <div class="flex gap-4 relative">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg">3</div>
            <div class="w-0.5 h-full bg-orange-500/30 mt-2 absolute top-12 left-6"></div>
          </div>
          <div class="flex-1 pt-2">
            <h3 class="font-bold text-white mb-2">Build</h3>
            <p class="text-sm text-zinc-400">Clean, fast implementation and QA.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg">4</div>
          </div>
          <div class="flex-1 pt-2">
            <h3 class="font-bold text-white mb-2">Launch</h3>
            <p class="text-sm text-zinc-400">Testing, deploy, and smooth handoff.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class="text-center mt-12 sm:mt-16 px-4" data-aos="fade-up">
      <div class="inline-flex flex-col sm:flex-row gap-3 sm:gap-3 w-full sm:w-auto">
        <a href="mailto:info@example.com" class="px-8 sm:px-10 py-4 sm:py-5 bg-orange-600 text-white font-bold rounded-full hover:bg-orange-500 transition-colors text-base sm:text-lg btn-glow">
          Request a free consult
        </a>
        <a href="/services" class="px-8 sm:px-10 py-4 sm:py-5 bg-white/5 text-white font-bold rounded-full border border-white/10 hover:bg-white/10 transition-colors text-base sm:text-lg">
          Our services
        </a>
      </div>
      <p class="text-zinc-500 text-xs sm:text-sm mt-3">Prefer a call? Add your number in the email.</p>
    </div>
  </main>
</MainLayout>


