---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout 
  title="Checkout Cancelled | OCWebPros" 
  description="Your checkout was cancelled. Your cart is saved and you can return anytime to complete your purchase."
  bodyClass="page-cancel">
  <header class="relative pt-32 sm:pt-32 md:pt-40 pb-12 sm:pb-16 px-4 sm:px-6 text-center overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90vw] max-w-[800px] h-[400px] sm:h-[500px] md:h-[600px] glow-bg pointer-events-none opacity-40"></div>
    <div class="max-w-5xl mx-auto relative">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-zinc-400 mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
        Checkout Cancelled
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4">
        No problem at all
      </h1>
      <p class="text-zinc-400 text-lg leading-relaxed">
        Your cart is still saved. You can return anytime to complete your purchase.
      </p>
    </div>
  </header>

  <main class="pb-24 px-6 md:px-8">
    <div class="max-w-2xl mx-auto">
      <div class="backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-2xl p-8 text-center">
        <svg class="w-16 h-16 text-zinc-500 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
        </svg>
        
        <h2 class="text-2xl font-bold text-white mb-3">Your items are waiting</h2>
        <p class="text-zinc-400 mb-6">
          We've saved your selections. When you're ready, just head back to complete your purchase.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/pricing" class="px-8 py-3.5 bg-orange-600 text-white font-semibold rounded-full hover:bg-orange-500 transition-colors btn-glow">
            Return to Pricing
          </a>
          <a href="/contact" class="px-8 py-3.5 bg-white/5 text-white font-semibold rounded-full border border-white/10 hover:bg-white/10 transition-colors">
            Contact Us Instead
          </a>
        </div>
      </div>

      <!-- Help Section -->
      <div class="mt-8 text-center">
        <p class="text-zinc-400 text-sm mb-3">Have questions or need help deciding?</p>
        <div class="flex gap-4 justify-center text-sm">
          <a href="tel:9493294437" class="text-orange-400 hover:text-orange-300 transition-colors">
            Call (949) 329-4437
          </a>
          <span class="text-zinc-600">or</span>
          <a href="mailto:info@ocwebpros.com" class="text-orange-400 hover:text-orange-300 transition-colors">
            Email Us
          </a>
        </div>
      </div>
    </div>
  </main>
</MainLayout>
