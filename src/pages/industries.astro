---
import MainLayout from '../layouts/MainLayout.astro';
import SpotlightImage from '../components/SpotlightImage.astro';
import { industrySectors, industryResources } from '../data/industriesPage';
---
<MainLayout 
  title="Industries | OCWebPros" 
  description="Industry-specific web design and local SEO for contractors, healthcare, restaurants, professional services, retail, and more in Orange County. Guides, case studies, and conversion-focused builds."
  bodyClass="page-industries"
  pageCSS="/css/pages/industries.css">

  <!-- Hero -->
  <header class="relative pt-32 sm:pt-32 md:pt-40 pb-12 sm:pb-16 px-4 sm:px-6 text-center overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90vw] max-w-[800px] h-[400px] sm:h-[500px] md:h-[600px] glow-bg pointer-events-none opacity-40"></div>
    <div class="max-w-5xl mx-auto relative">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-orange-400 mb-6">
        <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
        Industries
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4">
        Websites for <span class="text-gradient-orange">Local Businesses</span>
      </h1>
      <p class="text-zinc-400 text-lg leading-relaxed max-w-2xl mx-auto">
        Industry-specific websites and local SEO for Orange County businesses — with guides, case studies, and service pages built to rank and convert.
      </p>
      <div class="flex flex-wrap justify-center gap-3 mt-8">
        <a href="/services/web-design" class="px-5 py-2.5 bg-white/5 text-white text-sm font-medium rounded-full border border-white/10 hover:bg-white/10 transition-colors">Web Design</a>
        <a href="/services/local-seo" class="px-5 py-2.5 bg-white/5 text-white text-sm font-medium rounded-full border border-white/10 hover:bg-white/10 transition-colors">Local SEO</a>
        <a href="/pricing" class="px-5 py-2.5 bg-orange-700/80 text-white text-sm font-medium rounded-full hover:bg-orange-600 transition-colors">View Pricing</a>
        <a href="/service-areas" class="px-5 py-2.5 bg-white/5 text-white text-sm font-medium rounded-full border border-white/10 hover:bg-white/10 transition-colors">Service Areas</a>
      </div>
    </div>
  </header>

  <main class="pb-24 px-6 md:px-8">
    <!-- Spotlight Section -->
    <section class="max-w-7xl mx-auto pt-8 md:pt-12 pb-16 md:pb-24">
      <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
        <!-- Text Content (Left on desktop, bottom on mobile) -->
        <div class="w-full md:w-1/2 backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-2xl p-8 md:p-10" data-aos="fade-right">
          <div class="w-12 h-12 bg-white/5 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h2 class="text-3xl md:text-4xl font-bold mb-4 text-white">Built for Your Industry</h2>
          <p class="text-zinc-400 mb-6 text-lg leading-relaxed">Your website should reflect your community presence, showcase your expertise, and make it effortless for customers to choose you. We build sites that work the way your business works.</p>
          <ul class="space-y-3 text-zinc-300 mb-6">
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Tailored to your specific industry and service area</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Designed to convert visitors into customers</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Optimized for local search visibility across Orange County</span></li>
          </ul>
          <p class="text-sm text-zinc-500 leading-relaxed">
            Based in <a href="/local-seo/lake-forest" class="text-orange-400 hover:text-orange-300 transition-colors">Lake Forest</a>, serving
            <a href="/service-areas" class="text-orange-400 hover:text-orange-300 transition-colors">24 OC cities</a> with
            <a href="/services/web-design" class="text-orange-400 hover:text-orange-300 transition-colors">custom web design</a> and
            <a href="/services/local-seo" class="text-orange-400 hover:text-orange-300 transition-colors">ongoing local SEO</a>.
          </p>
        </div>
        <!-- Mockup (Right on desktop, top on mobile) -->
        <SpotlightImage
          src="/images/unsplash/industries-local-business.jpg"
          alt="Local business storefront with a support local sign in the window"
        />
      </div>
    </section>

    <!-- Why choose us for local -->
    <section class="max-w-7xl mx-auto pt-2 md:pt-4 pb-16 md:pb-24 px-6 md:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        <div class="group hover:scale-105 transition-transform" data-aos="fade-up" data-aos-delay="0">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Built for Your Business</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">No generic themes. Layouts and messaging tailored to your services, service areas, and customers.</p>
        </div>
        <div class="group hover:scale-105 transition-transform" data-aos="fade-up" data-aos-delay="100">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Built to Last</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Clean code, mobile‑first structure, and performance best practices. Easy to manage, ready to grow.</p>
        </div>
        <div class="group hover:scale-105 transition-transform" data-aos="fade-up" data-aos-delay="200">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Conversion‑First</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Service pages, trust signals, reviews, maps, and clear CTAs make it easy to call, book, or request a quote.</p>
        </div>
      </div>
    </section>

    <!-- Industries We Serve -->
    <section class="max-w-7xl mx-auto py-16 md:py-24 px-6 md:px-8 bg-zinc-900/30 border-y border-white/5">
      <div class="text-center mb-10 md:mb-12" data-aos="fade-up">
        <h2 class="text-2xl md:text-3xl font-bold mb-3">Industries We Serve</h2>
        <p class="text-zinc-400 text-sm md:text-base max-w-2xl mx-auto">
          Every sector gets a different playbook. Explore what we build, read the guides we&apos;ve published, and see how our services fit your business.
        </p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {industrySectors.map((sector, index) => (
          <article class="industry-sector-card backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-2xl p-6 md:p-8 hover:bg-white/[0.07] hover:border-white/20 transition-all" data-aos="fade-up" data-aos-delay={index * 50}>
            <h3 class="text-xl font-bold text-white mb-2">{sector.title}</h3>
            <p class="text-sm text-orange-400/90 font-medium mb-3">{sector.summary}</p>
            <p class="text-sm text-zinc-400 leading-relaxed mb-5">{sector.detail}</p>
            <ul class="space-y-2 mb-6">
              {sector.highlights.map((item) => (
                <li class="flex items-start gap-2.5 text-sm text-zinc-300">
                  <span class="w-1.5 h-1.5 rounded-full bg-orange-500 mt-2 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <div class="flex flex-wrap gap-2 pt-5 border-t border-white/10">
              {sector.guides.map((guide) => (
                <a href={`/blog/${guide.slug}`} class="text-xs px-3 py-1.5 rounded-full bg-orange-500/10 border border-orange-500/25 text-orange-400 hover:bg-orange-500/20 transition-colors">
                  {guide.label} →
                </a>
              ))}
              {sector.webDesignPath && (
                <a href={sector.webDesignPath} class="text-xs px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-zinc-300 hover:bg-white/10 transition-colors">
                  Web Design
                </a>
              )}
              {sector.localSeoPath && (
                <a href={sector.localSeoPath} class="text-xs px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-zinc-300 hover:bg-white/10 transition-colors">
                  Local SEO
                </a>
              )}
              {sector.pricingAnchor && (
                <a href={`/pricing${sector.pricingAnchor}`} class="text-xs px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-zinc-300 hover:bg-white/10 transition-colors">
                  Pricing
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Industry guides & case studies -->
    <section class="max-w-7xl mx-auto py-16 md:py-24 px-6 md:px-8">
      <div class="text-center mb-10" data-aos="fade-up">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-orange-400 mb-4">
          <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
          Deep Dives
        </div>
        <h2 class="text-2xl md:text-3xl font-bold mb-3">Industry Guides &amp; Case Studies</h2>
        <p class="text-zinc-400 text-sm max-w-xl mx-auto">
          In-depth resources we&apos;ve written for Orange County businesses — or browse all posts on the <a href="/blog" class="text-orange-400 hover:text-orange-300 transition-colors">blog</a>.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {industryResources.map((resource, index) => (
          <a
            href={`/blog/${resource.slug}`}
            class="industry-resource-card group block backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-xl p-5 hover:bg-white/[0.07] hover:border-orange-500/30 transition-all"
            data-aos="fade-up"
            data-aos-delay={index * 30}
          >
            <span class="text-xs text-orange-400 font-medium">{resource.category}</span>
            <h3 class="text-base font-bold text-white mt-1 mb-2 group-hover:text-orange-400 transition-colors">{resource.title}</h3>
            <p class="text-xs text-zinc-500">{resource.sector}</p>
          </a>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/blog" class="text-sm text-orange-400 font-medium hover:text-orange-300 transition-colors inline-flex items-center gap-1">
          View all blog posts
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </a>
      </div>
    </section>

    <!-- What you get -->
    <section class="max-w-7xl mx-auto py-16 md:py-24 px-6 md:px-8 border-y border-white/5">
      <h2 class="text-2xl md:text-3xl font-bold mb-8 text-center" data-aos="fade-up">What You Get</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        <div class="group hover:scale-105 transition-transform" data-aos="fade-up" data-aos-delay="0">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Service & Location Pages</h3>
          <p class="text-sm text-zinc-400 leading-relaxed mb-3">Structured pages for each service and city you target — built for users and local SEO.</p>
          <a href="/service-areas" class="text-sm text-orange-400 font-medium hover:text-orange-300 transition-colors">Browse service areas →</a>
        </div>
        <div class="group hover:scale-105 transition-transform" data-aos="fade-up" data-aos-delay="100">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Reviews & Trust Signals</h3>
          <p class="text-sm text-zinc-400 leading-relaxed mb-3">Testimonials, badges, and policies placed strategically to reduce friction and increase inquiries.</p>
          <a href="/blog/2026-07-05-trust-signals-local-seo-2026" class="text-sm text-orange-400 font-medium hover:text-orange-300 transition-colors">Trust signals guide →</a>
        </div>
        <div class="group hover:scale-105 transition-transform" data-aos="fade-up" data-aos-delay="200">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Speed, Security, & Hygiene</h3>
          <p class="text-sm text-zinc-400 leading-relaxed mb-3">Core Web Vitals, managed hosting, and ongoing support — search engines and customers both get what they need.</p>
          <div class="flex flex-wrap gap-x-4 gap-y-1">
            <a href="/hosting" class="text-sm text-orange-400 font-medium hover:text-orange-300 transition-colors">Hosting →</a>
            <a href="/support" class="text-sm text-orange-400 font-medium hover:text-orange-300 transition-colors">Support →</a>
          </div>
      </div>
    </section>

    <!-- Process Timeline -->
    <section class="max-w-7xl mx-auto py-16 md:py-24 px-6 md:px-8 bg-zinc-900/30 border-y border-white/5">
      <h2 class="text-2xl md:text-3xl font-bold mb-12 text-center" data-aos="fade-up">Our Simple Process</h2>
      <!-- Desktop: Horizontal Timeline -->
      <div class="hidden md:flex items-center justify-between relative">
        <!-- Connecting line -->
        <div class="absolute top-6 left-0 right-0 h-0.5 bg-orange-500/30 -z-10"></div>
        <!-- Step 1 -->
        <div class="flex flex-col items-center flex-1 relative group cursor-pointer" data-aos="zoom-in" data-aos-delay="0">
          <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">1</div>
          <h3 class="font-bold text-white mb-2 text-center group-hover:text-orange-400 transition-colors">Discovery</h3>
          <p class="text-sm text-zinc-400 text-center max-w-[180px]">Goals, audience, competitive context.</p>
        </div>
        <!-- Step 2 -->
        <div class="flex flex-col items-center flex-1 relative group cursor-pointer" data-aos="zoom-in" data-aos-delay="150">
          <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">2</div>
          <h3 class="font-bold text-white mb-2 text-center group-hover:text-orange-400 transition-colors">Sitemap & Design</h3>
          <p class="text-sm text-zinc-400 text-center max-w-[180px]">Structure and visuals reviewed together.</p>
        </div>
        <!-- Step 3 -->
        <div class="flex flex-col items-center flex-1 relative group cursor-pointer" data-aos="zoom-in" data-aos-delay="300">
          <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">3</div>
          <h3 class="font-bold text-white mb-2 text-center group-hover:text-orange-400 transition-colors">Build</h3>
          <p class="text-sm text-zinc-400 text-center max-w-[180px]">Clean implementation with content and QA.</p>
        </div>
        <!-- Step 4 -->
        <div class="flex flex-col items-center flex-1 relative group cursor-pointer" data-aos="zoom-in" data-aos-delay="450">
          <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">4</div>
          <h3 class="font-bold text-white mb-2 text-center group-hover:text-orange-400 transition-colors">Launch</h3>
          <p class="text-sm text-zinc-400 text-center max-w-[180px]">Cross‑device testing and go‑live checklist.</p>
        </div>
        <!-- Step 5 -->
        <div class="flex flex-col items-center flex-1 relative group cursor-pointer" data-aos="zoom-in" data-aos-delay="600">
          <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">5</div>
          <h3 class="font-bold text-white mb-2 text-center group-hover:text-orange-400 transition-colors">Support</h3>
          <p class="text-sm text-zinc-400 text-center max-w-[180px]">Updates, hosting, and growth options.</p>
        </div>
      </div>
      <!-- Mobile: Vertical Timeline -->
      <div class="md:hidden space-y-8">
        <div class="flex gap-4 relative">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg">1</div>
            <div class="w-0.5 h-full bg-orange-500/30 mt-2 absolute top-12 left-6"></div>
          </div>
          <div class="flex-1 pt-2">
            <h3 class="font-bold text-white mb-2">Discovery</h3>
            <p class="text-sm text-zinc-400">Goals, audience, competitive context.</p>
          </div>
        </div>
        <div class="flex gap-4 relative">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg">2</div>
            <div class="w-0.5 h-full bg-orange-500/30 mt-2 absolute top-12 left-6"></div>
          </div>
          <div class="flex-1 pt-2">
            <h3 class="font-bold text-white mb-2">Sitemap & Design</h3>
            <p class="text-sm text-zinc-400">Structure and visuals reviewed together.</p>
          </div>
        </div>
        <div class="flex gap-4 relative">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg">3</div>
            <div class="w-0.5 h-full bg-orange-500/30 mt-2 absolute top-12 left-6"></div>
          </div>
          <div class="flex-1 pt-2">
            <h3 class="font-bold text-white mb-2">Build</h3>
            <p class="text-sm text-zinc-400">Clean implementation with content and QA.</p>
          </div>
        </div>
        <div class="flex gap-4 relative">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg">4</div>
            <div class="w-0.5 h-full bg-orange-500/30 mt-2 absolute top-12 left-6"></div>
          </div>
          <div class="flex-1 pt-2">
            <h3 class="font-bold text-white mb-2">Launch</h3>
            <p class="text-sm text-zinc-400">Cross‑device testing and go‑live checklist.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg">5</div>
          </div>
          <div class="flex-1 pt-2">
            <h3 class="font-bold text-white mb-2">Support</h3>
            <p class="text-sm text-zinc-400">Updates, hosting, and growth options.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="text-center py-16 md:py-24 px-6 md:px-8" data-aos="fade-up">
      <div class="inline-flex flex-col sm:flex-row gap-4">
        <a href="/contact" class="px-10 py-5 bg-orange-700 text-white font-bold rounded-full hover:bg-orange-600 transition-colors text-lg btn-glow">
          Talk to our team
        </a>
        <a href="/pricing" class="px-10 py-5 bg-white/5 text-white font-bold rounded-full border border-white/10 hover:bg-white/10 transition-colors text-lg">
          View pricing
        </a>
        <a href="/portfolio" class="px-10 py-5 bg-white/5 text-white font-bold rounded-full border border-white/10 hover:bg-white/10 transition-colors text-lg">
          See our work
        </a>
      </div>
