---
import MainLayout from '../../layouts/MainLayout.astro';
import SpotlightImage from '../../components/SpotlightImage.astro';
import { industryHubs, industryHubBySlug } from '../../data/industryHubs';

export function getStaticPaths() {
  return industryHubs.map((hub) => ({
    params: { slug: hub.slug },
  }));
}

const { slug } = Astro.params;
const hub = industryHubBySlug[slug!];
if (!hub) {
  throw new Error(`Unknown industry hub: ${slug}`);
}

const siteUrl = Astro.site || new URL(Astro.url.origin);
const pageUrl = new URL(`/industries/${hub.slug}/`, siteUrl).toString();

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: hub.title,
  description: hub.description,
  url: pageUrl,
  provider: {
    '@type': 'LocalBusiness',
    '@id': siteUrl.toString() + '#business',
    name: 'OCWebPros',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Lake Forest',
      addressRegion: 'CA',
      postalCode: '92630',
      addressCountry: 'US',
    },
    telephone: '+1-949-329-4437',
  },
  areaServed: {
    '@type': 'AdministrativeArea',
    name: 'Orange County',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: hub.faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<MainLayout
  title={hub.metaTitle}
  description={hub.description}
  bodyClass="page-industries page-industry-hub"
  pageCSS="/css/pages/industries.css"
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />

  <header class="relative pt-32 sm:pt-32 md:pt-40 pb-12 sm:pb-16 px-4 sm:px-6 text-center overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90vw] max-w-[800px] h-[400px] sm:h-[500px] md:h-[600px] glow-bg pointer-events-none opacity-40"></div>
    <div class="max-w-5xl mx-auto relative">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 border border-slate-200 text-xs font-medium text-orange-400 mb-6">
        <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
        {hub.badge}
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4 text-slate-900">
        {hub.title}
      </h1>
      <p class="text-slate-600 text-lg leading-relaxed max-w-3xl mx-auto">{hub.heroSubtitle}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a href="/contact/" class="px-8 py-3.5 bg-orange-700 text-white font-semibold rounded-full hover:bg-orange-600 transition-colors btn-glow text-sm md:text-base">
          Get a Free Audit
        </a>
        <a href="/pricing/" class="px-8 py-3.5 bg-slate-100 text-slate-900 font-semibold rounded-full border border-slate-200 hover:bg-slate-100 transition-colors text-sm md:text-base">
          View Pricing
        </a>
      </div>
      <p class="mt-6 text-sm text-slate-500">
        <a href="/industries/" class="text-orange-400 hover:text-orange-300 transition-colors">← All industries</a>
      </p>
    </div>
  </header>

  <main class="pb-16 sm:pb-24 px-4 sm:px-6 md:px-8">
    <section class="max-w-4xl mx-auto pt-8 pb-12">
      {hub.intro.map((paragraph) => (
        <p class="text-slate-700 text-lg leading-relaxed mb-6">{paragraph}</p>
      ))}
    </section>

    <section class="max-w-7xl mx-auto pt-4 md:pt-8 pb-16 md:pb-24 px-4 sm:px-6">
      <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
        <SpotlightImage
          class="order-1"
          aos="fade-left"
          src={hub.slug === 'dental' ? '/images/unsplash/services-local-seo.jpg' : '/images/unsplash/industries-local-business.jpg'}
          alt={`${hub.badge} digital marketing in Orange County`}
        />
        <div class="w-full md:w-1/2 backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6 sm:p-8 md:p-10 order-2" data-aos="fade-right">
          <h2 class="text-3xl md:text-4xl font-bold mb-4 text-slate-900">What we deliver</h2>
          <ul class="space-y-5">
            {hub.deliverables.map((item) => (
              <li>
                <h3 class="text-base font-bold text-slate-900 mb-1">{item.title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{item.body}</p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="max-w-7xl mx-auto py-16 md:py-20 px-4 sm:px-6 md:px-8 bg-slate-50 border-y border-slate-100">
      <div class="text-center mb-10" data-aos="fade-up">
        <h2 class="text-2xl md:text-3xl font-bold mb-2 text-slate-900">Why this market is hard</h2>
        <p class="text-slate-600 text-sm md:text-base max-w-2xl mx-auto">The same problems we solve for clients every month.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {hub.challenges.map((item, index) => (
          <div class="backdrop-blur-[12px] bg-white border border-slate-200 rounded-2xl p-6" data-aos="fade-up" data-aos-delay={index * 50}>
            <h3 class="text-lg font-bold text-slate-900 mb-2">{item.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="max-w-7xl mx-auto py-16 md:py-20 px-4 sm:px-6 md:px-8">
      <div class="text-center mb-10" data-aos="fade-up">
        <h2 class="text-2xl md:text-3xl font-bold mb-2 text-slate-900">Cities we pair with this work</h2>
        <p class="text-slate-600 text-sm md:text-base max-w-2xl mx-auto">
          Industry hubs plus <a href="/services/local-seo/" class="text-orange-400 hover:text-orange-300">city SEO pages</a> — the combination that ranks hire intent.
        </p>
      </div>
      <div class="flex flex-wrap justify-center gap-3 max-w-3xl mx-auto">
        {hub.cityLinks.map((link) => (
          <a href={link.href} class="px-4 py-2 rounded-full bg-slate-100 border border-slate-200 text-sm font-medium text-slate-800 hover:border-orange-300 hover:text-orange-600 transition-colors">
            {link.label}
          </a>
        ))}
      </div>
    </section>

    <section class="max-w-4xl mx-auto py-12 px-4 sm:px-6">
      <h2 class="text-2xl md:text-3xl font-bold mb-6 text-slate-900 text-center">Guides</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {hub.guides.map((guide) => (
          <a href={`/blog/${guide.slug}/`} class="text-sm px-4 py-2 rounded-full bg-orange-500/10 border border-orange-500/25 text-orange-500 hover:bg-orange-500/20 transition-colors">
            {guide.label} →
          </a>
        ))}
        <a href="/services/local-seo/" class="text-sm px-4 py-2 rounded-full bg-slate-100 border border-slate-200 text-slate-700 hover:bg-white transition-colors">Local SEO</a>
        <a href="/services/web-design/" class="text-sm px-4 py-2 rounded-full bg-slate-100 border border-slate-200 text-slate-700 hover:bg-white transition-colors">Web Design</a>
      </div>
    </section>

    <section class="max-w-3xl mx-auto py-16 px-4 sm:px-6">
      <h2 class="text-2xl md:text-3xl font-bold mb-8 text-slate-900 text-center">FAQ</h2>
      <div class="space-y-6">
        {hub.faqs.map((faq) => (
          <div class="border-b border-slate-200 pb-6">
            <h3 class="text-lg font-bold text-slate-900 mb-2">{faq.question}</h3>
            <p class="text-slate-600 leading-relaxed">{faq.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="max-w-3xl mx-auto text-center py-12 px-4">
      <h2 class="text-2xl md:text-3xl font-bold mb-4 text-slate-900">Ready to grow?</h2>
      <p class="text-slate-600 mb-8 leading-relaxed">
        Request a free audit. We’ll show where you stand in Maps and organic — and what to fix first.
      </p>
      <a href="/contact/" class="inline-flex px-8 py-3.5 bg-orange-700 text-white font-semibold rounded-full hover:bg-orange-600 transition-colors btn-glow text-sm md:text-base">
        Contact OCWebPros
      </a>
    </section>
  </main>
</MainLayout>
