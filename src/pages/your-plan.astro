---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout 
  title="Your Plan | OCWebPros" 
  description="Review your selected web design, SEO, hosting, and support services. Get in touch to discuss your custom plan."
  bodyClass="page-your-plan">

  <header class="relative pt-32 sm:pt-32 md:pt-40 pb-12 sm:pb-16 px-4 sm:px-6 text-center overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90vw] max-w-[800px] h-[400px] sm:h-[500px] md:h-[600px] glow-bg pointer-events-none opacity-40"></div>
    <div class="max-w-5xl mx-auto relative">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 border border-slate-200 text-xs font-medium text-orange-400 mb-6">
        <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
        Your Plan
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4">
        Review your <span class="text-gradient-orange">selections</span>
      </h1>
      <p class="text-slate-600 text-lg leading-relaxed">
        Here's what you've picked. Reach out when you're ready and we'll tailor everything to your business.
      </p>
    </div>
  </header>

  <main class="pb-24 px-6 md:px-8">
    <div class="max-w-2xl mx-auto">
      <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-8">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">Plan Summary</h2>
        
        <div id="planItems" class="space-y-4 mb-6">
          <!-- Plan items will be injected here -->
        </div>

        <div id="planTotals" class="border-t border-slate-200 pt-4 space-y-2 mb-8">
          <!-- Totals will be injected here -->
        </div>

        <p class="text-sm text-slate-600 mb-6">
          What you see here reflects our standard package rates. We'll walk through your selections together, then send a clear invoice based on the plan you choose. No surprises.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a id="contactPlanBtn" href="/contact/"
            class="flex-1 px-8 py-4 bg-orange-700 text-white font-bold rounded-full hover:bg-orange-600 transition-colors btn-glow text-center">
            Get in Touch
          </a>
          <a href="/pricing/"
            class="flex-1 px-8 py-4 bg-slate-100 text-slate-900 font-semibold rounded-full text-center border border-slate-200 hover:bg-slate-100 transition-colors">
            Adjust Selections
          </a>
        </div>
      </div>

      <div class="text-center mt-8">
        <a href="/pricing/" class="text-slate-600 hover:text-slate-900 transition-colors text-sm">
          ← Back to pricing
        </a>
      </div>
    </div>
  </main>

  <script is:inline>
    (function() {
      function buildPlanMailto(items, totals) {
        var lines = ['Hi OCWebPros,', '', 'I\'d like to discuss the following plan:', ''];
        items.forEach(function(item) {
          var price = '$' + item.price.toLocaleString() + (item.type === 'subscription' ? '/mo' : '');
          lines.push('- ' + item.name + ' (' + price + ')');
        });
        lines.push('');
        if (totals.oneTime > 0) {
          lines.push('One-time total: $' + totals.oneTime.toLocaleString());
        }
        if (totals.monthly > 0) {
          lines.push('Monthly total: $' + totals.monthly.toLocaleString() + '/mo');
        }
        lines.push('', 'Thanks!');
        var subject = encodeURIComponent('Plan inquiry from ocwebpros.com');
        var body = encodeURIComponent(lines.join('\n'));
        return 'mailto:hello@ocwebpros.com?subject=' + subject + '&body=' + body;
      }

      function runPlanReview() {
        if (!window.cart) {
          console.error('Plan not initialized');
          window.location.href = '/pricing/';
          return;
        }

        const items = window.cart.getItems();
        const totals = window.cart.getTotals();

        if (items.length === 0) {
          window.location.href = '/pricing/';
          return;
        }

        const planItems = document.getElementById('planItems');
        planItems.innerHTML = items.map(item => `
          <div class="flex justify-between items-start py-3 border-b border-slate-100 last:border-0">
            <div class="flex-1">
              <h3 class="font-semibold text-slate-900 text-sm mb-1">${item.name}</h3>
              <p class="text-xs text-slate-600">
                ${item.type === 'one-time' ? 'One-time' : 'Monthly subscription'}
              </p>
            </div>
            <p class="font-bold text-orange-400 text-sm">
              $${item.price.toLocaleString()}${item.type === 'subscription' ? '/mo' : ''}
            </p>
          </div>
        `).join('');

        let totalsHTML = '';
        
        if (totals.oneTime > 0) {
          totalsHTML += `
            <div class="flex justify-between">
              <span class="text-slate-600">One-time total:</span>
              <span class="text-slate-900 font-bold text-lg">$${totals.oneTime.toLocaleString()}</span>
            </div>
          `;
        }

        if (totals.monthly > 0) {
          totalsHTML += `
            <div class="flex justify-between">
              <span class="text-slate-600">Monthly total:</span>
              <span class="text-slate-900 font-bold text-lg">$${totals.monthly.toLocaleString()}/mo</span>
            </div>
          `;
        }

        document.getElementById('planTotals').innerHTML = totalsHTML;

        const contactBtn = document.getElementById('contactPlanBtn');
        if (contactBtn) {
          contactBtn.href = buildPlanMailto(items, totals);
        }
      }

      function whenCartReady() {
        if (window.cart) {
          runPlanReview();
          return;
        }
        var attempts = 0;
        var t = setInterval(function() {
          attempts++;
          if (window.cart) {
            clearInterval(t);
            runPlanReview();
          } else if (attempts > 40) {
            clearInterval(t);
            window.location.href = '/pricing/';
          }
        }, 50);
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', whenCartReady);
      } else {
        whenCartReady();
      }
    })();
  </script>
</MainLayout>
