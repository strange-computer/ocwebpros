---
import MainLayout from '../layouts/MainLayout.astro';
import SpotlightImage from '../components/SpotlightImage.astro';
---
<MainLayout 
  title="Managed Hosting | OCWebPros" 
  description="Managed hosting for OCWebPros-built sites. Global CDN, auto-renewing SSL, deploy rollback, and uptime monitoring. $75/mo."
  bodyClass="page-hosting"
  pageCSS="/css/pages/hosting.css">

  <!-- Hero -->
  <header class="relative pt-32 sm:pt-32 md:pt-40 pb-12 sm:pb-16 px-4 sm:px-6 text-center overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90vw] max-w-[800px] h-[400px] sm:h-[500px] md:h-[600px] glow-bg pointer-events-none opacity-40"></div>
    <div class="max-w-5xl mx-auto relative">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-orange-400 mb-6">
        <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
        Managed Hosting
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4">
        Hosting That <span class="text-gradient-orange">Actually Works</span>
      </h1>
      <p class="text-zinc-400 text-lg leading-relaxed">
        Fully managed hosting for sites we build: modern cloud infrastructure, always-on SSL, and a team that handles the technical side so you don&apos;t have to.
      </p>
    </div>
  </header>

  <main class="pb-24 px-6 md:px-8">
    <!-- Pricing: The "Peace of Mind" Protocol -->
    <section class="max-w-7xl mx-auto pt-4 md:pt-8 pb-12 md:pb-16 px-4 sm:px-6">
      <div class="max-w-5xl mx-auto">
        <div class="hosting-pricing-card backdrop-blur-[12px] border border-emerald-500/20 rounded-2xl p-6 md:p-8 overflow-hidden relative flex flex-col transition-all duration-300 ease-out shadow-[0_0_30px_rgba(16,185,129,0.08)]" style="background: rgba(24, 24, 27, 0.6);">
          <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/10 via-transparent to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 bg-gradient-to-tl from-teal-500/5 via-transparent to-transparent pointer-events-none"></div>
          <div class="relative">
            <!-- Mobile only: badge + headline at top -->
            <div class="text-center mb-4 md:hidden">
              <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-emerald-400 mb-4">
                <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                MANAGED CLOUD INFRASTRUCTURE
              </div>
              <h2 class="text-2xl md:text-4xl font-bold mb-2 text-white tracking-tight">The &quot;Peace of Mind&quot; Protocol</h2>
              <p class="text-zinc-400 text-sm leading-relaxed">We don&apos;t just host your site. We guard it.</p>
              <p class="text-zinc-500 text-xs mt-2">For websites we&apos;ve built and deploy.</p>
            </div>
            <!-- Mobile: badge/headline (top) → price → features → CTA → Tech Bar. Desktop: left = badge+headline+features, right = price+CTA+Tech Bar -->
            <div class="flex flex-col md:grid gap-6 md:grid-cols-[1fr_auto] md:items-stretch">
              <!-- Left column: badge + headline (desktop only) + features -->
              <div class="order-2 md:order-1 md:col-start-1 md:row-start-1 md:pr-8 min-w-0">
                <div class="hidden md:block text-center mb-4">
                  <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-emerald-400 mb-4">
                    <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                    MANAGED CLOUD INFRASTRUCTURE
                  </div>
                  <h2 class="text-2xl md:text-4xl font-bold mb-2 text-white tracking-tight">The &quot;Peace of Mind&quot; Protocol</h2>
                  <p class="text-zinc-400 text-sm leading-relaxed max-w-xl mx-auto">We don&apos;t just host your site. We guard it.</p>
                  <p class="text-zinc-500 text-xs mt-2">For websites we&apos;ve built and deploy.</p>
                </div>
                <ul class="grid grid-cols-2 md:grid-cols-3 gap-2 md:gap-2">
                  <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                    <svg class="w-5 h-5 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    <div><span class="text-sm font-semibold text-white block">Deploy Rollback</span><span class="text-xs text-zinc-400">Every publish is saved. Roll back to a previous version instantly if an update causes trouble.</span></div>
                  </li>
                  <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                    <svg class="w-5 h-5 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    <div><span class="text-sm font-semibold text-white block">Global CDN &amp; Caching</span><span class="text-xs text-zinc-400">Your site is served from edge locations worldwide for fast load times.</span></div>
                  </li>
                  <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                    <svg class="w-5 h-5 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    <div><span class="text-sm font-semibold text-white block">Uptime Monitoring</span><span class="text-xs text-zinc-400">We check that your site stays online and respond quickly if something goes wrong.</span></div>
                  </li>
                  <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                    <svg class="w-5 h-5 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    <div><span class="text-sm font-semibold text-white block">Edge Security &amp; DDoS Protection</span><span class="text-xs text-zinc-400">Built-in edge protection against DDoS attacks and sudden traffic spikes.</span></div>
                  </li>
                  <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                    <svg class="w-5 h-5 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    <div><span class="text-sm font-semibold text-white block">Auto-Renewing SSL</span><span class="text-xs text-zinc-400">The &quot;Padlock&quot; is managed and renewed for you forever.</span></div>
                  </li>
                  <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                    <svg class="w-5 h-5 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    <div><span class="text-sm font-semibold text-white block">Managed DNS &amp; Domain Setup</span><span class="text-xs text-zinc-400">We configure your domain and DNS at launch so your site goes live without the headache.</span></div>
                  </li>
                </ul>
              </div>
              <!-- Right column: price + CTA + Tech Bar -->
              <div class="contents md:flex md:flex-col md:gap-4 md:pl-8 md:border-l md:border-white/10 md:col-start-2 md:row-start-1 md:justify-center">
                <div class="order-1 md:order-none text-center flex flex-col items-center">
                  <div class="text-4xl md:text-5xl font-bold text-white mb-1">
                    <span class="text-xl md:text-2xl align-top">$</span>75
                  </div>
                  <p class="text-zinc-400 text-sm">per month</p>
                </div>
                <div class="order-3 md:order-none text-center flex flex-col items-center">
                  <a href="/pricing#hosting" class="inline-block px-8 py-3.5 bg-orange-700 text-white font-semibold rounded-full hover:bg-orange-600 transition-colors btn-glow text-sm md:text-base">
                    Get Started
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- We Handle the Server. You Get the Speed. -->
    <section class="max-w-7xl mx-auto pt-8 md:pt-12 pb-16 md:pb-24 px-6 md:px-8">
      <h2 class="text-2xl md:text-3xl font-bold mb-8 text-center" data-aos="fade-up">We Handle the Infrastructure. You Get the Speed.</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        <div class="group hover:scale-105 transition-transform" data-aos="fade-up" data-aos-delay="0">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Modern Cloud Hosting</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Your site runs on globally distributed cloud infrastructure, not a crowded shared server with hundreds of unrelated sites.</p>
        </div>
        <div class="group hover:scale-105 transition-transform" data-aos="fade-up" data-aos-delay="100">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Lightning-Fast Load Times</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Fast static architecture, global CDN delivery, and smart caching keep your pages loading quickly for visitors near and far.</p>
        </div>
        <div class="group hover:scale-105 transition-transform" data-aos="fade-up" data-aos-delay="200">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Proactive Monitoring</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">We monitor uptime and deploy health. When something looks off, we investigate and roll back or fix it, often before you notice.</p>
        </div>
      </div>
    </section>

    <!-- Spotlight: Built for Your Business -->
    <section class="max-w-7xl mx-auto py-16 md:py-24">
      <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
        <!-- Text Content (Left on desktop, bottom on mobile) -->
        <div class="w-full md:w-1/2 backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-2xl p-8 md:p-10" data-aos="fade-right">
          <div class="w-12 h-12 bg-white/5 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h2 class="text-3xl md:text-4xl font-bold mb-4 text-white">Built for Your Business</h2>
          <p class="text-zinc-400 mb-6 text-lg leading-relaxed">We use modern cloud infrastructure and manage it for you, so you get strong performance, security, and reliability without the hassle. Each site gets its own configured environment.</p>
          <ul class="space-y-3 text-zinc-300">
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Per-site configuration: CDN, cache headers, and security rules tuned for your build</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>HTTPS, edge protection, and uptime monitoring included</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Local support team that actually understands your business</span></li>
          </ul>
        </div>
        <!-- Mockup (Right on desktop, top on mobile) -->
        <SpotlightImage
          src="/images/unsplash/hosting-infrastructure.jpg"
          alt="Server cooling fans in a data center"
        />
      </div>
    </section>

    <!-- Security Spotlight -->
    <section class="max-w-7xl mx-auto py-16 md:py-24 bg-zinc-900/30 border-y border-white/5">
      <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
        <!-- Mockup (Left on desktop, top on mobile) -->
        <SpotlightImage
          src="/images/unsplash/hosting-security.jpg"
          alt="Padlock on a keyboard representing website security"
        />
        <!-- Text Content (Right on desktop, bottom on mobile) -->
        <div class="w-full md:w-1/2 backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-2xl p-8 md:p-10 order-2 md:order-2" data-aos="fade-right">
          <div class="w-12 h-12 bg-white/5 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <h2 class="text-3xl md:text-4xl font-bold mb-4 text-white">Enterprise-Grade Security</h2>
          <p class="text-zinc-400 mb-6 text-lg leading-relaxed">Your site&apos;s security is built in from the start. We manage SSL, DNS, and infrastructure so you don&apos;t have to worry about the technical side.</p>
          <ul class="space-y-3 text-zinc-300">
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>HTTPS enforced site-wide with automatic certificate renewal</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Edge-level DDoS protection and traffic filtering</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Deploy rollback so you can recover quickly if something goes wrong</span></li>
          </ul>
        </div>
      </div>
    </section>

    <!-- What's Included -->
    <section class="max-w-7xl mx-auto py-16 md:py-24 px-6 md:px-8">
      <h2 class="text-2xl md:text-3xl font-bold mb-8 text-center" data-aos="fade-up">What's Included</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        <div class="backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-xl p-6 hover:bg-white/10 hover:border-white/20 transition-all" data-aos="fade-up" data-aos-delay="0">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Deploy Rollback</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Every publish is saved. Roll back to a previous version instantly if an update causes trouble.</p>
        </div>
        <div class="backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-xl p-6 hover:bg-white/10 hover:border-white/20 transition-all" data-aos="fade-up" data-aos-delay="100">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">SSL Certificates</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Free SSL certificates with automatic renewal to keep your site secure.</p>
        </div>
        <div class="backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-xl p-6 hover:bg-white/10 hover:border-white/20 transition-all" data-aos="fade-up" data-aos-delay="200">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Performance &amp; Caching</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Global CDN delivery, edge caching, and optimized cache headers for fast page loads.</p>
        </div>
        <div class="backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-xl p-6 hover:bg-white/10 hover:border-white/20 transition-all" data-aos="fade-up" data-aos-delay="300">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Edge Security</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">DDoS mitigation and HTTPS enforced across your entire site.</p>
        </div>
        <div class="backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-xl p-6 hover:bg-white/10 hover:border-white/20 transition-all" data-aos="fade-up" data-aos-delay="400">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Uptime Monitoring</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">We monitor whether your site is up and respond quickly if it goes down.</p>
        </div>
        <div class="backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-xl p-6 hover:bg-white/10 hover:border-white/20 transition-all" data-aos="fade-up" data-aos-delay="500">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Expert Support</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Direct access to our team in Lake Forest. No ticket queues or chatbots.</p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="max-w-7xl mx-auto py-16 md:py-24 px-6 md:px-8 bg-zinc-900/30 border-y border-white/5">
      <h2 class="text-2xl md:text-3xl font-bold mb-8 text-center" data-aos="fade-up" data-aos-offset="320">Common Questions</h2>
      <div class="max-w-3xl mx-auto space-y-4">
        <div class="faq-item backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-xl overflow-hidden transition-all" data-aos="fade-up" data-aos-offset="320">
          <button class="faq-question w-full text-left p-6 flex items-center justify-between hover:bg-white/10 transition-colors" aria-expanded="false">
            <h3 class="font-bold text-white pr-4">What kind of infrastructure do you use?</h3>
            <svg class="w-5 h-5 text-orange-500 flex-shrink-0 faq-icon transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="faq-answer overflow-hidden transition-all duration-300">
            <div class="px-6 pb-6 pt-0 border-t border-white/5">
