---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout 
  title="Checkout | OCWebPros" 
  description="Complete your order for web design, SEO, hosting, or support services. Secure checkout powered by Stripe."
  bodyClass="page-checkout">

  <header class="relative pt-32 sm:pt-32 md:pt-40 pb-12 sm:pb-16 px-4 sm:px-6 text-center overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90vw] max-w-[800px] h-[400px] sm:h-[500px] md:h-[600px] glow-bg pointer-events-none opacity-40"></div>
    <div class="max-w-5xl mx-auto relative">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-orange-400 mb-6">
        <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
        Checkout
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4">
        Review your <span class="text-gradient-orange">order</span>
      </h1>
      <p class="text-zinc-400 text-lg leading-relaxed">
        Confirm your selections and proceed to secure payment.
      </p>
    </div>
  </header>

  <main class="pb-24 px-6 md:px-8">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Order Summary -->
        <div class="backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-2xl p-8 h-fit">
          <h2 class="text-2xl font-bold text-white mb-6">Order Summary</h2>
          
          <div id="checkoutItems" class="space-y-4 mb-6">
            <!-- Cart items will be injected here -->
          </div>

          <div id="checkoutTotals" class="border-t border-white/10 pt-4 space-y-2">
            <!-- Totals will be injected here -->
          </div>
        </div>

        <!-- Customer Information -->
        <div class="backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-2xl p-8">
          <h2 class="text-2xl font-bold text-white mb-6">Your Information</h2>
          
          <form id="checkoutForm" class="space-y-4">
            <div>
              <label for="customerName" class="block text-sm font-medium text-zinc-300 mb-2">Full Name *</label>
              <input type="text" id="customerName" name="customerName" required 
                class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent" 
                placeholder="John Doe">
            </div>

            <div>
              <label for="customerEmail" class="block text-sm font-medium text-zinc-300 mb-2">Email *</label>
              <input type="email" id="customerEmail" name="customerEmail" required 
                class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent" 
                placeholder="john@example.com">
            </div>

            <div>
              <label for="customerPhone" class="block text-sm font-medium text-zinc-300 mb-2">Phone *</label>
              <input type="tel" id="customerPhone" name="customerPhone" required 
                class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent" 
                placeholder="(949) 329-4437">
            </div>

            <div>
              <label for="businessName" class="block text-sm font-medium text-zinc-300 mb-2">Business Name</label>
              <input type="text" id="businessName" name="businessName" 
                class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent" 
                placeholder="Your Business LLC">
            </div>

            <button type="submit" id="proceedToPaymentBtn" 
              class="w-full px-8 py-4 bg-orange-600 text-white font-bold rounded-full hover:bg-orange-500 transition-colors btn-glow mt-6">
              Proceed to Payment
            </button>

            <p class="text-xs text-zinc-500 text-center mt-4">
              Secure checkout powered by Stripe. Your payment information is encrypted and never stored on our servers.
            </p>
          </form>
        </div>
      </div>

      <!-- Back to Pricing -->
      <div class="text-center mt-8">
        <a href="/pricing" class="text-zinc-400 hover:text-white transition-colors text-sm">
          ← Back to pricing
        </a>
      </div>
    </div>
  </main>

  <script is:inline>
    (function() {
      function runCheckout() {
        if (!window.cart) {
          console.error('Cart not initialized');
          window.location.href = '/pricing';
          return;
        }

        const items = window.cart.getItems();
        const totals = window.cart.getTotals();

        // Redirect if cart is empty
        if (items.length === 0) {
          window.location.href = '/pricing';
          return;
        }

        // Render cart items
      const checkoutItems = document.getElementById('checkoutItems');
      checkoutItems.innerHTML = items.map(item => `
        <div class="flex justify-between items-start py-3 border-b border-white/5 last:border-0">
          <div class="flex-1">
            <h3 class="font-semibold text-white text-sm mb-1">${item.name}</h3>
            <p class="text-xs text-zinc-400">
              ${item.type === 'one-time' ? 'One-time payment' : 'Monthly subscription'}
            </p>
          </div>
          <p class="font-bold text-orange-400 text-sm">
            $${item.price.toLocaleString()}${item.type === 'subscription' ? '/mo' : ''}
          </p>
        </div>
      `).join('');

      // Render totals
      let totalsHTML = '';
      
      if (totals.oneTime > 0) {
        totalsHTML += `
          <div class="flex justify-between">
            <span class="text-zinc-400">One-time total:</span>
            <span class="text-white font-bold text-lg">$${totals.oneTime.toLocaleString()}</span>
          </div>
        `;
      }

      if (totals.monthly > 0) {
        totalsHTML += `
          <div class="flex justify-between">
            <span class="text-zinc-400">Monthly total:</span>
            <span class="text-white font-bold text-lg">$${totals.monthly.toLocaleString()}/mo</span>
          </div>
        `;
      }

      if (totals.hostingIncluded) {
        totalsHTML += `
          <div class="flex items-center gap-2 py-2 px-3 bg-emerald-500/10 border border-emerald-500/20 rounded-lg mt-2">
            <svg class="w-4 h-4 text-emerald-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span class="text-xs text-emerald-300 font-medium">FREE Managed Hosting ($75/mo value)</span>
          </div>
        `;
      }

      document.getElementById('checkoutTotals').innerHTML = totalsHTML;

      // Handle form submission
      document.getElementById('checkoutForm').addEventListener('submit', async function(e) {
        e.preventDefault();

        const btn = document.getElementById('proceedToPaymentBtn');
        const originalText = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = 'Processing...';

        try {
          const formData = new FormData(e.target);
          const customerInfo = {
            name: formData.get('customerName'),
            email: formData.get('customerEmail'),
            phone: formData.get('customerPhone'),
            businessName: formData.get('businessName')
          };

          // Call API to create Stripe checkout session
          const response = await fetch('/api/create-checkout-session', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              items: window.cart.getCheckoutData(),
              customer: customerInfo
            })
          });

          const data = await response.json();

          if (data.error) {
            throw new Error(data.error);
          }

          // Redirect to Stripe Checkout
          if (data.url) {
            window.location.href = data.url;
          } else {
            throw new Error('No checkout URL received');
          }

        } catch (error) {
          console.error('Checkout error:', error);
          alert('There was an error processing your checkout. Please try again or contact us directly.');
          btn.disabled = false;
          btn.innerHTML = originalText;
        }
      });
      }

      // Cart is loaded by layout script after this page's content; wait for it before running
      function whenCartReady() {
        if (window.cart) {
          runCheckout();
          return;
        }
        var attempts = 0;
        var t = setInterval(function() {
          attempts++;
          if (window.cart) {
            clearInterval(t);
            runCheckout();
          } else if (attempts > 40) {
            clearInterval(t);
            window.location.href = '/pricing';
          }
        }, 50);
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', whenCartReady);
      } else {
        whenCartReady();
      }
    })();
  </script>
</MainLayout>
