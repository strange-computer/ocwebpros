---
import MainLayout from '../../layouts/MainLayout.astro';

// Get all blog posts
const allPosts = await Astro.glob('./*.md');
const posts = allPosts
  .filter(post => !post.url?.includes('index') && !post.url?.includes('README'))
  .sort((a, b) => {
    const dateA = new Date(a.frontmatter.pubDate || 0);
    const dateB = new Date(b.frontmatter.pubDate || 0);
    return dateB.getTime() - dateA.getTime();
  });
---
<MainLayout 
  title="Blog | OCWebPros" 
  description="Web design tips, local SEO strategies, and digital marketing insights for Orange County businesses. Expert advice from the OCWebPros team."
  bodyClass="page-blog"
  pageCSS="/css/pages/blog.css">

  <!-- Hero -->
  <header class="relative pt-32 sm:pt-32 md:pt-40 pb-12 sm:pb-16 px-4 sm:px-6 text-center overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90vw] max-w-[800px] h-[400px] sm:h-[500px] md:h-[600px] glow-bg pointer-events-none opacity-40"></div>
    <div class="max-w-5xl mx-auto relative">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-orange-400 mb-6">
        <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
        Blog
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4">
        Insights & <span class="text-gradient-orange">Resources</span>
      </h1>
      <p class="text-zinc-400 text-lg leading-relaxed">
        Web design tips, SEO strategies, and practical advice for growing your business online.
      </p>
    </div>
  </header>

  <main class="pb-24 px-6 md:px-8">
    <div class="max-w-7xl mx-auto">
      {posts.length === 0 ? (
        <!-- Empty state -->
        <div class="max-w-2xl mx-auto text-center py-16">
          <div class="backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-2xl p-12">
            <svg class="w-16 h-16 text-zinc-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
            <h2 class="text-2xl font-bold text-white mb-3">Coming Soon</h2>
            <p class="text-zinc-400">We're working on valuable content for local businesses. Check back soon for web design tips and SEO strategies.</p>
          </div>
        </div>
      ) : (
        <!-- Blog posts grid -->
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((post) => (
            <article class="framer-card p-6 rounded-2xl group cursor-pointer" data-aos="fade-up">
              <a href={post.url} class="block">
                {post.frontmatter.image && (
                  <div class="relative h-48 rounded-xl border border-white/10 mb-4 overflow-hidden">
                    <img 
                      src={post.frontmatter.image} 
                      alt={post.frontmatter.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    />
                  </div>
                )}
                
                <div class="flex items-center gap-3 mb-3">
                  {post.frontmatter.category && (
                    <span class="px-2 py-1 text-xs rounded-full bg-orange-500/10 border border-orange-500/30 text-orange-400">
                      {post.frontmatter.category}
                    </span>
                  )}
                  {post.frontmatter.pubDate && (
                    <time class="text-xs text-zinc-400">
                      {new Date(post.frontmatter.pubDate).toLocaleDateString('en-US', { 
                        year: 'numeric', 
                        month: 'short', 
                        day: 'numeric' 
                      })}
                    </time>
                  )}
                </div>

                <h2 class="text-xl font-bold text-white mb-2 group-hover:text-orange-400 transition-colors">
                  {post.frontmatter.title}
                </h2>
                
                {post.frontmatter.description && (
                  <p class="text-sm text-zinc-400 mb-4 leading-relaxed">
                    {post.frontmatter.description}
                  </p>
                )}

                <div class="flex items-center gap-2 text-orange-400 text-sm font-medium group-hover:gap-3 transition-all">
                  Read article
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </div>
              </a>
            </article>
          ))}
        </div>
      )}
    </div>

    <!-- CTA -->
    <section class="text-center py-16 md:py-24 px-6 md:px-8 mt-12" data-aos="fade-up">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Need help with your website?</h2>
        <p class="text-zinc-400 mb-8">Let's discuss how we can help your business grow online.</p>
        <div class="inline-flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="px-10 py-5 bg-orange-700 text-white font-bold rounded-full hover:bg-orange-600 transition-colors text-lg btn-glow">
            Get in touch
          </a>
          <a href="/services" class="px-10 py-5 bg-white/5 text-white font-bold rounded-full border border-white/10 hover:bg-white/10 transition-colors text-lg">
            Our services
          </a>
        </div>
      </div>
    </section>
  </main>
</MainLayout>
