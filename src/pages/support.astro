    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const faqItems = document.querySelectorAll('.faq-item');
        
        faqItems.forEach(item => {
          const button = item.querySelector('.faq-question');
          const answer = item.querySelector('.faq-answer');
          const icon = item.querySelector('.faq-icon');
          const answerContent = answer.querySelector('div');
          
          // Initially hide all answers
          answer.style.maxHeight = '0';
          
          button.addEventListener('click', () => {
            const isExpanded = button.getAttribute('aria-expanded') === 'true';
            
            // Close all other items
            faqItems.forEach(otherItem => {
              if (otherItem !== item) {
                const otherButton = otherItem.querySelector('.faq-question');
                const otherAnswer = otherItem.querySelector('.faq-answer');
                const otherIcon = otherItem.querySelector('.faq-icon');
                
                otherButton.setAttribute('aria-expanded', 'false');
                otherAnswer.style.maxHeight = '0';
                otherIcon.style.transform = 'rotate(0deg)';
                otherItem.classList.remove('border-orange-500/30');
              }
            });
            
            // Toggle current item
            if (isExpanded) {
              button.setAttribute('aria-expanded', 'false');
              answer.style.maxHeight = '0';
              icon.style.transform = 'rotate(0deg)';
              item.classList.remove('border-orange-500/30');
            } else {
              button.setAttribute('aria-expanded', 'true');
              answer.style.maxHeight = answerContent.scrollHeight + 'px';
              icon.style.transform = 'rotate(180deg)';
              item.classList.add('border-orange-500/30');
            }
          });
        });
      });
    </script>

