---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout 
  title="Web Support | OCWebPros" 
  description="WordPress and website support from $50/mo. Plugin updates, content edits, security patches, and priority response. Local team in Lake Forest, CA."
  bodyClass="page-support"
  pageCSS="/css/pages/support.css">

  <!-- Hero -->
  <header class="relative pt-32 sm:pt-32 md:pt-40 pb-12 sm:pb-16 px-4 sm:px-6 text-center overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90vw] max-w-[800px] h-[400px] sm:h-[500px] md:h-[600px] glow-bg pointer-events-none opacity-40"></div>
    <div class="max-w-5xl mx-auto relative">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-orange-400 mb-6">
        <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
        Web Support
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4">
        Web Support <span class="text-gradient-orange">That Actually Helps</span>
      </h1>
      <p class="text-zinc-400 text-lg leading-relaxed">
        When your site breaks or needs updates, you need real help - fast. Our local web experts fix issues, make updates, and keep your site running smoothly.
      </p>
    </div>
  </header>

  <main class="pb-24 px-6 md:px-8">
    <!-- What We Handle -->
    <section class="max-w-7xl mx-auto pt-8 md:pt-12 pb-16 md:pb-24 px-6 md:px-8">
      <h2 class="text-2xl md:text-3xl font-bold mb-8 text-center" data-aos="fade-up">What We Handle</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        <div class="group hover:scale-105 transition-transform" data-aos="fade-up" data-aos-delay="0">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Problem Resolution</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">When things break, we fix them. Layout issues, error messages, plugin conflicts, and performance problems - we diagnose and solve them correctly the first time.</p>
        </div>
        <div class="group hover:scale-105 transition-transform" data-aos="fade-up" data-aos-delay="100">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Site Updates & Refinements</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Keep your content fresh and your design current. We handle text changes, image updates, layout adjustments, and accessibility improvements.</p>
        </div>
        <div class="group hover:scale-105 transition-transform" data-aos="fade-up" data-aos-delay="200">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Functionality & Integrations</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Add new capabilities or improve existing ones. Contact forms, payment systems, third-party integrations, and custom features - we build them right.</p>
        </div>
      </div>
    </section>

    <!-- Support Pricing Tiers -->
    <section class="max-w-7xl mx-auto pt-4 md:pt-8 pb-12 md:pb-16 px-4 sm:px-6">
      <div class="relative text-center mb-8" data-aos="fade-up">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-72 h-48 md:w-96 md:h-56 bg-gradient-to-tr from-orange-500/15 to-purple-500/15 blur-3xl rounded-full pointer-events-none" aria-hidden="true"></div>
        <div class="relative">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-orange-400 mb-4">
            <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
            Support Plans
          </div>
          <h2 class="text-2xl md:text-3xl font-bold mb-2 text-white">Choose your plan</h2>
          <p class="text-zinc-400 text-sm md:text-base">Monthly plans to fit your business needs</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-6xl mx-auto">
        <!-- Tier 1: The "Technical" Plan -->
        <div class="support-pricing-card backdrop-blur-[12px] border border-white/10 rounded-2xl p-6 md:p-8 overflow-hidden relative flex flex-col transition-all duration-300 ease-out" style="background: rgba(24, 24, 27, 0.6);">
          <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 via-transparent to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 bg-gradient-to-tl from-purple-500/5 via-transparent to-transparent pointer-events-none"></div>
          <div class="relative flex flex-col flex-1">
            <div class="mb-6">
              <h3 class="text-xl font-bold text-white mb-2">The &quot;Technical&quot; Plan</h3>
              <div class="text-4xl font-bold text-white mb-1">
                <span class="text-lg align-top">$</span>50
              </div>
              <p class="text-zinc-400 text-sm">per month</p>
              <p class="text-zinc-400 text-sm mt-2">For businesses that just want technical security.</p>
            </div>
            <ul class="space-y-2 mb-6 flex-1">
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-zinc-300">Weekly Plugin Updates: We manually update plugins to prevent security holes.</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-zinc-300">Visual Regression Testing: We check to make sure an update didn&apos;t break your design.</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-zinc-300">Database Optimization: Keeping the site fast.</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-zinc-300">Monthly PDF Report: Proof that we are working.</span>
              </li>
            </ul>
            <a href="/pricing" class="block w-full px-6 py-3 bg-white/5 text-white font-semibold rounded-full text-center border border-white/10 hover:bg-white/10 transition-colors text-sm mt-auto">Get Started</a>
          </div>
        </div>

        <!-- Tier 2: The "Content" Plan (Recommended) -->
        <div class="support-pricing-card backdrop-blur-[12px] border-2 border-orange-500/50 rounded-2xl p-6 md:p-8 overflow-hidden relative flex flex-col transition-all duration-300 ease-out" style="background: rgba(24, 24, 27, 0.6);">
          <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 via-transparent to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 bg-gradient-to-tl from-purple-500/5 via-transparent to-transparent pointer-events-none"></div>
          <div class="absolute top-4 right-4">
            <span class="px-2 py-1 bg-orange-500 text-white text-xs font-semibold rounded-full">Recommended</span>
          </div>
          <div class="relative flex flex-col flex-1">
            <div class="mb-6">
              <h3 class="text-xl font-bold text-white mb-2">The &quot;Content&quot; Plan</h3>
              <div class="text-4xl font-bold text-white mb-1">
                <span class="text-lg align-top">$</span>125
              </div>
              <p class="text-zinc-400 text-sm">per month</p>
              <p class="text-zinc-400 text-sm mt-2">For businesses that need regular website updates.</p>
            </div>
            <ul class="space-y-2 mb-6 flex-1">
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg transition-all duration-200 ease-out hover:-translate-y-0.5" style="background-color: rgba(180, 80, 200, 0.15); border: 1px solid rgba(180, 80, 200, 0.3);">
                <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: #B450C8;">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm font-semibold" style="color: #B450C8;">Everything in Technical, PLUS:</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-zinc-300">1 Hour of Content Edits: Send us your text/image changes, and we do them for you.</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-zinc-300">Priority Support: You skip the line. 24-hour turnaround guarantee.</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-zinc-300">Performance Audits: Quarterly checkups to ensure Google still loves your speed.</span>
              </li>
            </ul>
            <a href="/pricing" class="block w-full px-6 py-3 bg-orange-700 text-white font-semibold rounded-full text-center hover:bg-orange-600 transition-colors btn-glow text-sm mt-auto">Get Started</a>
          </div>
        </div>

        <!-- Tier 3: The "VIP" Plan -->
        <div class="support-pricing-card backdrop-blur-[12px] border border-white/10 rounded-2xl p-6 md:p-8 overflow-hidden relative flex flex-col transition-all duration-300 ease-out" style="background: rgba(24, 24, 27, 0.6);">
          <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 via-transparent to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 bg-gradient-to-tl from-purple-500/5 via-transparent to-transparent pointer-events-none"></div>
          <div class="relative flex flex-col flex-1">
            <div class="mb-6">
              <h3 class="text-xl font-bold text-white mb-2">The &quot;VIP&quot; Plan</h3>
              <div class="text-4xl font-bold text-white mb-1">
                <span class="text-lg align-top">$</span>250
              </div>
              <p class="text-zinc-400 text-sm">per month</p>
              <p class="text-zinc-400 text-sm mt-2">For high-traffic sites or businesses that need maximum support.</p>
            </div>
            <ul class="space-y-2 mb-6 flex-1">
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg transition-all duration-200 ease-out hover:-translate-y-0.5" style="background-color: rgba(180, 80, 200, 0.15); border: 1px solid rgba(180, 80, 200, 0.3);">
                <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: #B450C8;">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm font-semibold" style="color: #B450C8;">Everything in Content, PLUS:</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-zinc-300">2 Hours of Content Edits: Text, images, and small changes when you need them.</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-sm text-zinc-300">Emergency Response: Immediate top priority for downtime, bugs, and urgent site issues.</span>
              </li>
            </ul>
            <a href="/pricing" class="block w-full px-6 py-3 bg-white/5 text-white font-semibold rounded-full text-center border border-white/10 hover:bg-white/10 transition-colors text-sm mt-auto">Get Started</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Spotlight: Website Expertise -->
    <section class="max-w-7xl mx-auto py-16 md:py-24">
      <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
        <!-- Text Content (Left on desktop, bottom on mobile) -->
        <div class="w-full md:w-1/2 backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-2xl p-8 md:p-10" data-aos="fade-right">
          <div class="w-12 h-12 bg-white/5 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
          </div>
          <h2 class="text-3xl md:text-4xl font-bold mb-4 text-white">Website Specialists</h2>
          <p class="text-zinc-400 mb-6 text-lg leading-relaxed">Whether your site runs on WordPress, a static generator, or a custom stack - we know how to keep it running. We handle updates, performance, and fixes so you get specialists who understand your setup, not generic support.</p>
          <ul class="space-y-3 text-zinc-300">
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Deep knowledge of modern CMS, themes, and site architecture</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Proactive maintenance to prevent issues before they happen</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Conflict resolution that keeps your site stable and fast</span></li>
          </ul>
        </div>
        <!-- Mockup (Right on desktop, top on mobile) -->
        <div class="w-full md:w-1/2 h-96 md:h-[500px] border border-white/10 rounded-xl overflow-hidden" data-aos="fade-left">
          <img
            src="/images/WallofCodeBlock.png"
            alt="Website Support Dashboard Mockup"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </section>

    <!-- Spotlight: Direct Access to Experts -->
    <section class="max-w-7xl mx-auto py-16 md:py-24 bg-zinc-900/30 border-y border-white/5">
      <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
        <!-- Mockup (Left on desktop, top on mobile) -->
        <div class="w-full md:w-1/2 h-96 md:h-[500px] border border-white/10 rounded-xl overflow-hidden order-1 md:order-1" data-aos="fade-left">
          <img
            src="/images/expert.png"
            alt="Direct Access to Experts"
            class="w-full h-full object-cover"
          />
        </div>
        <!-- Text Content (Right on desktop, bottom on mobile) -->
        <div class="w-full md:w-1/2 backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-2xl p-8 md:p-10 order-2 md:order-2" data-aos="fade-right">
          <div class="w-12 h-12 bg-white/5 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          </div>
          <h2 class="text-3xl md:text-4xl font-bold mb-4 text-white">Direct Access to Experts</h2>
          <p class="text-zinc-400 mb-6 text-lg leading-relaxed">Skip the ticket queues and automated responses. When you contact us, you're talking directly to the technicians who will fix your site. No middlemen, no runaround - just clear communication and fast solutions.</p>
          <ul class="space-y-3 text-zinc-300">
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Same-day response times for urgent issues</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Direct communication with the person working on your site</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Local team in Lake Forest - we understand your business context</span></li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Response Times & Process -->
    <section class="max-w-7xl mx-auto py-16 md:py-24 px-6 md:px-8">
      <h2 class="text-2xl md:text-3xl font-bold mb-8 text-center" data-aos="fade-up">How We Work</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        <div class="backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-xl p-6 hover:bg-white/10 hover:border-white/20 transition-all" data-aos="fade-up" data-aos-delay="0">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Quick Response</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Urgent issues get same-day attention. Routine requests are handled within 24-48 hours. We don't make you wait.</p>
        </div>
        <div class="backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-xl p-6 hover:bg-white/10 hover:border-white/20 transition-all" data-aos="fade-up" data-aos-delay="100">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
