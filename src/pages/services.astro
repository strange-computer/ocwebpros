---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Services | Lake Forest Websites" bodyClass="page-services">
  <link rel="stylesheet" href="/css/pages/services.css" />

  <header class="relative pt-32 sm:pt-32 md:pt-40 pb-12 sm:pb-16 px-4 sm:px-6 text-center overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90vw] max-w-[800px] h-[400px] sm:h-[500px] md:h-[600px] glow-bg pointer-events-none opacity-40"></div>
    <div class="max-w-5xl mx-auto relative">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-orange-400 mb-6">
        <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
        Services
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4">
        Web Design & <span class="text-gradient-orange">Local SEO</span>
      </h1>
      <p class="text-zinc-400 text-lg leading-relaxed">
        Modern, fast websites and search visibility—built for real‑world outcomes, not trends.
      </p>
    </div>
  </header>

  <main class="pb-16 sm:pb-24 px-4 sm:px-6 md:px-8">
    <!-- Web Design Spotlight Section -->
    <section class="max-w-7xl mx-auto pt-8 md:pt-12 pb-16 md:pb-24 px-4 sm:px-6">
      <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
        <!-- Text Content (Left on desktop, bottom on mobile) -->
        <div class="w-full md:w-1/2 backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-2xl p-6 sm:p-8 md:p-10" data-aos="fade-right">
          <div class="w-12 h-12 bg-white/5 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7h18M3 12h18M3 17h18"/></svg>
          </div>
          <h2 class="text-3xl md:text-4xl font-bold mb-4 text-white">Web Design</h2>
          <p class="text-zinc-400 mb-6 text-lg leading-relaxed">Fast-loading, mobile-optimized pages crafted around your content strategy and business objectives—designed for longevity and straightforward management.</p>
          <ul class="space-y-3 text-zinc-300">
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Custom, component‑based UI built without bloated templates</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Responsive layouts that look great on phones, tablets, and desktops</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Accessible markup and performance‑minded best practices</span></li>
          </ul>
        </div>
        <!-- Mockup Image (Right on desktop, top on mobile) -->
        <div class="w-full md:w-1/2 h-64 sm:h-80 md:h-[500px] border border-white/10 rounded-xl overflow-hidden" data-aos="fade-left">
          <img src="/images/web-design-mockup.png" alt="Web Design Portfolio Mockup" class="w-full h-full object-cover" />
        </div>
      </div>
    </section>

    <!-- Web Design Pricing Box -->
    <section class="max-w-7xl mx-auto pt-4 md:pt-8 pb-12 md:pb-16 px-4 sm:px-6">
      <div class="max-w-5xl mx-auto relative" data-aos="fade-up">
        <!-- Glow orb behind card -->
        <div class="absolute -top-12 -left-12 w-64 h-64 md:w-80 md:h-80 bg-gradient-to-tr from-orange-500/20 to-purple-500/20 blur-3xl rounded-full pointer-events-none" aria-hidden="true"></div>
        <div class="web-design-pricing-card relative backdrop-blur-[12px] border border-white/10 rounded-2xl p-8 md:p-10 overflow-hidden transition-all duration-300 ease-out shadow-[0_10px_40px_-10px_rgba(0,0,0,0.5)]" style="background: rgba(24, 24, 27, 0.6);">
          <!-- Stronger gradient overlays -->
          <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 via-transparent to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 bg-gradient-to-tl from-purple-500/5 via-transparent to-transparent pointer-events-none"></div>
          
          <div class="relative">
            <!-- Mobile only: badge + headline at top -->
            <div class="text-center mb-4 md:hidden">
              <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-orange-400 mb-4">
                <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
                Web Design Pricing
              </div>
              <h2 class="text-2xl md:text-4xl font-bold mb-2 text-white tracking-tight">One Project,<br /><span class="text-gradient-orange">Endless Possibilities</span></h2>
            </div>

            <!-- Mobile: badge/headline (top) → price → features → CTA. Desktop: left = badge+headline+features, right = price+CTA -->
            <div class="flex flex-col md:grid gap-6 md:grid-cols-[1fr_auto] md:items-stretch">
              <!-- Left column: badge + headline (desktop only) + features -->
              <div class="order-2 md:order-1 md:col-start-1 md:row-start-1 md:pr-8 min-w-0">
                <div class="hidden md:block text-center mb-4">
                  <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-orange-400 mb-4">
                    <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
                    Web Design Pricing
                  </div>
                  <h2 class="text-2xl md:text-4xl font-bold mb-2 text-white tracking-tight">One Project,<br /><span class="text-gradient-orange">Endless Possibilities</span></h2>
                </div>
                <ul class="grid grid-cols-2 md:grid-cols-3 gap-2 md:gap-2">
                  <li class="flex items-center gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                    <svg class="w-5 h-5 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span class="text-sm text-zinc-300">Custom design</span>
                  </li>
                  <li class="flex items-center gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                    <svg class="w-5 h-5 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span class="text-sm text-zinc-300">Fully responsive</span>
                  </li>
                  <li class="flex items-center gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                    <svg class="w-5 h-5 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span class="text-sm text-zinc-300">Up to 5 pages</span>
                  </li>
                  <li class="flex items-center gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                    <svg class="w-5 h-5 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span class="text-sm text-zinc-300">SEO foundations</span>
                  </li>
                  <li class="flex items-center gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                    <svg class="w-5 h-5 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span class="text-sm text-zinc-300">CMS included</span>
                  </li>
                  <li class="flex items-center gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                    <svg class="w-5 h-5 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span class="text-sm text-zinc-300">2 revisions</span>
                  </li>
                </ul>
              </div>

              <!-- Right column: price + CTA in one block (single cell on desktop, display:contents on mobile for order) -->
              <div class="contents md:flex md:flex-col md:gap-4 md:pl-8 md:border-l md:border-white/10 md:col-start-2 md:row-start-1 md:justify-center">
                <!-- Price (mobile order 1) -->
                <div class="order-1 md:order-none text-center flex flex-col items-center">
                  <div class="text-4xl md:text-5xl font-bold text-white mb-1">
                    <span class="text-xl md:text-2xl align-top">$</span>4,995
                  </div>
                  <p class="text-zinc-400 text-sm">one-time project fee</p>
                </div>
                <!-- CTA (mobile order 3) -->
                <div class="order-3 md:order-none text-center flex flex-col items-center">
                  <a href="/contact" class="inline-block px-8 py-3.5 bg-orange-600 text-white font-semibold rounded-full hover:bg-orange-500 transition-colors btn-glow text-sm md:text-base">
                    Get Started Today
                  </a>
                  <p class="text-xs text-zinc-400 mt-2 font-medium">Custom quotes available</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Web Design Features Grid -->
    <section class="max-w-7xl mx-auto pt-2 md:pt-4 pb-16 md:pb-24 px-4 sm:px-6 md:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        <div data-aos="fade-up" data-aos-delay="0">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Custom Design</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Your website should authentically represent your brand and objectives. We focus on content strategy and conversion optimization, not generic themes.</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="100">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h10"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Modern Features</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Animations, galleries, forms, and social—implemented lightly so pages stay fast.</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="200">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v12m6-6H6"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Built to Last</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Streamlined architecture, optimized performance, mobile-responsive. Simple to update and built to scale alongside your business.</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="300">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c1.657 0 3-1.567 3-3.5S13.657 4 12 4 9 5.567 9 7.5 10.343 11 12 11zm0 0v9m-7-5h14"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Performance & Security</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Best practices for speed and security baked in from day one.</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="400">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h10M4 18h6"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Scalable Architecture</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Flexible content structure so pages, sections, and features can be added later without a rebuild.</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="500">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Easy Content Management</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Update copy and images yourself, or lean on us—we keep things simple either way.</p>
        </div>
      </div>
    </section>

    <!-- Local SEO Spotlight Section -->
    <section class="max-w-7xl mx-auto py-16 md:py-24 px-4 sm:px-6">
      <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
        <!-- Mockup Image (Left on desktop, top on mobile) -->
        <div class="w-full md:w-1/2 h-64 sm:h-80 md:h-[500px] border border-white/10 rounded-xl overflow-hidden order-1 md:order-1" data-aos="fade-left">
          <img src="/images/local-seo-mockup.png" alt="Local SEO Dashboard Mockup" class="w-full h-full object-cover" />
        </div>
        <!-- Text Content (Right on desktop, bottom on mobile) -->
        <div class="w-full md:w-1/2 backdrop-blur-[12px] bg-white/5 border border-white/10 rounded-2xl p-6 sm:p-8 md:p-10 order-2 md:order-2" data-aos="fade-right">
          <div class="w-12 h-12 bg-white/5 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 17l-5-5m0 0l5-5m-5 5h12"/></svg>
          </div>
          <h2 class="text-3xl md:text-4xl font-bold mb-4 text-white">Local SEO</h2>
          <p class="text-zinc-400 mb-6 text-lg leading-relaxed">Make it easy for nearby customers to find and contact you across Google and maps results.</p>
          <ul class="space-y-3 text-zinc-300">
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>On‑page basics: titles, meta, headings, internal links</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Google Business Profile setup and optimization</span></li>
            <li class="flex items-start gap-3"><span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span><span>Local content guidance and simple schema where useful</span></li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Local SEO Pricing Tiers -->
    <section class="max-w-7xl mx-auto pt-4 md:pt-8 pb-12 md:pb-16 px-4 sm:px-6">
      <div class="relative text-center mb-8" data-aos="fade-up">
        <!-- Subtle glow behind header -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-72 h-48 md:w-96 md:h-56 bg-gradient-to-tr from-orange-500/15 to-purple-500/15 blur-3xl rounded-full pointer-events-none" aria-hidden="true"></div>
        <div class="relative">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-orange-400 mb-4">
            <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
            Local SEO Pricing
          </div>
          <h2 class="text-2xl md:text-3xl font-bold mb-2 text-white">Choose your plan</h2>
          <p class="text-zinc-400 text-sm md:text-base">Monthly packages to fit your business needs</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-6xl mx-auto" data-aos="fade-up">
        <!-- Starter Tier -->
        <div class="local-seo-pricing-card backdrop-blur-[12px] border border-white/10 rounded-2xl p-6 md:p-8 overflow-hidden relative flex flex-col transition-all duration-300 ease-out" style="background: rgba(24, 24, 27, 0.6);">
          <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 via-transparent to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 bg-gradient-to-tl from-purple-500/5 via-transparent to-transparent pointer-events-none"></div>
          <div class="relative flex flex-col flex-1">
            <div class="mb-6">
              <h3 class="text-xl font-bold text-white mb-2">Starter</h3>
              <div class="text-4xl font-bold text-white mb-1">
                <span class="text-lg align-top">$</span>495
              </div>
              <p class="text-zinc-400 text-sm">per month</p>
            </div>
            <ul class="space-y-2 mb-6 flex-1">
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm text-zinc-300">Google Business Profile optimization</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm text-zinc-300">Basic on-page SEO</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm text-zinc-300">Monthly reporting</span>
              </li>
            </ul>
            <a href="/contact" class="block w-full px-6 py-3 bg-white/5 text-white font-semibold rounded-full text-center border border-white/10 hover:bg-white/10 transition-colors text-sm mt-auto">
              Get Started
            </a>
          </div>
        </div>

        <!-- Professional Tier (Featured) -->
        <div class="local-seo-pricing-card backdrop-blur-[12px] border-2 border-orange-500/50 rounded-2xl p-6 md:p-8 overflow-hidden relative flex flex-col transition-all duration-300 ease-out" style="background: rgba(24, 24, 27, 0.6);">
          <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 via-transparent to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 bg-gradient-to-tl from-purple-500/5 via-transparent to-transparent pointer-events-none"></div>
          <div class="absolute top-4 right-4">
            <span class="px-2 py-1 bg-orange-500 text-white text-xs font-semibold rounded-full">Popular</span>
          </div>
          <div class="relative flex flex-col flex-1">
            <div class="mb-6">
              <h3 class="text-xl font-bold text-white mb-2">Professional</h3>
              <div class="text-4xl font-bold text-white mb-1">
                <span class="text-lg align-top">$</span>995
              </div>
              <p class="text-zinc-400 text-sm">per month</p>
            </div>
            <ul class="space-y-2 mb-6 flex-1">
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm text-zinc-300">Everything in Starter</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm text-zinc-300">Advanced on-page optimization</span>
              </li>
              <li class="flex items-start gap-2.5 py-2 px-3 rounded-lg bg-white/[0.03] border border-white/5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-white/[0.06] hover:border-white/10">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm text-zinc-300">Content creation & optimization</span>
              </li>
