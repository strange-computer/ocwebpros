---
import MainLayout from '../layouts/MainLayout.astro';
import TerminalAnimation from '../components/TerminalAnimation.astro';
---
<MainLayout title="Lake Forest Websites | Modern Dark Design" bodyClass="page-home">
  <link rel="stylesheet" href="/css/pages/home.css" />

  <section class="relative min-h-[90vh] flex flex-col items-center justify-start text-center px-6 pt-32 pb-20 sm:pt-32 sm:pb-20 md:pt-40 md:pb-24 overflow-hidden">
    <!-- Hero background video -->
    <video
      class="absolute inset-0 -z-10 w-full h-full object-cover"
      src="/videos/backgroundvideo.mp4"
      autoplay
      muted
      loop
      playsinline
    ></video>
    <!-- Dark overlay + glow -->
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-black/95 via-black/85 to-black/95"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90vw] max-w-[800px] h-[400px] sm:h-[500px] md:h-[600px] glow-bg pointer-events-none opacity-50"></div>

    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-orange-400 mb-8 sm:mb-10 md:mb-8">
      <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
      Based in Lake Forest, CA
    </div>

    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-8xl font-bold tracking-tight mb-8 sm:mb-10 md:mb-10 max-w-5xl mx-auto px-4">
      Design for <span class="text-gradient-orange">Humans</span>.<br />
      Rank for <span class="text-gradient-orange">Machines</span>.
    </h1>

    <p class="text-base sm:text-lg md:text-xl text-zinc-400 max-w-2xl mx-auto mb-12 sm:mb-14 md:mb-14 leading-relaxed px-4">
      We build websites that rank and convert. Clean design, strategic SEO, and pages built for the way customers actually make decisions.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 sm:gap-4 w-full justify-center max-w-md sm:max-w-none px-4 mb-8 sm:mb-0">
      <a href="/contact" class="px-6 sm:px-8 py-3 sm:py-4 bg-orange-600 text-white font-semibold rounded-xl btn-glow hover:bg-orange-500 transition-colors text-sm sm:text-base text-center">
        Request Consultation
      </a>
      <a href="/portfolio" class="px-6 sm:px-8 py-3 sm:py-4 bg-white/5 text-white font-semibold rounded-xl border border-white/10 hover:bg-white/10 transition-colors text-sm sm:text-base text-center">
        View Our Work
      </a>
    </div>

    <div class="mt-12 sm:mt-16 md:mt-20 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 sm:gap-8 md:gap-16 border-t border-white/10 pt-8 sm:pt-10 px-4">
      <div data-aos="fade-up" data-aos-delay="100">
        <div class="text-2xl sm:text-3xl font-bold text-white mb-1">Custom Design</div>
        <div class="text-xs sm:text-sm text-zinc-500">Tailored to your brand and goals</div>
      </div>
      <div data-aos="fade-up" data-aos-delay="200">
        <div class="text-2xl sm:text-3xl font-bold text-white mb-1">Mobile‑first</div>
        <div class="text-xs sm:text-sm text-zinc-500">Looks great on every device</div>
      </div>
      <div class="col-span-1 sm:col-span-2 md:col-span-1" data-aos="fade-up" data-aos-delay="300">
        <div class="text-2xl sm:text-3xl font-bold text-white mb-1">Straightforward Pricing</div>
        <div class="text-xs sm:text-sm text-zinc-500">Clear scope, no surprises</div>
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-zinc-900/30 border-y border-white/5" data-aos="fade-up">
    <div class="max-w-7xl mx-auto">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">
            More Than a Website.<br />
            <span class="text-gradient-orange">A Team That Delivers.</span>
          </h2>
          <div class="space-y-8">
            <div class="flex gap-4">
              <div class="w-12 h-12 rounded-full bg-zinc-800 flex items-center justify-center flex-shrink-0 border border-white/10">
                <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"></path></svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold text-white mb-2">Custom, Purpose-Built Design</h3>
                <p class="text-zinc-400 leading-relaxed">Every site is built from scratch for your specific needs. No template bloat, no unnecessary features - just what works for your business.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-12 h-12 rounded-full bg-zinc-800 flex items-center justify-center flex-shrink-0 border border-white/10">
                <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold text-white mb-2">Direct Access to Your Team</h3>
                <p class="text-zinc-400 leading-relaxed">Skip the ticket queues. Work directly with the people who built your site, based right here in Lake Forest, CA.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="relative min-w-0">
          <div class="absolute inset-0 bg-gradient-to-tr from-orange-500/20 to-purple-500/20 blur-3xl rounded-full"></div>
          <div class="framer-card p-8 rounded-2xl relative z-10 min-w-0 overflow-visible">
            <div class="space-y-4">
              <TerminalAnimation />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mid-page CTA stripe -->
  <section class="px-4 sm:px-6 py-10 sm:py-12 border-t border-white/5 bg-gradient-to-r from-zinc-900/40 via-zinc-900/20 to-zinc-900/40" data-aos="fade-up">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <h3 class="text-2xl md:text-3xl font-bold">Let's make your website a growth asset.</h3>
        <p class="text-zinc-400 mt-2">Fast, clear, and built to last - without the bloat.</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto">
        <a href="/contact" class="px-6 py-3 bg-orange-600 text-white font-semibold rounded-full hover:bg-orange-500 transition-colors btn-glow text-center text-sm sm:text-base">Request consult</a>
        <a href="/portfolio" class="px-6 py-3 bg-white/5 text-white font-semibold rounded-full border border-white/10 hover:bg-white/10 transition-colors text-center text-sm sm:text-base">See examples</a>
      </div>
    </div>
  </section>

  <section class="py-32 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16" data-aos="fade-up">
        <h2 class="text-3xl md:text-5xl font-bold mb-4">What We Build</h2>
        <p class="text-zinc-400">Tailored solutions for every stage of your business.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="framer-card p-8 rounded-2xl group cursor-pointer" data-aos="fade-up" data-aos-delay="100">
          <div class="w-12 h-12 bg-white/5 rounded-xl flex items-center justify-center mb-6 group-hover:bg-orange-500/20 transition-colors">
            <svg class="w-6 h-6 text-white group-hover:text-orange-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Web Design</h3>
          <p class="text-sm text-zinc-400 mb-6 leading-relaxed">
            Custom websites built for local businesses. Fast, mobile-first, and designed to convert visitors into customers.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-2 py-1 text-xs bg-white/5 rounded text-zinc-300">Service Sites</span>
            <span class="px-2 py-1 text-xs bg-white/5 rounded text-zinc-300">Local Business</span>
          </div>
        </div>

        <div class="framer-card p-8 rounded-2xl group cursor-pointer" data-aos="fade-up" data-aos-delay="200">
          <div class="w-12 h-12 bg-white/5 rounded-xl flex items-center justify-center mb-6 group-hover:bg-orange-500/20 transition-colors">
            <svg class="w-6 h-6 text-white group-hover:text-orange-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Local SEO</h3>
          <p class="text-sm text-zinc-400 mb-6 leading-relaxed">
            Strategic optimization to help you rank in local search. Google Business, content strategy, and ongoing improvements.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-2 py-1 text-xs bg-white/5 rounded text-zinc-300">Google Business</span>
            <span class="px-2 py-1 text-xs bg-white/5 rounded text-zinc-300">Link Building</span>
          </div>
        </div>

        <div class="framer-card p-8 rounded-2xl group cursor-pointer" data-aos="fade-up" data-aos-delay="300">
          <div class="w-12 h-12 bg-white/5 rounded-xl flex items-center justify-center mb-6 group-hover:bg-orange-500/20 transition-colors">
            <svg class="w-6 h-6 text-white group-hover:text-orange-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"></path></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Hosting & Support</h3>
          <p class="text-sm text-zinc-400 mb-6 leading-relaxed">
            Managed hosting, security updates, and ongoing support. Content updates, backups, and priority response when you need it.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-2 py-1 text-xs bg-white/5 rounded text-zinc-300">Managed Hosting</span>
            <span class="px-2 py-1 text-xs bg-white/5 rounded text-zinc-300">Content Updates</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <!-- Logos/social proof (moved near testimonials) -->
  <section class="px-6 py-10 border-t border-white/5">
    <div class="max-w-7xl mx-auto flex flex-wrap items-center justify-center gap-6 md:gap-10">
      <div class="h-8" data-aos="fade-up" data-aos-delay="0">
        <img src="/images/gaclogo.png" alt="GAC" class="h-8 w-auto object-contain opacity-90 grayscale hover:grayscale-0 transition" />
      </div>
      <div class="h-8" data-aos="fade-up" data-aos-delay="100">
        <img src="/images/honkpill-logo.png" alt="Honkpill" class="h-8 w-auto object-contain opacity-90 grayscale hover:grayscale-0 transition" />
      </div>
      <div class="h-8" data-aos="fade-up" data-aos-delay="200">
        <img src="/images/whatisthebeststuff-logo.png" alt="What Is The Best Stuff" class="h-8 w-auto object-contain opacity-90 invert grayscale hover:grayscale-0 transition" />
      </div>
      <div class="h-8" data-aos="fade-up" data-aos-delay="300">
        <img src="/images/nexus-logo.svg" alt="Nexus" class="h-8 w-auto object-contain opacity-90 grayscale hover:grayscale-0 transition" />
      </div>
      <div class="h-8" data-aos="fade-up" data-aos-delay="400">
        <img src="/images/velocity-logo.svg" alt="Velocity" class="h-8 w-auto object-contain opacity-90 grayscale hover:grayscale-0 transition" />
      </div>
    </div>
  </section>
  
  <!-- Testimonials -->
  <section class="py-24 border-t border-white/5 overflow-hidden relative">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-zinc-900/20 to-transparent pointer-events-none"></div>
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="text-center mb-12" data-aos="fade-up">
        <h2 class="text-3xl font-bold mb-4">What Clients Say</h2>
        <p class="text-zinc-400">Real feedback about process, speed, and outcomes.</p>
      </div>
    </div>
    <div class="relative">
      <!-- Gradient overlays for fade effect -->
      <div class="absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-black to-transparent z-10 pointer-events-none"></div>
      <div class="absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-black to-transparent z-10 pointer-events-none"></div>
      
      <div class="testimonials-scroll-container overflow-hidden">
        <div class="testimonials-track flex gap-6 px-6 py-4">
          <!-- First set of testimonials -->
          <div class="testimonial-card framer-card p-8 rounded-2xl min-w-[320px] md:min-w-[380px] flex-shrink-0">
            <div class="flex text-orange-500 mb-4 text-lg">★★★★★</div>
            <p class="text-zinc-300 mb-6 text-sm leading-relaxed">"They made the process simple and handled updates quickly."</p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-sm font-semibold text-white">MJ</div>
              <div>
                <div class="text-sm font-semibold text-white">MJ</div>
                <div class="text-xs text-zinc-400">Local Services</div>
              </div>
            </div>
          </div>
          
          <div class="testimonial-card framer-card p-8 rounded-2xl min-w-[320px] md:min-w-[380px] flex-shrink-0">
            <div class="flex text-orange-500 mb-4 text-lg">★★★★★</div>
            <p class="text-zinc-300 mb-6 text-sm leading-relaxed">"Clean design, faster site, and clearer calls to action."</p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-sm font-semibold text-white">RS</div>
              <div>
                <div class="text-sm font-semibold text-white">RS</div>
                <div class="text-xs text-zinc-400">Professional</div>
              </div>
            </div>
          </div>
          
          <div class="testimonial-card framer-card p-8 rounded-2xl min-w-[320px] md:min-w-[380px] flex-shrink-0">
            <div class="flex text-orange-500 mb-4 text-lg">★★★★★</div>
            <p class="text-zinc-300 mb-6 text-sm leading-relaxed">"Responsive team and solid results on mobile."</p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-sm font-semibold text-white">LT</div>
              <div>
                <div class="text-sm font-semibold text-white">LT</div>
                <div class="text-xs text-zinc-400">Retail</div>
              </div>
            </div>
          </div>
          
          <div class="testimonial-card framer-card p-8 rounded-2xl min-w-[320px] md:min-w-[380px] flex-shrink-0">
            <div class="flex text-orange-500 mb-4 text-lg">★★★★★</div>
            <p class="text-zinc-300 mb-6 text-sm leading-relaxed">"Professional work and great communication throughout."</p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-sm font-semibold text-white">KC</div>
              <div>
                <div class="text-sm font-semibold text-white">KC</div>
                <div class="text-xs text-zinc-400">Healthcare</div>
              </div>
            </div>
          </div>

          <div class="testimonial-card framer-card p-8 rounded-2xl min-w-[320px] md:min-w-[380px] flex-shrink-0">
            <div class="flex text-orange-500 mb-4 text-lg">★★★★★</div>
            <p class="text-zinc-300 mb-6 text-sm leading-relaxed">"Exceeded expectations with attention to detail."</p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-sm font-semibold text-white">DM</div>
              <div>
                <div class="text-sm font-semibold text-white">DM</div>
                <div class="text-xs text-zinc-400">Real Estate</div>
              </div>
            </div>
          </div>

          <!-- Duplicate set for seamless loop -->
          <div class="testimonial-card framer-card p-8 rounded-2xl min-w-[320px] md:min-w-[380px] flex-shrink-0">
            <div class="flex text-orange-500 mb-4 text-lg">★★★★★</div>
            <p class="text-zinc-300 mb-6 text-sm leading-relaxed">"They made the process simple and handled updates quickly."</p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-sm font-semibold text-white">MJ</div>
              <div>
                <div class="text-sm font-semibold text-white">MJ</div>
                <div class="text-xs text-zinc-400">Local Services</div>
              </div>
            </div>
          </div>
          
          <div class="testimonial-card framer-card p-8 rounded-2xl min-w-[320px] md:min-w-[380px] flex-shrink-0">
            <div class="flex text-orange-500 mb-4 text-lg">★★★★★</div>
            <p class="text-zinc-300 mb-6 text-sm leading-relaxed">"Clean design, faster site, and clearer calls to action."</p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-sm font-semibold text-white">RS</div>
              <div>
                <div class="text-sm font-semibold text-white">RS</div>
                <div class="text-xs text-zinc-400">Professional</div>
              </div>
            </div>
          </div>
          
          <div class="testimonial-card framer-card p-8 rounded-2xl min-w-[320px] md:min-w-[380px] flex-shrink-0">
            <div class="flex text-orange-500 mb-4 text-lg">★★★★★</div>
            <p class="text-zinc-300 mb-6 text-sm leading-relaxed">"Responsive team and solid results on mobile."</p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-sm font-semibold text-white">LT</div>
              <div>
                <div class="text-sm font-semibold text-white">LT</div>
                <div class="text-xs text-zinc-400">Retail</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Auto-scrolling testimonials
    const track = document.querySelector('.testimonials-track');
    const container = document.querySelector('.testimonials-scroll-container');
    
    if (track && container) {
      let scrollPosition = 0;
      const scrollSpeed = 0.5; // pixels per frame
      
      // Clone items for seamless loop
      const items = track.querySelectorAll('.testimonial-card');
      const itemWidth = items[0].offsetWidth + 24; // card width + gap
      const totalWidth = itemWidth * (items.length / 2); // half because we duplicated
      
      function animate() {
        scrollPosition += scrollSpeed;
        
        // Reset position for seamless loop
        if (scrollPosition >= totalWidth) {
          scrollPosition = 0;
        }
        
        track.style.transform = `translateX(-${scrollPosition}px)`;
        requestAnimationFrame(animate);
      }
      
      // Start animation
      animate();
    }
  </script>

  <section class="py-24 px-6 bg-zinc-900/30 border-y border-white/5">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12" data-aos="fade-up">
        <h2 class="text-3xl font-bold mb-4">What You Can Expect</h2>
        <p class="text-zinc-400">Clear process, reliable communication, and quality outcomes.</p>
      </div>
      <!-- Desktop: Horizontal Timeline -->
      <div class="hidden md:flex items-center justify-between relative">
        <!-- Connecting line -->
        <div class="absolute top-6 left-0 right-0 h-0.5 bg-orange-500/30 -z-10"></div>
        <!-- Step 1 -->
        <div class="flex flex-col items-center flex-1 relative group cursor-pointer" data-aos="zoom-in" data-aos-delay="0">
          <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">1</div>
          <h3 class="font-bold text-white mb-2 text-center group-hover:text-orange-400 transition-colors">Discovery</h3>
          <p class="text-sm text-zinc-400 text-center max-w-[180px]">We clarify goals, audience, and success criteria together.</p>
        </div>
        <!-- Step 2 -->
        <div class="flex flex-col items-center flex-1 relative group cursor-pointer" data-aos="zoom-in" data-aos-delay="150">
          <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">2</div>
          <h3 class="font-bold text-white mb-2 text-center group-hover:text-orange-400 transition-colors">Design</h3>
          <p class="text-sm text-zinc-400 text-center max-w-[180px]">Modern, accessible UI tailored to your brand and content.</p>
        </div>
        <!-- Step 3 -->
        <div class="flex flex-col items-center flex-1 relative group cursor-pointer" data-aos="zoom-in" data-aos-delay="300">
          <div class="w-12 h-12 rounded-full bg-zinc-900 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mb-4 relative z-10 group-hover:scale-110 transition-transform">3</div>
          <h3 class="font-bold text-white mb-2 text-center group-hover:text-orange-400 transition-colors">Build & Launch</h3>
          <p class="text-sm text-zinc-400 text-center max-w-[180px]">Fast, mobile‑first pages and a smooth handoff at launch.</p>
        </div>
      </div>
      <!-- Mobile: Vertical Timeline -->
      <div class="md:hidden space-y-8">
        <div class="flex gap-4 relative">
          <div class="flex flex-col items-center">
