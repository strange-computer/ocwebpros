---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout 
  title="SEO Newsletter | OCWebPros" 
  description="Subscribe to the OCWebPros SEO newsletter. Local SEO tips, AI search updates, and web design insights for Orange County businesses - no spam, unsubscribe anytime."
  bodyClass="page-newsletter"
  pageCSS="/css/pages/contact.css">

  <header class="relative pt-32 sm:pt-32 md:pt-40 pb-12 sm:pb-16 px-4 sm:px-6 text-center overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90vw] max-w-[800px] h-[400px] sm:h-[500px] md:h-[600px] glow-bg pointer-events-none opacity-40"></div>
    <div class="max-w-5xl mx-auto relative">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 border border-slate-200 text-xs font-medium text-orange-400 mb-6">
        <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
        Newsletter
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4">
        The OCWebPros <span class="text-gradient-orange">SEO Newsletter</span>
      </h1>
      <p class="text-slate-600 text-lg leading-relaxed max-w-3xl mx-auto">
        Practical SEO, local search, and AI visibility updates for Orange County businesses - written by our Lake Forest team, not a marketing agency content mill.
      </p>
    </div>
  </header>

  <main class="pb-16 sm:pb-24 px-4 sm:px-6 md:px-8">
    <!-- Signup -->
    <section class="max-w-4xl mx-auto pt-8 md:pt-12 pb-16 md:pb-24 px-4 sm:px-6" data-aos="fade-up">
      <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6 sm:p-8 md:p-10">
        <h2 class="text-2xl md:text-3xl font-bold mb-2 text-slate-900 text-center">Subscribe for free</h2>
        <p class="text-slate-600 text-sm md:text-base text-center mb-8">Get the latest when we publish - usually a few times a month.</p>
        <form id="newsletterForm" class="max-w-md mx-auto space-y-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">Email*</label>
            <input type="email" name="email" required class="w-full rounded-xl bg-white border border-slate-200 px-4 py-3 text-slate-900 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500/50 transition-all" placeholder="you@example.com" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">First name <span class="text-slate-500">(optional)</span></label>
            <input type="text" name="name" class="w-full rounded-xl bg-white border border-slate-200 px-4 py-3 text-slate-900 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500/50 transition-all" placeholder="Jane" />
          </div>
          <button type="submit" class="w-full px-8 py-3.5 bg-orange-700 text-white font-semibold rounded-full hover:bg-orange-600 transition-colors btn-glow">
            Subscribe
          </button>
          <p id="newsletterNote" class="text-sm text-slate-600 text-center">No spam. Unsubscribe anytime.</p>
        </form>
      </div>
    </section>

    <!-- What You Get -->
    <section class="max-w-7xl mx-auto pt-2 md:pt-4 pb-16 md:pb-24 px-4 sm:px-6 md:px-8">
      <div class="text-center mb-12" data-aos="fade-up">
        <h2 class="text-2xl md:text-3xl font-bold mb-2 text-slate-900">What you&apos;ll get</h2>
        <p class="text-slate-600 text-sm md:text-base">Actionable insights, not fluff.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6" data-aos="fade-up" data-aos-delay="0">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Local SEO Updates</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Google Business Profile changes, local ranking shifts, and tactics that work for Orange County markets.</p>
        </div>
        <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6" data-aos="fade-up" data-aos-delay="100">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">AI Search &amp; GEO</h3>
          <p class="text-sm text-slate-600 leading-relaxed">AI Overviews, generative engine optimization, and how to stay visible as search evolves.</p>
        </div>
        <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6 sm:col-span-2 md:col-span-1" data-aos="fade-up" data-aos-delay="200">
          <div class="w-8 h-8 flex items-center justify-center mb-3">
            <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Web Design &amp; Performance</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Core Web Vitals, mobile UX, and site updates that support search visibility and conversions.</p>
        </div>
      </div>
    </section>

    <!-- Blog link -->
    <section class="max-w-3xl mx-auto text-center py-12 px-4 sm:px-6 md:px-8 bg-slate-50 border-y border-slate-100" data-aos="fade-up">
      <h2 class="text-xl md:text-2xl font-bold mb-3 text-slate-900">Prefer to browse first?</h2>
      <p class="text-slate-600 mb-6">Our blog is full of in-depth guides on local SEO, web design, and AI search for Orange County businesses.</p>
      <a href="/blog" class="inline-block px-8 py-3.5 bg-slate-100 text-slate-900 font-semibold rounded-full border border-slate-200 hover:bg-slate-100 transition-colors">
        Read the blog
      </a>
    </section>
  </main>

  <script>
    (function () {
      const form = document.getElementById('newsletterForm');
      if (!form) return;
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const fd = new FormData(form);
        const email = fd.get('email') || '';
        const name = fd.get('name') || '';
        const subject = encodeURIComponent('Newsletter subscription request');
        const body = encodeURIComponent(
          `Please add me to the OCWebPros SEO newsletter.\n\nEmail: ${email}\nName: ${name || '(not provided)'}`
        );
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({ event: 'newsletter_signup' });
        window.location.href = `mailto:hello@ocwebpros.com?subject=${subject}&body=${body}`;
      });
    })();
  </script>
</MainLayout>
