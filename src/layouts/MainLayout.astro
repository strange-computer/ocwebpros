---
interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
  pageCSS?: string;
}
import '../styles/global.css';
import '../styles/aos-minimal.css';
import CartSidebar from '../components/CartSidebar.astro';
import ocwebprosLogo from '../assets/ocwebpros_logo.png';
import { Image } from 'astro:assets';
import { cityRegistry } from '../data/cityRegistry';
const { 
  title = 'OCWebPros', 
  description = 'Professional web design and local SEO services in Orange County, CA. Custom websites built for local businesses with strategic optimization.',
  bodyClass = '',
  pageCSS = ''
} = Astro.props;
// Highlight active nav link based on current path
const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const navClass = (href: string) =>
  `hover:text-slate-900 transition-colors ${currentPath === href || (href !== '/' && currentPath.startsWith(href)) || (href === '/service-areas' && (currentPath.startsWith('/local-seo') || currentPath.startsWith('/web-design'))) ? 'text-slate-900 font-semibold' : ''}`;

// Get the full URL for schema — always prefer trailing-slash canonicals
const siteUrl = Astro.site || new URL(Astro.url.origin);
const canonicalPath =
  Astro.url.pathname === '/'
    ? '/'
    : Astro.url.pathname.endsWith('/')
      ? Astro.url.pathname
      : `${Astro.url.pathname}/`;
const canonicalURL = new URL(canonicalPath, siteUrl);

// Schema.org structured data for SEO
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": ["ProfessionalService", "LocalBusiness"],
  "@id": siteUrl.toString() + "#business",
  "name": "OCWebPros",
  "description": "Professional web design and local SEO services in Orange County, California. Custom websites built for local businesses with strategic SEO optimization.",
  "url": siteUrl.toString(),
  "logo": {
    "@type": "ImageObject",
    "url": new URL(ocwebprosLogo.src, siteUrl).toString()
  },
  "image": new URL(ocwebprosLogo.src, siteUrl).toString(),
  "telephone": "+1-949-329-4437",
  "email": "hello@ocwebpros.com",
  "foundingDate": "2026",
  "priceRange": "$$",
  "currenciesAccepted": "USD",
  "paymentAccepted": "Credit Card, Bank Transfer",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Lake Forest",
    "addressRegion": "CA",
    "postalCode": "92630",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 33.6469,
    "longitude": -117.6892
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+1-949-329-4437",
    "email": "hello@ocwebpros.com",
    "contactType": "customer service",
    "areaServed": "US-CA",
    "availableLanguage": "English"
  },
  "sameAs": [
    "https://share.google/tSH03wj1lOrG59DXD",
    "https://clutch.co/profile/ocwebpros",
    "https://www.crunchbase.com/organization/ocwebpros",
    "https://www.manta.com/c/m1hxc2q/ocwebpros",
    "https://www.hotfrog.com/company/e5c8ed6667cb34f7e45c5f6f292e93df"
  ],
  "areaServed": [
    ...cityRegistry.map((city) => ({
      "@type": "City",
      "name": city.name,
      "containedInPlace": {
        "@type": "State",
        "name": "California"
      }
    })),
    {
      "@type": "Place",
      "name": "Orange County, California"
    }
  ],
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "09:00",
      "closes": "17:00"
    }
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Web Design and SEO Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Custom Web Design",
          "description": "Professional custom website design and development for local businesses in Orange County"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Local SEO Services",
          "description": "Strategic local search engine optimization to improve visibility in Orange County"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Managed Web Hosting",
          "description": "Secure managed hosting with global CDN, auto-renewing SSL, deploy rollback, and uptime monitoring"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Website Support & Maintenance",
          "description": "Ongoing website updates, security patches, and technical support"
        }
      }
    ]
  }
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": siteUrl.toString() + "#website",
  "name": "OCWebPros",
  "url": siteUrl.toString(),
  "publisher": {
    "@id": siteUrl.toString() + "#business"
  }
};

// Breadcrumb schema (dynamically generated based on current path)
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl.toString()
    },
    ...pathSegments.map((segment, index) => ({
      "@type": "ListItem",
      "position": index + 2,
      "name": segment.charAt(0).toUpperCase() + segment.slice(1).replace(/-/g, ' '),
      "item": new URL(pathSegments.slice(0, index + 1).join('/'), siteUrl).toString()
    }))
  ]
};
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.toString()} />
    <link rel="alternate" type="application/rss+xml" title="OCWebPros Blog" href="/rss.xml" />

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ocwebprosLogo.src, siteUrl).toString()} />
    <meta property="og:site_name" content="OCWebPros" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL.toString()} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ocwebprosLogo.src, siteUrl).toString()} />
    
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-PBXTHDW8');</script>
    <!-- End Google Tag Manager -->

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Outfit:wght@500;600;700;800&family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@500;600;700;800&family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" /></noscript>
    
    <!-- Schema.org Structured Data for SEO -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    {pathSegments.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    )}
    <slot name="head" />
    
    {pageCSS && (
      <>
        <link rel="preload" as="style" href={pageCSS} onload="this.onload=null;this.rel='stylesheet'" />
        <noscript><link rel="stylesheet" href={pageCSS} /></noscript>
      </>
    )}
  </head>
  <body class={`antialiased overflow-x-hidden selection:bg-orange-500 selection:text-white text-slate-900 bg-slate-50 ${bodyClass}`}>
    <script is:inline>document.documentElement.classList.add('aos-boot');</script>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PBXTHDW8"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <nav class="fixed inset-x-0 top-0 z-50 border-b border-slate-200/80 bg-white/90 backdrop-blur-lg shadow-[0_1px_3px_rgba(15,23,42,0.06)]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 h-16 sm:h-20 flex items-center justify-between">
        <div class="flex items-center gap-2 min-w-0 flex-shrink">
          <a href="/" class="flex items-center flex-shrink-0">
            <Image src={ocwebprosLogo} alt="OCWebPros" width={104} height={64} class="h-8 w-auto" />
          </a>
          <a href="/" class="logo-text text-sm sm:text-base text-slate-900 hover:text-orange-600 transition">
            OCWebPros
          </a>
        </div>
        <div class="hidden lg:flex items-center gap-6 text-sm font-medium text-slate-500">
          <a href="/services/" class={navClass('/services')}>Services</a>
          <a href="/service-areas/" class={navClass('/service-areas')}>Service Areas</a>
          <a href="/pricing/" class={navClass('/pricing')}>Pricing</a>
          <a href="/portfolio/" class={navClass('/portfolio')}>Portfolio</a>
          <a href="/blog/" class={navClass('/blog')}>Blog</a>
          <a href="/about/" class={navClass('/about')}>About</a>
          <a href="/contact/" class={navClass('/contact')}>Contact</a>
        </div>
        <div class="flex items-center gap-2 sm:gap-3 flex-shrink-0">
          <button id="cartBtn" aria-label="View your plan" class="relative p-2 text-slate-500 hover:text-slate-900 transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
            </svg>
            <span id="cartBadge" class="hidden absolute -top-1 -right-1 w-5 h-5 bg-orange-500 text-white text-xs font-bold rounded-full flex items-center justify-center">0</span>
          </button>
          <a href="tel:9493294437" class="md:hidden flex items-center justify-center px-3 py-1.5 bg-slate-100 text-slate-900 text-xs font-semibold rounded-full border border-slate-200 hover:bg-slate-200 transition-colors leading-none">
            Call
          </a>
          <a href="/contact/" class="hidden md:inline-flex px-5 py-2.5 bg-orange-600 text-white text-sm font-semibold rounded-full hover:bg-orange-700 transition-colors btn-glow">
            Book a Call
          </a>
          <button id="mobileMenuToggle" class="lg:hidden p-2 text-slate-500 hover:text-slate-900 transition-colors" aria-label="Toggle menu">
            <svg id="menuIcon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <svg id="closeIcon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <!-- Mobile Menu Overlay -->
    <div id="mobileMenu" class="fixed inset-0 z-40 bg-white lg:hidden transform translate-x-full transition-transform duration-300 ease-in-out">
      <div class="flex flex-col h-full pt-20 pb-8 px-6">
        <div class="flex flex-col gap-1 text-slate-600">
          <a href="/services/" class={`py-3 px-4 rounded-lg text-base font-medium transition-colors ${navClass('/services')}`}>Services</a>
          <a href="/service-areas/" class={`py-3 px-4 rounded-lg text-base font-medium transition-colors ${navClass('/service-areas')}`}>Service Areas</a>
          <a href="/pricing/" class={`py-3 px-4 rounded-lg text-base font-medium transition-colors ${navClass('/pricing')}`}>Pricing</a>
          <a href="/portfolio/" class={`py-3 px-4 rounded-lg text-base font-medium transition-colors ${navClass('/portfolio')}`}>Portfolio</a>
          <a href="/blog/" class={`py-3 px-4 rounded-lg text-base font-medium transition-colors ${navClass('/blog')}`}>Blog</a>
          <a href="/support/" class={`py-3 px-4 rounded-lg text-base font-medium transition-colors ${navClass('/support')}`}>Support</a>
          <a href="/hosting/" class={`py-3 px-4 rounded-lg text-base font-medium transition-colors ${navClass('/hosting')}`}>Hosting</a>
          <a href="/about/" class={`py-3 px-4 rounded-lg text-base font-medium transition-colors ${navClass('/about')}`}>About</a>
          <a href="/contact/" class={`py-3 px-4 rounded-lg text-base font-medium transition-colors ${navClass('/contact')}`}>Contact</a>
        </div>
        <div class="mt-auto pt-6 border-t border-slate-200">
          <a href="tel:9493294437" class="block w-full px-6 py-3 bg-orange-600 text-white font-semibold rounded-full text-center hover:bg-orange-700 transition-colors mb-3">
            (949) 329-4437
          </a>
          <a href="mailto:hello@ocwebpros.com" class="block w-full px-6 py-3 bg-slate-50 text-slate-900 font-semibold rounded-full text-center border border-slate-200 hover:bg-slate-100 transition-colors">
            Email Us
          </a>
        </div>
      </div>
    </div>

    <slot />

    <footer class="border-t border-slate-800 py-16 px-6 bg-slate-900 text-slate-300">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
          <div class="lg:col-span-1">
            <a href="/" class="logo-text text-xl text-white hover:text-orange-400 transition">OCWebPros</a>
            <p class="mt-4 text-sm leading-relaxed text-slate-400">
              Web design and local SEO for Orange County businesses. Based in Lake Forest — built to get you found and convert.
            </p>
            <a href="tel:9493294437" class="mt-4 inline-block text-white font-semibold hover:text-orange-400 transition">(949) 329-4437</a>
            <a href="mailto:hello@ocwebpros.com" class="mt-1 block text-sm text-slate-400 hover:text-white transition">hello@ocwebpros.com</a>
          </div>
          <div>
            <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Services</h3>
            <div class="flex flex-col gap-2 text-sm">
              <a href="/services/web-design/" class="hover:text-white transition-colors">Web Design</a>
              <a href="/services/local-seo/" class="hover:text-white transition-colors">Local SEO</a>
              <a href="/services/seo-strategy/" class="hover:text-white transition-colors">SEO Strategy</a>
              <a href="/hosting/" class="hover:text-white transition-colors">Hosting</a>
              <a href="/support/" class="hover:text-white transition-colors">Support</a>
              <a href="/pricing/" class="hover:text-white transition-colors">Pricing</a>
            </div>
          </div>
          <div>
            <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Company</h3>
            <div class="flex flex-col gap-2 text-sm">
              <a href="/about/" class="hover:text-white transition-colors">About</a>
              <a href="/portfolio/" class="hover:text-white transition-colors">Portfolio</a>
              <a href="/industries/" class="hover:text-white transition-colors">Industries</a>
              <a href="/service-areas/" class="hover:text-white transition-colors">Service Areas</a>
              <a href="/blog/" class="hover:text-white transition-colors">Blog</a>
              <a href="/contact/" class="hover:text-white transition-colors">Contact</a>
            </div>
          </div>
          <div>
            <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Get Started</h3>
            <p class="text-sm text-slate-400 mb-4">Ready for a site that ranks and converts?</p>
            <a href="/contact/" class="inline-flex px-5 py-2.5 bg-orange-600 text-white text-sm font-semibold rounded-full hover:bg-orange-700 transition-colors">
              Book a Free Consult
            </a>
            <a href="https://share.google/tSH03wj1lOrG59DXD" target="_blank" rel="noopener noreferrer" class="mt-4 block text-sm text-slate-400 hover:text-white transition-colors">Verified on Google →</a>
          </div>
        </div>
        <div class="pt-8 border-t border-slate-800 text-sm text-slate-500">
          © 2026 OCWebPros. Lake Forest, CA. All Rights Reserved.
        </div>
      </div>
    </footer>
    
    <!-- Cart: deferred so it doesn't block initial render -->
    <script is:inline src="/js/cart.js" defer></script>
    <CartSidebar />

    <!-- AOS: classic scripts so init is reliable; content visible until AOS is ready -->
    <script is:inline src="/js/aos.js" defer></script>
    <script is:inline src="/js/aos-init.js" defer></script>
    <script is:inline>
      // Mobile menu toggle
      (function() {
        const toggle = document.getElementById('mobileMenuToggle');
        const menu = document.getElementById('mobileMenu');
        const menuIcon = document.getElementById('menuIcon');
        const closeIcon = document.getElementById('closeIcon');
        const body = document.body;

        if (!toggle || !menu) return;

        toggle.addEventListener('click', function() {
          const isOpen = !menu.classList.contains('translate-x-full');
          
          if (isOpen) {
            menu.classList.add('translate-x-full');
            menuIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
            body.style.overflow = '';
          } else {
            menu.classList.remove('translate-x-full');
            menuIcon.classList.add('hidden');
            closeIcon.classList.remove('hidden');
            body.style.overflow = 'hidden';
          }
        });

        // Close menu when clicking on a link
        const menuLinks = menu.querySelectorAll('a');
        menuLinks.forEach(link => {
          link.addEventListener('click', function() {
            menu.classList.add('translate-x-full');
            menuIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
            body.style.overflow = '';
          });
        });

        // Close menu when clicking outside
        menu.addEventListener('click', function(e) {
          if (e.target === menu) {
            menu.classList.add('translate-x-full');
            menuIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
            body.style.overflow = '';
          }
        });
      })();

    </script>
  </body>
  <!-- Per-page CSS layers can be added by the page (e.g., /css/pages/home.css) -->
</html>


