---
interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
}
import '../styles/global.css';
import CartSidebar from '../components/CartSidebar.astro';
const { 
  title = 'OCWebPros', 
  description = 'Professional web design and local SEO services in Orange County, CA. Custom websites built for local businesses with strategic optimization.',
  bodyClass = '' 
} = Astro.props;
// Highlight active nav link based on current path
const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const navClass = (href: string) =>
  `hover:text-white transition-colors ${currentPath === href || (href !== '/' && currentPath.startsWith(href)) ? 'text-white' : ''}`;

// Get the full URL for schema
const siteUrl = Astro.site || new URL(Astro.url.origin);
const canonicalURL = new URL(Astro.url.pathname, siteUrl);

// Schema.org structured data for SEO
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "OCWebPros",
  "description": "Professional web design and local SEO services in Orange County, California. Custom websites built for local businesses with strategic SEO optimization.",
  "url": siteUrl.toString(),
  "logo": new URL("/images/LakeForestLogo.png", siteUrl).toString(),
  "image": new URL("/images/LakeForestLogo.png", siteUrl).toString(),
  "telephone": "+1-949-329-4437",
  "email": "info@ocwebpros.com",
  "foundingDate": "2026",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Lake Forest",
    "addressRegion": "CA",
    "addressCountry": "US"
  },
  "areaServed": [
    {
      "@type": "City",
      "name": "Lake Forest",
      "containedInPlace": {
        "@type": "State",
        "name": "California"
      }
    },
    {
      "@type": "City",
      "name": "Irvine",
      "containedInPlace": {
        "@type": "State",
        "name": "California"
      }
    },
    {
      "@type": "City",
      "name": "Mission Viejo",
      "containedInPlace": {
        "@type": "State",
        "name": "California"
      }
    },
    {
      "@type": "City",
      "name": "Laguna Hills",
      "containedInPlace": {
        "@type": "State",
        "name": "California"
      }
    },
    {
      "@type": "City",
      "name": "Tustin",
      "containedInPlace": {
        "@type": "State",
        "name": "California"
      }
    },
    {
      "@type": "Place",
      "name": "Orange County, California"
    }
  ],
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "09:00",
      "closes": "17:00"
    }
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Web Design and SEO Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Custom Web Design",
          "description": "Professional custom website design and development for local businesses"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Local SEO Services",
          "description": "Strategic local search engine optimization to improve visibility in Orange County"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Managed Web Hosting",
          "description": "Secure, fast managed hosting with daily backups and monitoring"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Website Support & Maintenance",
          "description": "Ongoing website updates, security patches, and technical support"
        }
      }
    ]
  }
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "OCWebPros",
  "url": siteUrl.toString(),
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": new URL("/services?q={search_term_string}", siteUrl).toString()
    },
    "query-input": "required name=search_term_string"
  }
};

// Breadcrumb schema (dynamically generated based on current path)
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl.toString()
    },
    ...pathSegments.map((segment, index) => ({
      "@type": "ListItem",
      "position": index + 2,
      "name": segment.charAt(0).toUpperCase() + segment.slice(1).replace(/-/g, ' '),
      "item": new URL(pathSegments.slice(0, index + 1).join('/'), siteUrl).toString()
    }))
  ]
};
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.toString()} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL("/images/LakeForestLogo.png", siteUrl).toString()} />
    <meta property="og:site_name" content="OCWebPros" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL.toString()} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL("/images/LakeForestLogo.png", siteUrl).toString()} />
    
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-SEP6G0WSB0"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-SEP6G0WSB0');
    </script>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Montserrat:wght@600;700&display=swap" rel="stylesheet" />
    
    <!-- Schema.org Structured Data for SEO -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    {pathSegments.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    )}
    
    <!-- AOS CSS -->
    <link rel="stylesheet" href="https://unpkg.com/aos@2.3.4/dist/aos.css" />
    <!-- Existing layered CSS -->
    <link rel="stylesheet" href="/css/layers.css" />
    <link rel="stylesheet" href="/css/base.css" />
    <link rel="stylesheet" href="/css/components.css" />
  </head>
  <body class={`antialiased overflow-x-hidden selection:bg-orange-500 selection:text-white ${bodyClass}`}>
    <nav class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-black/30 backdrop-blur-xl backdrop-saturate-150 shadow-[0_8px_32px_rgba(0,0,0,0.35)] ring-1 ring-white/10">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 h-16 sm:h-20 flex items-center justify-between">
        <div class="flex items-center gap-2 min-w-0 flex-shrink">
          <a href="/" class="flex items-center flex-shrink-0">
            <img src="/images/LakeForestLogo.png" alt="OCWebPros" class="h-8 w-auto" />
          </a>
          <a href="/" class="logo-text text-sm sm:text-base hover:text-white/80 transition">
            OCWebPros
          </a>
        </div>
        <div class="hidden md:flex items-center gap-8 text-sm font-medium text-zinc-400">
          <a href="/services" class={navClass('/services')}>Services</a>
          <a href="/pricing" class={navClass('/pricing')}>Pricing</a>
          <a href="/industries" class={navClass('/industries')}>Industries</a>
          <a href="/portfolio" class={navClass('/portfolio')}>Portfolio</a>
          <a href="/support" class={navClass('/support')}>Support</a>
          <a href="/hosting" class={navClass('/hosting')}>Hosting</a>
          <a href="/about" class={navClass('/about')}>About</a>
          <a href="/contact" class={navClass('/contact')}>Contact</a>
        </div>
        <div class="flex items-center gap-2 sm:gap-3 flex-shrink-0">
          <button id="cartBtn" class="relative p-2 text-zinc-400 hover:text-white transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
            </svg>
            <span id="cartBadge" class="hidden absolute -top-1 -right-1 w-5 h-5 bg-orange-500 text-white text-xs font-bold rounded-full flex items-center justify-center">0</span>
          </button>
          <a href="tel:9493294437" class="md:hidden flex items-center justify-center px-3 py-1.5 bg-white/10 text-white text-xs font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors leading-none">
            Call
          </a>
          <a href="tel:9493294437" class="hidden md:block px-5 py-2.5 bg-white text-black text-sm font-semibold rounded-full hover:bg-zinc-200 transition-colors">
            (949) 329-4437
          </a>
          <button id="mobileMenuToggle" class="md:hidden p-2 text-zinc-400 hover:text-white transition-colors" aria-label="Toggle menu">
            <svg id="menuIcon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <svg id="closeIcon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <!-- Mobile Menu Overlay -->
    <div id="mobileMenu" class="fixed inset-0 z-40 bg-black/95 backdrop-blur-xl md:hidden transform translate-x-full transition-transform duration-300 ease-in-out">
      <div class="flex flex-col h-full pt-20 pb-8 px-6">
        <div class="flex flex-col gap-1">
          <a href="/services" class={`py-3 px-4 rounded-lg text-base font-medium transition-colors ${navClass('/services')}`}>Services</a>
          <a href="/pricing" class={`py-3 px-4 rounded-lg text-base font-medium transition-colors ${navClass('/pricing')}`}>Pricing</a>
          <a href="/industries" class={`py-3 px-4 rounded-lg text-base font-medium transition-colors ${navClass('/industries')}`}>Industries</a>
          <a href="/portfolio" class={`py-3 px-4 rounded-lg text-base font-medium transition-colors ${navClass('/portfolio')}`}>Portfolio</a>
          <a href="/support" class={`py-3 px-4 rounded-lg text-base font-medium transition-colors ${navClass('/support')}`}>Support</a>
          <a href="/hosting" class={`py-3 px-4 rounded-lg text-base font-medium transition-colors ${navClass('/hosting')}`}>Hosting</a>
          <a href="/about" class={`py-3 px-4 rounded-lg text-base font-medium transition-colors ${navClass('/about')}`}>About</a>
          <a href="/contact" class={`py-3 px-4 rounded-lg text-base font-medium transition-colors ${navClass('/contact')}`}>Contact</a>
        </div>
        <div class="mt-auto pt-6 border-t border-white/10">
          <a href="tel:9493294437" class="block w-full px-6 py-3 bg-orange-600 text-white font-semibold rounded-full text-center hover:bg-orange-500 transition-colors mb-3">
            (949) 329-4437
          </a>
          <a href="mailto:info@ocwebpros.com" class="block w-full px-6 py-3 bg-white/5 text-white font-semibold rounded-full text-center border border-white/10 hover:bg-white/10 transition-colors">
            Email Us
          </a>
        </div>
      </div>
    </div>

    <slot />

    <footer class="border-t border-white/10 py-12 px-6 bg-black">
      <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8">
          <div class="text-zinc-500 text-sm">© 2026 OCWebPros. All Rights Reserved.</div>
          <div class="grid grid-cols-2 sm:flex sm:flex-wrap gap-x-6 gap-y-3 text-sm text-zinc-400">
            <a href="/" class="hover:text-white transition-colors">Home</a>
            <a href="/services" class="hover:text-white transition-colors">Services</a>
            <a href="/pricing" class="hover:text-white transition-colors">Pricing</a>
            <a href="/industries" class="hover:text-white transition-colors">Industries</a>
            <a href="/portfolio" class="hover:text-white transition-colors">Portfolio</a>
            <a href="/support" class="hover:text-white transition-colors">Support</a>
            <a href="/hosting" class="hover:text-white transition-colors">Hosting</a>
            <a href="/about" class="hover:text-white transition-colors">About</a>
            <a href="/contact" class="hover:text-white transition-colors">Contact</a>
          </div>
        </div>
      </div>
    </footer>
    
    <!-- Cart: load first so it's available on every page -->
    <script is:inline src="/js/cart.js"></script>
    <CartSidebar />

    <!-- AOS JavaScript -->
    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js" defer></script>
    <script is:inline>
      // Mobile menu toggle
      (function() {
        const toggle = document.getElementById('mobileMenuToggle');
        const menu = document.getElementById('mobileMenu');
        const menuIcon = document.getElementById('menuIcon');
        const closeIcon = document.getElementById('closeIcon');
        const body = document.body;

        if (!toggle || !menu) return;

        toggle.addEventListener('click', function() {
          const isOpen = !menu.classList.contains('translate-x-full');
          
          if (isOpen) {
            menu.classList.add('translate-x-full');
            menuIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
            body.style.overflow = '';
          } else {
            menu.classList.remove('translate-x-full');
            menuIcon.classList.add('hidden');
            closeIcon.classList.remove('hidden');
            body.style.overflow = 'hidden';
          }
        });

        // Close menu when clicking on a link
        const menuLinks = menu.querySelectorAll('a');
        menuLinks.forEach(link => {
          link.addEventListener('click', function() {
            menu.classList.add('translate-x-full');
            menuIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
            body.style.overflow = '';
          });
        });

        // Close menu when clicking outside
        menu.addEventListener('click', function(e) {
          if (e.target === menu) {
            menu.classList.add('translate-x-full');
            menuIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
            body.style.overflow = '';
          }
        });
      })();

      // Cart button handler
      const cartBtn = document.getElementById('cartBtn');
      if (cartBtn && typeof window.openCart === 'function') {
        cartBtn.addEventListener('click', window.openCart);
      }

      // AOS initialization
      window.addEventListener('load', function() {
        if (typeof AOS !== 'undefined') {
          AOS.init({
            duration: 700,
            easing: 'ease-out',
            once: true,
            offset: 100,
            delay: 0,
            disable: false
          });
        } else {
          // Retry if AOS hasn't loaded yet
          setTimeout(function() {
            if (typeof AOS !== 'undefined') {
              AOS.init({
                duration: 700,
                easing: 'ease-out',
                once: true,
                offset: 100,
                delay: 0,
                disable: false
              });
            }
          }, 100);
        }
      });
    </script>
  </body>
  <!-- Per-page CSS layers can be added by the page (e.g., /css/pages/home.css) -->
</html>


