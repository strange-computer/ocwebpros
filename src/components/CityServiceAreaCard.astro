---
import type { CityRegistryEntry } from '../data/cityRegistry';

interface Props {
  city: CityRegistryEntry;
  variant?: 'primary' | 'compact';
  cardLead?: string;
  cardDetail?: string;
}

const { city, variant = 'compact', cardLead, cardDetail } = Astro.props;
const lead = cardLead ?? city.marketAngle;
---

{variant === 'primary' ? (
  <div class="bg-white border border-slate-200 rounded-2xl p-6 hover:border-orange-300 hover:bg-orange-50/30 transition-colors">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-orange-500/20 border border-orange-500/30 text-xs font-medium text-orange-400 mb-4">
      <span class="w-2 h-2 rounded-full bg-orange-500"></span>
      {city.badge}
    </div>
    <h3 class="text-2xl font-bold text-slate-900 mb-3">{city.name}</h3>
    {cardLead && <p class="text-slate-600 mb-4">{cardLead}</p>}
    {cardDetail && <p class="text-slate-600 mb-6">{cardDetail}</p>}
    <p class="text-slate-600 mb-4 text-sm">
      <a href={`/local-seo/${city.slug}`} class="text-orange-400 hover:text-orange-300 underline font-medium">Local SEO</a>
      <span class="text-slate-500 mx-2">·</span>
      <a href={`/web-design/${city.slug}`} class="text-orange-400 hover:text-orange-300 underline font-medium">Web Design</a>
      {city.blogSlug && (
        <>
          <span class="text-slate-500 mx-2">·</span>
          <a href={`/blog/${city.blogSlug}`} class="text-orange-400 hover:text-orange-300 underline">{city.blogTitle?.split(':')[0] ?? 'Local guide'}</a>
        </>
      )}
    </p>
    <a href="/contact" class="text-orange-400 font-medium hover:text-orange-300 transition-colors">
      Request {city.name} Consultation →
    </a>
  </div>
) : (
  <a
    href={`/local-seo/${city.slug}`}
    class="bg-white border border-slate-200 rounded-xl p-4 text-center hover:border-orange-500/30 hover:bg-orange-50/30 transition-colors group"
  >
    <div class="text-slate-900 font-medium group-hover:text-orange-600 transition-colors">{city.name}</div>
    <div class="text-xs text-slate-500 mt-1">Local SEO & Web Design</div>
  </a>
)}
