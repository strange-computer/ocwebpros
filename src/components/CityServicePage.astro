---
import MainLayout from '../layouts/MainLayout.astro';
import SpotlightImage from './SpotlightImage.astro';
import type { CityServicePageData } from '../data/cityPageTypes';
import { cityProofStrip } from '../data/priorityLocalSeoCities';

type ServiceKind = 'local-seo' | 'web-design';

interface Props {
  city: CityServicePageData;
  serviceKind: ServiceKind;
  allCities: CityServicePageData[];
}

const { city, serviceKind, allCities } = Astro.props;

const config = {
  'local-seo': {
    label: 'Local SEO',
    path: 'local-seo',
    schemaType: 'Local SEO',
    sisterPath: 'web-design',
    sisterLabel: 'Web Design',
    hubPath: '/services/local-seo/',
    hubLabel: 'local SEO services',
    spotlightSrc: '/images/unsplash/services-local-seo.jpg',
    spotlightAlt: (name: string) => `Local SEO results for ${name} businesses on Google Maps`,
    includesLead: (name: string) =>
      `A complete local search strategy for ${name} — not a one-time setup. We manage the ongoing work that keeps your business visible.`,
    includesBullets: (name: string) => [
      'Google Business Profile setup, optimization, and weekly posts',
      `Dedicated ${name} service landing pages on your website`,
      'Citation consistency across Yelp, Bing, Apple Maps, and local directories',
      'Review strategy, monitoring, and monthly performance reporting',
    ],
    h1Lead: 'Local SEO Services',
    servicesHeading: (name: string) => `Our ${name} Local SEO Services`,
    servicesSub: (name: string) =>
      `Everything needed to rank for SEO ${name} and Maps searches — managed monthly by a Lake Forest-based team.`,
    challengesHeading: (name: string) => `Why ${name} SEO Is Challenging`,
    processHeading: (name: string) => `How We Get ${name} Businesses Ranking`,
    processSteps: [
      { title: 'Audit', desc: (name: string) => `Baseline ${name} rankings, GBP health check, and citation review.` },
      { title: 'Build', desc: (name: string) => `Launch ${name} landing pages, fix on-page SEO, optimize your Google profile.` },
      { title: 'Grow', desc: (name: string) => `Publish local content, earn reviews, and build ${name} citations monthly.` },
      { title: 'Report', desc: (name: string) => `Monthly ${name} ranking updates, lead tracking, and next-step plan.` },
    ],
    faqHeading: (name: string) => `${name} Local SEO — Frequently Asked Questions`,
    blogCardTitle: (name: string) => `${name} SEO Guide (Blog)`,
    blogCardDesc: (name: string) =>
      `Prefer a how-to deep-dive first? Our ${name} blog guide covers neighborhoods and tactics. When you're ready to hire, this service page is the commercial home for SEO in ${name}.`,
    ctaHeading: (name: string) => `Ready to hire SEO services in ${name}?`,
    ctaDesc: (name: string) =>
      `Request a free local SEO audit for your ${name} business. We'll show you exactly where you stand and what to fix first.`,
    auditLabel: 'SEO audit',
    pricingHash: '',
  },
  'web-design': {
    label: 'Web Design',
    path: 'web-design',
    schemaType: 'Web Design',
    sisterPath: 'local-seo',
    sisterLabel: 'Local SEO',
    hubPath: '/services/web-design/',
    hubLabel: 'web design services',
    spotlightSrc: '/images/unsplash/services-web-design.jpg',
    spotlightAlt: (name: string) => `Custom web design for ${name} businesses`,
    h1Lead: 'Web Design',
    includesLead: (name: string) =>
      `Every ${name} website we build is custom, mobile-first, and optimized to convert visitors into customers.`,
    includesBullets: () => [
      'Custom design tailored to your brand — no bloated templates',
      'City and service page structure for local search visibility',
      'Mobile-first layouts with Core Web Vitals optimization',
      'Local schema markup, hosting, and optional ongoing support',
    ],
    servicesHeading: (name: string) => `Our ${name} Web Design Services`,
    servicesSub: (name: string) =>
      `Everything your ${name} business needs for a website that ranks, converts, and grows.`,
    challengesHeading: (name: string) => `Why ${name} Businesses Struggle Online`,
    processHeading: (name: string) => `How We Build ${name} Websites`,
    processSteps: [
      { title: 'Discover', desc: (name: string) => `Clarify goals, audience, and how ${name} customers find you online.` },
      { title: 'Design', desc: () => `Visual concepts and page structure refined together before a single line of code.` },
      { title: 'Build', desc: (name: string) => `Fast, mobile-first development with ${name} service pages and local SEO built in.` },
      { title: 'Launch', desc: () => `Testing, deploy, training, and optional ongoing hosting and support.` },
    ],
    faqHeading: (name: string) => `${name} Web Design — Frequently Asked Questions`,
    blogCardTitle: (name: string) => `${name} Web Design Resources`,
    blogCardDesc: (name: string) =>
      `Guides, trends, and strategies for ${name} businesses building or redesigning their online presence.`,
    ctaHeading: (name: string) => `Ready for a new ${name} website?`,
    ctaDesc: (name: string) =>
      `Request a free consultation for your ${name} business. We'll review your current site and outline a clear plan.`,
    auditLabel: 'consultation',
    pricingHash: '',
  },
} as const;

const cfg = config[serviceKind];
const siteUrl = Astro.site || new URL(Astro.url.origin);
const pageUrl = new URL(`/${cfg.path}/${city.slug}/`, siteUrl).toString();
const otherCities = allCities.filter((c) => c.slug !== city.slug);

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `${cfg.label} in ${city.name}`,
  description: city.description,
  url: pageUrl,
  provider: {
    '@type': 'LocalBusiness',
    '@id': siteUrl.toString() + '#business',
    name: 'OCWebPros',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Lake Forest',
      addressRegion: 'CA',
      postalCode: '92630',
      addressCountry: 'US',
    },
    telephone: '+1-949-329-4437',
  },
  areaServed: {
    '@type': 'City',
    name: city.name,
    containedInPlace: { '@type': 'State', name: 'California' },
  },
  serviceType: cfg.schemaType,
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: city.faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<MainLayout
  title={city.title}
  description={city.description}
  bodyClass={`page-services page-${cfg.path} page-city-service`}
  pageCSS="/css/pages/services.css"
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />

  <header class="relative pt-32 sm:pt-32 md:pt-40 pb-12 sm:pb-16 px-4 sm:px-6 text-center overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90vw] max-w-[800px] h-[400px] sm:h-[500px] md:h-[600px] glow-bg pointer-events-none opacity-40"></div>
    <div class="max-w-5xl mx-auto relative">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 border border-slate-200 text-xs font-medium text-orange-400 mb-6">
        <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
        {city.badge}
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4">
        {cfg.h1Lead} in <span class="text-gradient-orange">{city.name}</span>
      </h1>
      <p class="text-slate-600 text-lg leading-relaxed max-w-3xl mx-auto">{city.heroSubtitle}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a href="/contact/" class="px-8 py-3.5 bg-orange-700 text-white font-semibold rounded-full hover:bg-orange-600 transition-colors btn-glow text-sm md:text-base">
          Get a Free {city.shortName} {cfg.auditLabel}
        </a>
        <a href={`/pricing/${cfg.pricingHash}`} class="px-8 py-3.5 bg-slate-100 text-slate-900 font-semibold rounded-full border border-slate-200 hover:bg-slate-100 transition-colors text-sm md:text-base">
          View Pricing
        </a>
      </div>
      <dl class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-3 max-w-3xl mx-auto text-left">
        {cityProofStrip.map((item) => (
          <div class="rounded-xl border border-slate-200 bg-white/80 px-4 py-3">
            <dt class="text-[11px] uppercase tracking-wide text-slate-500 font-medium">{item.label}</dt>
            <dd class="text-sm font-semibold text-slate-900 mt-0.5">{item.value}</dd>
          </div>
        ))}
      </dl>
    </div>
  </header>

  <main class="pb-16 sm:pb-24 px-4 sm:px-6 md:px-8">
    <section class="max-w-4xl mx-auto pt-8 pb-12">
      {city.intro.map((paragraph) => (
        <p class="text-slate-700 text-lg leading-relaxed mb-6">{paragraph}</p>
      ))}
      <p class="text-slate-600 text-base leading-relaxed border-l-2 border-orange-500/50 pl-6">{city.marketInsight}</p>
    </section>

    <section class="max-w-7xl mx-auto pt-4 md:pt-8 pb-16 md:pb-24 px-4 sm:px-6">
      <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
        <SpotlightImage class="order-1" aos="fade-left" src={cfg.spotlightSrc} alt={cfg.spotlightAlt(city.name)} />
        <div class="w-full md:w-1/2 backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6 sm:p-8 md:p-10 order-2" data-aos="fade-right">
          <div class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h2 class="text-3xl md:text-4xl font-bold mb-4 text-slate-900">What {city.name} {cfg.label} Includes</h2>
          <p class="text-slate-600 mb-6 text-lg leading-relaxed">{cfg.includesLead(city.name)}</p>
          <ul class="space-y-3 text-slate-700">
            {cfg.includesBullets(city.name).map((bullet) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 w-2 h-2 rounded-full bg-orange-500 flex-shrink-0"></span>
                <span>{bullet}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="max-w-7xl mx-auto py-16 md:py-20 px-4 sm:px-6 md:px-8 bg-slate-50 border-y border-slate-100">
      <div class="grid md:grid-cols-2 gap-10 md:gap-16">
        <div data-aos="fade-up">
          <h2 class="text-2xl md:text-3xl font-bold mb-6 text-slate-900">{city.name} Areas We Serve</h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {city.neighborhoods.map((area) => (
              <li class="flex items-start gap-2 text-sm text-slate-700">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-orange-500 flex-shrink-0"></span>
                <span>{area}</span>
              </li>
            ))}
          </ul>
        </div>
        <div data-aos="fade-up" data-aos-delay="100">
          <h2 class="text-2xl md:text-3xl font-bold mb-6 text-slate-900">Businesses We Help in {city.name}</h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {city.businessTypes.map((type) => (
              <li class="flex items-start gap-2 text-sm text-slate-700">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-orange-500 flex-shrink-0"></span>
                <span>{type}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="max-w-7xl mx-auto pt-16 md:pt-24 pb-12 px-4 sm:px-6 md:px-8">
      <div class="text-center mb-12" data-aos="fade-up">
        <h2 class="text-2xl md:text-3xl font-bold mb-2 text-slate-900">{cfg.servicesHeading(city.name)}</h2>
        <p class="text-slate-600 text-sm md:text-base max-w-2xl mx-auto">{cfg.servicesSub(city.name)}</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {city.services.map((service, index) => (
          <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6" data-aos="fade-up" data-aos-delay={index * 50}>
            <h3 class="text-lg font-bold text-slate-900 mb-2">{service.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="max-w-7xl mx-auto py-16 md:py-20 px-4 sm:px-6 md:px-8">
      <div class="grid md:grid-cols-2 gap-8">
        <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6 sm:p-8" data-aos="fade-up">
          <h2 class="text-xl md:text-2xl font-bold text-slate-900 mb-4">{cfg.challengesHeading(city.name)}</h2>
          <ul class="space-y-3">
            {city.challenges.map((challenge) => (
              <li class="flex items-start gap-3 text-sm text-slate-600">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                <span>{challenge}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="backdrop-blur-[12px] bg-slate-100 border border-orange-500/20 rounded-2xl p-6 sm:p-8" data-aos="fade-up" data-aos-delay="100">
          <h2 class="text-xl md:text-2xl font-bold text-slate-900 mb-4">Why {city.name} Businesses Choose OCWebPros</h2>
          <ul class="space-y-3">
            {city.whyUs.map((reason) => (
              <li class="flex items-start gap-3 text-sm text-slate-700">
                <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span>{reason}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="max-w-7xl mx-auto py-16 md:py-24 px-4 sm:px-6 md:px-8 bg-slate-50 border-y border-slate-100">
      <h2 class="text-2xl md:text-3xl font-bold mb-12 text-center text-slate-900" data-aos="fade-up">{cfg.processHeading(city.name)}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {cfg.processSteps.map((step, index) => (
          <div class="text-center" data-aos="fade-up" data-aos-delay={index * 100}>
            <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-orange-500 text-orange-400 flex items-center justify-center font-bold text-lg mx-auto mb-4">{index + 1}</div>
            <h3 class="font-bold text-slate-900 mb-2">{step.title}</h3>
            <p class="text-sm text-slate-600">{step.desc(city.name)}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="max-w-3xl mx-auto py-16 md:py-24 px-4 sm:px-6">
      <h2 class="text-2xl md:text-3xl font-bold mb-8 text-center text-slate-900" data-aos="fade-up">{cfg.faqHeading(city.name)}</h2>
      <div class="space-y-4 city-faq-list">
        {city.faqs.map((faq, index) => (
          <div class="faq-item backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-xl overflow-hidden transition-all" data-aos="fade-up" data-aos-delay={index * 50}>
            <button class="faq-question w-full text-left p-6 flex items-center justify-between hover:bg-slate-100 transition-colors" aria-expanded="false">
              <span class="font-semibold text-slate-900 pr-4">{faq.question}</span>
              <svg class="w-5 h-5 text-orange-500 flex-shrink-0 faq-icon transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-answer overflow-hidden transition-all duration-300" style="max-height: 0;">
              <p class="px-6 pb-6 text-sm text-slate-600 leading-relaxed">{faq.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="max-w-7xl mx-auto py-12 md:py-16 px-4 sm:px-6 md:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {city.blogSlug && city.blogTitle && (
          <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6 sm:p-8" data-aos="fade-up">
            <h3 class="text-xl font-bold text-slate-900 mb-3">{cfg.blogCardTitle(city.name)}</h3>
            <p class="text-sm text-slate-600 leading-relaxed mb-4">{cfg.blogCardDesc(city.name)}</p>
            <a href={`/blog/${city.blogSlug}/`} class="text-sm text-orange-400 font-medium hover:text-orange-300 transition-colors inline-flex items-center gap-1">
              Read: {city.blogTitle}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        )}
        <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6 sm:p-8" data-aos="fade-up" data-aos-delay="100">
          <h3 class="text-xl font-bold text-slate-900 mb-3">{cfg.sisterLabel} in {city.name}</h3>
          <p class="text-sm text-slate-600 leading-relaxed mb-4">
            Pair your {city.name} {cfg.label.toLowerCase()} with our {cfg.sisterLabel.toLowerCase()} services for full local visibility.
          </p>
          <a href={`/${cfg.sisterPath}/${city.slug}/`} class="text-sm text-orange-400 font-medium hover:text-orange-300 transition-colors inline-flex items-center gap-1">
            {cfg.sisterLabel} in {city.name} →
          </a>
        </div>
        <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6 sm:p-8" data-aos="fade-up" data-aos-delay="200">
          <h3 class="text-xl font-bold text-slate-900 mb-3">All {cfg.label} Services</h3>
          <p class="text-sm text-slate-600 leading-relaxed mb-4">
            See full plan details, pricing, and everything included in our Orange County {cfg.label.toLowerCase()} packages.
          </p>
          <a href={cfg.hubPath} class="text-sm text-orange-400 font-medium hover:text-orange-300 transition-colors inline-flex items-center gap-1">
            View {cfg.hubLabel}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="backdrop-blur-[12px] bg-slate-100 border border-slate-200 rounded-2xl p-6 sm:p-8" data-aos="fade-up" data-aos-delay="300">
          <h3 class="text-xl font-bold text-slate-900 mb-3">More Service Areas</h3>
          <ul class="space-y-2">
            {otherCities.slice(0, 6).map((other) => (
              <li>
                <a href={`/${cfg.path}/${other.slug}/`} class="text-sm text-orange-400 font-medium hover:text-orange-300 transition-colors">
                  {cfg.label} in {other.name} →
                </a>
              </li>
            ))}
            <li>
              <a href="/service-areas/" class="text-sm text-orange-400 font-medium hover:text-orange-300 transition-colors">
                All {allCities.length} Orange County service areas →
              </a>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <div class="text-center py-12 sm:py-16 md:py-24 px-4 sm:px-6 md:px-8" data-aos="fade-up">
      <h2 class="text-2xl md:text-3xl font-bold mb-4 text-slate-900">{cfg.ctaHeading(city.name)}</h2>
      <p class="text-slate-600 mb-8 max-w-xl mx-auto">{cfg.ctaDesc(city.name)}</p>
      <div class="inline-flex flex-col sm:flex-row gap-4">
        <a href="/contact/" class="px-10 py-5 bg-orange-700 text-white font-bold rounded-full hover:bg-orange-600 transition-colors text-lg btn-glow">
          Get a free {city.shortName} {cfg.auditLabel}
        </a>
        <a href="/pricing/" class="px-10 py-5 bg-slate-100 text-slate-900 font-bold rounded-full border border-slate-200 hover:bg-slate-100 transition-colors text-lg">
          View pricing
        </a>
      </div>
      <p class="text-slate-600 text-sm mt-3">Based in Lake Forest — serving all of {city.name} and South OC.</p>
    </div>
  </main>
</MainLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.city-faq-list .faq-item').forEach((item) => {
      const button = item.querySelector('.faq-question');
      const answer = item.querySelector('.faq-answer') as HTMLElement | null;
      const icon = item.querySelector('.faq-icon');
      if (!button || !answer) return;

      button.addEventListener('click', () => {
        const isOpen = button.getAttribute('aria-expanded') === 'true';
        const list = item.closest('.city-faq-list');
        list?.querySelectorAll('.faq-item').forEach((otherItem) => {
          if (otherItem !== item) {
            otherItem.querySelector('.faq-question')?.setAttribute('aria-expanded', 'false');
            const otherAnswer = otherItem.querySelector('.faq-answer') as HTMLElement | null;
            if (otherAnswer) otherAnswer.style.maxHeight = '0';
            otherItem.querySelector('.faq-icon')?.classList.remove('rotate-180');
          }
        });

        if (isOpen) {
          button.setAttribute('aria-expanded', 'false');
          answer.style.maxHeight = '0';
          icon?.classList.remove('rotate-180');
        } else {
          button.setAttribute('aria-expanded', 'true');
          answer.style.maxHeight = answer.scrollHeight + 'px';
          icon?.classList.add('rotate-180');
        }
      });
    });
  });
</script>
